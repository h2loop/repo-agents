@@ -86,7 +86,7 @@ Description Defines functions executed at the ESM Service Access
  **      Others:    None                                       **
  **                                                                        **
  ***************************************************************************/
-int esm_recv_status(int pti, int ebi, const esm_status_msg *msg)
+int esm_recv_status(nas_user_t *user, int pti, int ebi, const esm_status_msg *msg)
 {
   int esm_cause;
   int rc;
@@ -107,6 +107,29 @@ int esm_recv_status(int pti, int ebi, const esm_status_msg *msg)
 
   if (rc != RETURNerror) {
     esm_cause = ESM_CAUSE_SUCCESS;
+    
+    /* Check for active bearers and trigger scheduling request if needed */
+    if (user && user->esm_data && user->lowerlayer_data) {
+      bool has_active_bearers = false;
+      
+      /* Iterate through PDN connections to check for active bearers */
+      for (int i = 0; i < user->esm_data->n_pdns; i++) {
+        if (user->esm_data->pdn[i].is_active && user->esm_data->pdn[i].data) {
+          /* Check if there are active bearers */
+          if (user->esm_data->pdn[i].data->n_bearers > 0) {
+            has_active_bearers = true;
+            LOG_TRACE(INFO, "ESM-SAP   - Active bearer found on PDN %d", i);
+            break;
+          }
+        }
+      }
+      
+      /* Set scheduling request flag if active bearers are found */
+      if (has_active_bearers) {
+        LOG_TRACE(INFO, "ESM-SAP   - Active bearers detected, setting scheduling request");
+        user->lowerlayer_data->sched_req = true;
+      }
+    }
   }
 
   /* Return the ESM cause value */
