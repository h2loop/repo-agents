+/* Helper function to get maximum MCS capability for a UE */
+static uint8_t get_ue_max_mcs_capability(uint8_t Mod_id, uint8_t ue_id) {
+  /* Default maximum MCS for LTE is 28 (QPSK, 16QAM, 64QAM support) */
+  uint8_t max_mcs = 28;
+  
+  /* Check if UE capability information is available */
+  if (RC.rrc[Mod_id] && RC.rrc[Mod_id]->carrier[0].UE_active[ue_id]) {
+    /* In a real implementation, we would check UE_Capability here
+     * For now, we'll use a conservative approach based on common UE categories */
+    
+    /* UE Category 1-2: max MCS 21 (16QAM only) */
+    /* UE Category 3-5: max MCS 28 (64QAM support) */
+    /* For MBMS, we should be conservative and assume lower categories */
+    
+    /* Conservative default for MBMS - assume UE Category 2 capabilities */
+    max_mcs = 21; /* Limit to 16QAM for better reliability in MBMS */
+    
+    LOG_D(RRC, "UE %d max MCS capability estimated as %d for MBMS\n", ue_id, max_mcs);
+  }
+  
+  return max_mcs;
+}
