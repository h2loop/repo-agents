 static bool decode_cu_to_du_rrc_info(f1ap_cu_to_du_rrc_info_t *dec, const F1AP_CUtoDURRCInformation_t *cu2du)
 {
+  /* Note: This function does not have access to SpCellID/ServCellIndex fields
+   * as they are separate IEs at the UE Context message level. 
+   * Validation for 3GPP TS 38.473 compliance should be done at that level. */
+  
   if (cu2du->cG_ConfigInfo) {
     dec->cg_configinfo = calloc_or_fail(1, sizeof(*dec->cg_configinfo));
