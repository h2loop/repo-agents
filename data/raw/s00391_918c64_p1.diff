--- a/nfapi/open-nFAPI/common/src/nfapi.c
+++ b/nfapi/open-nFAPI/common/src/nfapi.c
@@ -53,6 +53,9 @@
 #include <nfapi.h>
 #include <debug.h>
 
+// Static mutex for thread-safe access to pusharrays32
+static pthread_mutex_t pusharrays32_mutex = PTHREAD_MUTEX_INITIALIZER;
+
 // What to do when an error happens (e.g., a push or pull fails)
 static inline void on_error()
 {
@@ -498,11 +501,19 @@ uint32_t pusharray32(const uint32_t *values_to_push,
 }
 uint32_t pusharrays32(int32_t in[], uint32_t max_len, uint32_t len, uint8_t **out, uint8_t *end)
 {
-  if (len == 0)
+  if (pthread_mutex_lock(&pusharrays32_mutex) != 0) {
+    NFAPI_TRACE(NFAPI_TRACE_ERROR, "%s failed to acquire mutex\n", __FUNCTION__);
+    return 0;
+  }
+
+  if (len == 0) {
+    pthread_mutex_unlock(&pusharrays32_mutex);
     return 1;
+  }
 
   if (len > max_len) {
     NFAPI_TRACE(NFAPI_TRACE_ERROR, "%s exceed array size (%d > %d)\n", __FUNCTION__, len, max_len);
+    pthread_mutex_unlock(&pusharrays32_mutex);
