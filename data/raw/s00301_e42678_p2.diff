+/* Structure to wrap NAS timer callback and arguments
+ * ----------------------------------------------------
+ * This wrapper ensures type safety when passing callbacks to the ITTI
+ * timer system, preventing type confusion vulnerabilities.
+ */
+typedef struct {
+  nas_timer_callback_t cb;    /* Original NAS timer callback function */
+  void *args;                 /* Original callback arguments          */
+} nas_timer_wrapper_t;
+
+/* Handler function for timer expiry that unwraps and calls original callback */
+static void nas_timer_wrapper_handler(void *arg) {
+  nas_timer_wrapper_t *wrapper = (nas_timer_wrapper_t *)arg;
+  if (wrapper && wrapper->cb) {
+    wrapper->cb(wrapper->args);
+    free(wrapper);  // Free the wrapper after use
+  }
+}
