+/**
+ * nas_timer_itti_handler: Handler called by ITTI timer system
+ * @param timer_id: ITTI timer identifier
+ * @param arg: Pointer to nas_timer_wrapper_t containing callback and args
+ * 
+ * This function unwraps the timer callback and arguments, then invokes
+ * the original NAS timer callback with the correct arguments to prevent
+ * type confusion vulnerabilities.
+ */
+static void nas_timer_itti_handler(long timer_id, void *arg)
+{
+  nas_timer_wrapper_t *wrapper = (nas_timer_wrapper_t *)arg;
+  
+  if (wrapper != NULL) {
+    /* Invoke the original callback with the correct arguments */
+    if (wrapper->cb != NULL) {
+      wrapper->cb(wrapper->args);
+    }
+    /* Free the wrapper after use */
+    free(wrapper);
+  }
+}
 
