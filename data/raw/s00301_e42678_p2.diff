+/**
+ * nas_ue_timer_expired: Handle timer expiry messages from ITTI
+ * @param instance: Instance identifier
+ * @param timer_expired: Timer expiry message containing timer_id and arg
+ * 
+ * This function handles timer expiry messages from the ITTI timer subsystem.
+ * It extracts the wrapper from the timer_arg and calls the appropriate handler.
+ */
+static void nas_ue_timer_expired(instance_t instance, timer_has_expired_t *timer_expired)
+{
+  if (timer_expired == NULL) {
+    LOG_E(NAS, "Received NULL timer_expired message\n");
+    return;
+  }
+  
+  if (timer_expired->arg != NULL) {
+    /* The arg contains our wrapper with the original callback */
+    nas_timer_wrapper_t *wrapper = (nas_timer_wrapper_t *)timer_expired->arg;
+    
+    if (wrapper->cb != NULL) {
+      /* Call the original NAS timer callback with the correct arguments */
+      wrapper->cb(wrapper->args);
+    }
+    
+    /* Free the wrapper as it's no longer needed */
+    free(wrapper);
+  } else {
+    LOG_W(NAS, "Timer expired with NULL arg\n");
+  }
+}
