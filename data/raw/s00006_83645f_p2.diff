+/**
+ * \fn void clear_job_list(Job_list* job_list_ptr)
+ * \brief Safely traverse and free all memory associated with a job list, including nested mobility structures.
+ *        This function prevents memory leaks and stale protocol state by properly cleaning up job lists
+ *        after procedure completion or failure. It performs defensive NULL checking at each nesting level
+ *        and frees mobility structures, node pairs, and job list nodes in the correct order.
+ * \param job_list_ptr pointer to the job list pointer to be cleared (will be set to NULL after cleanup)
+ * \note This function addresses the issue where nodes_avgspeed() accessed job list entries without proper
+ *       validation, risking division by zero and NULL pointer dereferences when the list contained invalid entries.
+ */
+void clear_job_list(job_list** job_list_ptr);
