+void pnf_handle_rssi_indication(pnf_t* pnf, void *pRecvMsg, int recvMsgLen)
+{
+	nfapi_rssi_indication_t ind;
+	
+	// validate the input params
+	if(pRecvMsg == NULL || recvMsgLen < NFAPI_HEADER_LENGTH)
+	{
+		NFAPI_TRACE(NFAPI_TRACE_ERROR, "%s: invalid input params\n", __FUNCTION__);
+		return;
+	}
+	
+	// unpack the message
+	if(nfapi_p4_message_unpack(pRecvMsg, recvMsgLen, &ind, sizeof(ind), &pnf->_public.codec_config) < 0)
+	{
+		NFAPI_TRACE(NFAPI_TRACE_ERROR, "%s: unpack failed\n", __FUNCTION__);
+		return;
+	}
+	
+	// check pnf state
+	if(pnf->_public.state != NFAPI_PNF_RUNNING)
+	{
+		NFAPI_TRACE(NFAPI_TRACE_ERROR, "%s: PNF not in RUNNING state (%d)\n", __FUNCTION__, pnf->_public.state);
+		return;
+	}
+	
+	// find the phy
+	nfapi_pnf_phy_config_t* phy = nfapi_pnf_phy_config_find(&pnf->_public, ind.header.phy_id);
+	if(phy == NULL)
+	{
+		NFAPI_TRACE(NFAPI_TRACE_ERROR, "%s: phy not found\n", __FUNCTION__);
+		return;
+	}
+	
+	// check phy state
+	if(phy->state != NFAPI_PNF_PHY_RUNNING)
+	{
+		NFAPI_TRACE(NFAPI_TRACE_ERROR, "%s: PHY not in RUNNING state (%d)\n", __FUNCTION__, phy->state);
+		return;
+	}
+	
+	// call the client callback if registered
+	if(pnf->_public.rssi_ind)
+	{
+		(pnf->_public.rssi_ind)(&pnf->_public, phy, &ind);
+	}
+	else
+	{
+		NFAPI_TRACE(NFAPI_TRACE_INFO, "%s: no client callback registered\n", __FUNCTION__);
+	}
+}
