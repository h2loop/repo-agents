diff --git a/openair3/NAS/COMMON/IES/EsmMessageContainer.c b/openair3/NAS/COMMON/IES/EsmMessageContainer.c
index e33c06c71d..7b2f4e1c61 100644
--- a/openair3/NAS/COMMON/IES/EsmMessageContainer.c
+++ b/openair3/NAS/COMMON/IES/EsmMessageContainer.c
@@ -91,13 +91,26 @@ int encode_esm_message_container(EsmMessageContainer *esmmessagecontainer, uint8
 
 void dump_esm_message_container_xml(EsmMessageContainer *esmmessagecontainer, uint8_t iei)
 {
+  char *xml_output;
+
   printf("<Esm Message Container>\n");
 
   if (iei > 0)
     /* Don't display IEI if = 0 */
     printf("    <IEI>0x%X</IEI>\n", iei);
 
-  printf("%s", dump_octet_string_xml(&esmmessagecontainer->esmmessagecontainercontents));
+  /* Validate input pointer */
+  if (esmmessagecontainer == NULL) {
+    printf("    <Error>NULL pointer: EsmMessageContainer</Error>\n");
+  } else {
+    xml_output = dump_octet_string_xml(&esmmessagecontainer->esmmessagecontainercontents);
+    if (xml_output != NULL) {
+      printf("%s", xml_output);
+    } else {
+      printf("    <Error>NULL pointer: dump_octet_string_xml returned NULL</Error>\n");
+    }
+  }
+
   printf("</Esm Message Container>\n");
 }
 
diff --git a/openair3/NAS/COMMON/UTIL/OctetString.c b/openair3/NAS/COMMON/UTIL/OctetString.c
index 2f1b7b2c32..1354131dc0 100644
--- a/openair3/NAS/COMMON/UTIL/OctetString.c
+++ b/openair3/NAS/COMMON/UTIL/OctetString.c
@@ -94,17 +94,53 @@ char* dump_octet_string_xml( const OctetString * const octetstring)
   int size           = 0;
   int size_print     = 0;
 
+  /* Validate input pointer */
+  if (octetstring == NULL) {
+    snprintf(_dump_output, DUMP_OUTPUT_SIZE, 
+             "<Error>NULL pointer: OctetString</Error>\n");
+    return _dump_output;
+  }
+
+  /* Validate value pointer - can be NULL if length is 0 */
+  if (octetstring->value == NULL && octetstring->length > 0) {
+    snprintf(_dump_output, DUMP_OUTPUT_SIZE, 
+             "<Error>NULL value pointer with non-zero length</Error>\n");
+    return _dump_output;
+  }
+
   size_print = snprintf(_dump_output, remaining_size, "<Length>%u</Length>\n\t<values>", octetstring->length);
+  if (size_print < 0 || size_print >= remaining_size) {
+    snprintf(_dump_output, DUMP_OUTPUT_SIZE, 
+             "<Error>Failed to format Length field</Error>\n");
+    return _dump_output;
+  }
   size += size_print;
   remaining_size -= size_print;
 
-  for (i = 0; i < octetstring->length; i++) {
+  for (i = 0; i < octetstring->length && remaining_size > 0; i++) {
 	size_print = snprintf(&_dump_output[size], remaining_size, "0x%x ", octetstring->value[i]);
+	if (size_print < 0 || size_print >= remaining_size) {
+      snprintf(_dump_output, DUMP_OUTPUT_SIZE, 
+               "<Error>Failed to format value at index %d</Error>\n", i);
+      return _dump_output;
+    }
 	size += size_print;
     remaining_size -= size_print;
   }
 
+  if (remaining_size <= 0) {
+    snprintf(_dump_output, DUMP_OUTPUT_SIZE, 
+             "<Error>Buffer overflow: insufficient space for values</Error>\n");
+    return _dump_output;
+  }
+
   size_print = snprintf(&_dump_output[size], remaining_size, "</values>\n");
+  if (size_print < 0 || size_print >= remaining_size) {
+    snprintf(_dump_output, DUMP_OUTPUT_SIZE, 
+             "<Error>Failed to close values tag</Error>\n");
+    return _dump_output;
+  }
+
   return _dump_output;
 }
 
