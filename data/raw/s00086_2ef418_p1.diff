diff --git a/openair3/NAS/TEST/AS_SIMULATOR/as_data.c b/openair3/NAS/TEST/AS_SIMULATOR/as_data.c
index 56b00125a4..b37f302010 100644
--- a/openair3/NAS/TEST/AS_SIMULATOR/as_data.c
+++ b/openair3/NAS/TEST/AS_SIMULATOR/as_data.c
@@ -66,13 +66,17 @@ Description Defines constants and functions used by the AS simulator
  */
 const char* getTime(void)
 {
-#define TIME_BUFFER_SIZE  16
+#define TIME_BUFFER_SIZE  32
   static char time_buffer[TIME_BUFFER_SIZE];
   struct timespec ts;
 
-  clock_gettime (CLOCK_REALTIME, &ts);
-  snprintf(time_buffer, TIME_BUFFER_SIZE, "%.6ld:%.6ld",
-           ts.tv_sec % 3600, ts.tv_nsec / 1000);
+  if (clock_gettime(CLOCK_REALTIME, &ts) == 0) {
+    snprintf(time_buffer, TIME_BUFFER_SIZE, "%ld:%06ld",
+             ts.tv_sec % 3600, ts.tv_nsec / 1000);
+  } else {
+    /* Provide fallback timestamp if clock_gettime fails */
+    snprintf(time_buffer, TIME_BUFFER_SIZE, "0:000000");
+  }
   return (time_buffer);
 }
 
