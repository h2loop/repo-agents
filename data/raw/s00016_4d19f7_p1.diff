diff --git a/openair2/LAYER2/MAC/eNB_scheduler_fairRR.c b/openair2/LAYER2/MAC/eNB_scheduler_fairRR.c
index 3d38a55421..9d0ac1549d 100644
--- a/openair2/LAYER2/MAC/eNB_scheduler_fairRR.c
+++ b/openair2/LAYER2/MAC/eNB_scheduler_fairRR.c
@@ -200,6 +200,75 @@ void dlsch_scheduler_pre_ue_select_fairRR(
     saved_dlsch_dci[CC_id] = DL_req->number_pdu;
   }
 
+  // Insert DLSCH(SI and PAGING) UE into selected UE list with highest priority
+  for (CC_id = 0; CC_id < MAX_NUM_CCs; CC_id++) {
+    if (mbsfn_flag[CC_id]>0) {
+      continue;
+    }
+
+    DL_req = &eNB->DL_req[CC_id].dl_config_request_body;
+
+    // Check for SI traffic - highest priority
+    if (eNB->common_channels[CC_id].SI_active == 1) {
+      aggregation = 4; // Use higher aggregation for SI for reliability
+      format_flag = 0; // SI uses format 1A/1C
+      
+      if (!CCE_allocation_infeasible(module_idP, CC_id, format_flag, subframeP, aggregation, SI_RNTI)) {
+        dl_config_pdu = &DL_req->dl_config_pdu_list[DL_req->number_pdu];
+        dl_config_pdu->pdu_type = NFAPI_DL_CONFIG_DCI_DL_PDU_TYPE;
+        dl_config_pdu->dci_dl_pdu.dci_dl_pdu_rel8.rnti = SI_RNTI;
+        dl_config_pdu->dci_dl_pdu.dci_dl_pdu_rel8.rnti_type = 2; // SI-RNTI
+        dl_config_pdu->dci_dl_pdu.dci_dl_pdu_rel8.aggregation_level = aggregation;
+        DL_req->number_pdu++;
+        
+        // Insert SI into selected UE list with highest priority
+        dlsch_ue_select[CC_id].list[dlsch_ue_select[CC_id].ue_num].UE_id = -1; // Special ID for SI
+        dlsch_ue_select[CC_id].list[dlsch_ue_select[CC_id].ue_num].ue_priority = SCH_DL_SI;
+        dlsch_ue_select[CC_id].list[dlsch_ue_select[CC_id].ue_num].rnti = SI_RNTI;
+        dlsch_ue_select[CC_id].list[dlsch_ue_select[CC_id].ue_num].nb_rb = 4; // Minimum RBs for SI
+        dlsch_ue_select[CC_id].ue_num++;
+        
+        if (dlsch_ue_select[CC_id].ue_num == dlsch_ue_max_num[CC_id]) {
+          end_flag[CC_id] = 1;
+        }
+      }
+    }
+
+    // Check for PAGING traffic - second highest priority  
+    if (eNB->common_channels[CC_id].PAGING_active == 1 && end_flag[CC_id] == 0) {
+      aggregation = 4; // Use higher aggregation for PAGING for reliability
+      format_flag = 0; // PAGING uses format 1A/1C
+      
+      if (!CCE_allocation_infeasible(module_idP, CC_id, format_flag, subframeP, aggregation, P_RNTI)) {
+        dl_config_pdu = &DL_req->dl_config_pdu_list[DL_req->number_pdu];
+        dl_config_pdu->pdu_type = NFAPI_DL_CONFIG_DCI_DL_PDU_TYPE;
+        dl_config_pdu->dci_dl_pdu.dci_dl_pdu_rel8.rnti = P_RNTI;
+        dl_config_pdu->dci_dl_pdu.dci_dl_pdu_rel8.rnti_type = 2; // P-RNTI
+        dl_config_pdu->dci_dl_pdu.dci_dl_pdu_rel8.aggregation_level = aggregation;
+        DL_req->number_pdu++;
+        
+        // Insert PAGING into selected UE list with high priority
+        dlsch_ue_select[CC_id].list[dlsch_ue_select[CC_id].ue_num].UE_id = -2; // Special ID for PAGING
+        dlsch_ue_select[CC_id].list[dlsch_ue_select[CC_id].ue_num].ue_priority = SCH_DL_PAGING;
+        dlsch_ue_select[CC_id].list[dlsch_ue_select[CC_id].ue_num].rnti = P_RNTI;
+        dlsch_ue_select[CC_id].list[dlsch_ue_select[CC_id].ue_num].nb_rb = 4; // Minimum RBs for PAGING
+        dlsch_ue_select[CC_id].ue_num++;
+        
+        if (dlsch_ue_select[CC_id].ue_num == dlsch_ue_max_num[CC_id]) {
+          end_flag[CC_id] = 1;
+        }
+      }
+    }
+  }
+
+  if(cc_id_end(end_flag) == 1) {
+    for (CC_id = 0; CC_id < MAX_NUM_CCs; CC_id++) {
+      DL_req = &eNB->DL_req[CC_id].dl_config_request_body;
+      DL_req->number_pdu = saved_dlsch_dci[CC_id];
+    }
+    return;
+  }
+
   // Insert DLSCH(retransmission) UE into selected UE list
   for (CC_id = 0; CC_id < MAX_NUM_CCs; CC_id++) {
     if (mbsfn_flag[CC_id]>0) {
@@ -973,12 +1042,10 @@ void dlsch_scheduler_pre_processor_fairRR (module_id_t   Mod_id,
     temp_total_ue_count = dlsch_ue_select[CC_id].ue_num;
 
     for (i = 0; i < dlsch_ue_select[CC_id].ue_num; i++) {
-      if(dlsch_ue_select[CC_id].list[i].ue_priority == SCH_DL_MSG2) {
-        temp_total_ue_count--;
-        continue;
-      }
-
-      if(dlsch_ue_select[CC_id].list[i].ue_priority == SCH_DL_MSG4) {
+      if(dlsch_ue_select[CC_id].list[i].ue_priority == SCH_DL_SI ||
+         dlsch_ue_select[CC_id].list[i].ue_priority == SCH_DL_PAGING ||
+         dlsch_ue_select[CC_id].list[i].ue_priority == SCH_DL_MSG2 ||
+         dlsch_ue_select[CC_id].list[i].ue_priority == SCH_DL_MSG4) {
         temp_total_ue_count--;
         continue;
       }
