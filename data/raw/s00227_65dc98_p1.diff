 #include "nr_rrc_extern.h"
 #include "cucp_cuup_if.h"
 
+static void deep_copy_e1ap_bearer_setup_req(e1ap_bearer_setup_req_t *dest, const e1ap_bearer_setup_req_t *src)
+{
+  // Copy primitive fields
+  dest->gNB_cu_cp_ue_id = src->gNB_cu_cp_ue_id;
+  dest->gNB_cu_up_ue_id = src->gNB_cu_up_ue_id;
+  dest->cipheringAlgorithm = src->cipheringAlgorithm;
+  dest->integrityProtectionAlgorithm = src->integrityProtectionAlgorithm;
+  memcpy(dest->encryptionKey, src->encryptionKey, sizeof(dest->encryptionKey));
+  memcpy(dest->integrityProtectionKey, src->integrityProtectionKey, sizeof(dest->integrityProtectionKey));
+  dest->ueDlAggMaxBitRate = src->ueDlAggMaxBitRate;
+  dest->servingPLMNid = src->servingPLMNid;
+  dest->bearerContextStatus = src->bearerContextStatus;
+  dest->activityNotificationLevel = src->activityNotificationLevel;
+
+  // Copy PDU sessions
+  dest->numPDUSessions = src->numPDUSessions;
+  for (int i = 0; i < src->numPDUSessions; i++) {
+    dest->pduSession[i].sessionId = src->pduSession[i].sessionId;
+    dest->pduSession[i].sessionType = src->pduSession[i].sessionType;
+    dest->pduSession[i].nssai = src->pduSession[i].nssai;
+    dest->pduSession[i].integrityProtectionIndication = src->pduSession[i].integrityProtectionIndication;
+    dest->pduSession[i].confidentialityProtectionIndication = src->pduSession[i].confidentialityProtectionIndication;
+    dest->pduSession[i].tlAddress = src->pduSession[i].tlAddress;
+    dest->pduSession[i].tlAddress_dl = src->pduSession[i].tlAddress_dl;
+    dest->pduSession[i].teId = src->pduSession[i].teId;
+    dest->pduSession[i].teId_dl = src->pduSession[i].teId_dl;
+    dest->pduSession[i].tl_port = src->pduSession[i].tl_port;
+    dest->pduSession[i].tl_port_dl = src->pduSession[i].tl_port_dl;
+    dest->pduSession[i].numDRB2Setup = src->pduSession[i].numDRB2Setup;
+    
+    // Copy DRB to setup list
+    for (int j = 0; j < src->pduSession[i].numDRB2Setup; j++) {
+      dest->pduSession[i].DRBnGRanList[j] = src->pduSession[i].DRBnGRanList[j];
+    }
+    
+    dest->pduSession[i].numDRB2Modify = src->pduSession[i].numDRB2Modify;
+    // Note: DRBnGRanModList is copied but the structure definition is not fully visible
+    // Assuming it's safe to copy as it contains only primitive types
+    for (int j = 0; j < src->pduSession[i].numDRB2Modify; j++) {
+      dest->pduSession[i].DRBnGRanModList[j] = src->pduSession[i].DRBnGRanModList[j];
+    }
+  }
+
+  // Copy PDU sessions to modify
+  dest->numPDUSessionsMod = src->numPDUSessionsMod;
+  for (int i = 0; i < src->numPDUSessionsMod; i++) {
+    dest->pduSessionMod[i].sessionId = src->pduSessionMod[i].sessionId;
+    dest->pduSessionMod[i].sessionType = src->pduSessionMod[i].sessionType;
+    dest->pduSessionMod[i].nssai = src->pduSessionMod[i].nssai;
+    dest->pduSessionMod[i].integrityProtectionIndication = src->pduSessionMod[i].integrityProtectionIndication;
+    dest->pduSessionMod[i].confidentialityProtectionIndication = src->pduSessionMod[i].confidentialityProtectionIndication;
+    dest->pduSessionMod[i].tlAddress = src->pduSessionMod[i].tlAddress;
+    dest->pduSessionMod[i].tlAddress_dl = src->pduSessionMod[i].tlAddress_dl;
+    dest->pduSessionMod[i].teId = src->pduSessionMod[i].teId;
+    dest->pduSessionMod[i].teId_dl = src->pduSessionMod[i].teId_dl;
+    dest->pduSessionMod[i].tl_port = src->pduSessionMod[i].tl_port;
+    dest->pduSessionMod[i].tl_port_dl = src->pduSessionMod[i].tl_port_dl;
+    dest->pduSessionMod[i].numDRB2Setup = src->pduSessionMod[i].numDRB2Setup;
+    
+    // Copy DRB to setup list
+    for (int j = 0; j < src->pduSessionMod[i].numDRB2Setup; j++) {
+      dest->pduSessionMod[i].DRBnGRanList[j] = src->pduSessionMod[i].DRBnGRanList[j];
+    }
+    
+    dest->pduSessionMod[i].numDRB2Modify = src->pduSessionMod[i].numDRB2Modify;
+    // Copy DRB to modify list
+    for (int j = 0; j < src->pduSessionMod[i].numDRB2Modify; j++) {
+      dest->pduSessionMod[i].DRBnGRanModList[j] = src->pduSessionMod[i].DRBnGRanModList[j];
+    }
+  }
+}
+
 static void cucp_cuup_bearer_context_setup_e1ap(sctp_assoc_t assoc_id, const e1ap_bearer_setup_req_t *req)
 {
   AssertFatal(assoc_id > 0, "illegal assoc_id %d\n", assoc_id);
   MessageDef *msg_p = itti_alloc_new_message(TASK_CUCP_E1, 0, E1AP_BEARER_CONTEXT_SETUP_REQ);
   msg_p->ittiMsgHeader.originInstance = assoc_id;
   e1ap_bearer_setup_req_t *bearer_req = &E1AP_BEARER_CONTEXT_SETUP_REQ(msg_p);
-  memcpy(bearer_req, req, sizeof(e1ap_bearer_setup_req_t));
+  
+  // Use deep copy instead of memcpy to prevent potential buffer overflow
+  deep_copy_e1ap_bearer_setup_req(bearer_req, req);
 
   itti_send_msg_to_task (TASK_CUCP_E1, 0, msg_p);
 }
