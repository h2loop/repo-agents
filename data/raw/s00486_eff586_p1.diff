diff --git a/openair2/LAYER2/NR_MAC_gNB/nr_radio_config.c b/openair2/LAYER2/NR_MAC_gNB/nr_radio_config.c
index 5fba6dcaaf..2bd6f4f168 100644
--- a/openair2/LAYER2/NR_MAC_gNB/nr_radio_config.c
+++ b/openair2/LAYER2/NR_MAC_gNB/nr_radio_config.c
@@ -1518,12 +1518,45 @@ static struct NR_SetupRelease_PUSCH_Config *config_pusch(NR_PUSCH_Config_t *pusc
   pusch_Config->pusch_AggregationFactor = NULL;
   set_ul_mcs_table(uecap, scc, pusch_Config);
   pusch_Config->transformPrecoder = NULL;
+  
+  // Configure UL MIMO parameters based on UE capabilities and gNB config
+  // Default to conservative values if no UE capabilities available
+  uint8_t ul_max_layers = 1;
+  
+  if (uecap && uecap->featureSets && uecap->featureSets->featureSetsUplinkPerCC
+      && uecap->featureSets->featureSetsUplinkPerCC->list.count > 0) {
+    NR_FeatureSetUplinkPerCC_t *ul_feature_setup_per_cc = uecap->featureSets->featureSetsUplinkPerCC->list.array[0];
+    if (ul_feature_setup_per_cc->mimo_CB_PUSCH && ul_feature_setup_per_cc->mimo_CB_PUSCH->maxNumberMIMO_LayersCB_PUSCH) {
+      switch (*ul_feature_setup_per_cc->mimo_CB_PUSCH->maxNumberMIMO_LayersCB_PUSCH) {
+        case NR_MIMO_LayersUL_twoLayers:
+          ul_max_layers = 2;
+          break;
+        case NR_MIMO_LayersUL_fourLayers:
+          ul_max_layers = 4;
+          break;
+        default:
+          ul_max_layers = 1;
+      }
+    }
+  }
+  
+  // Set codebookSubset based on UE capabilities and layers
   if (!pusch_Config->codebookSubset)
     pusch_Config->codebookSubset = calloc(1, sizeof(*pusch_Config->codebookSubset));
-  *pusch_Config->codebookSubset = NR_PUSCH_Config__codebookSubset_nonCoherent;
+  
+  // For multi-layer capable UEs, use partialAndNonCoherent for better performance
+  // For single layer, use nonCoherent as default
+  if (ul_max_layers > 1) {
+    *pusch_Config->codebookSubset = NR_PUSCH_Config__codebookSubset_partialAndNonCoherent;
+  } else {
+    *pusch_Config->codebookSubset = NR_PUSCH_Config__codebookSubset_nonCoherent;
+  }
+  
+  // Set maxRank based on UE capabilities
   if (!pusch_Config->maxRank)
     pusch_Config->maxRank = calloc(1, sizeof(*pusch_Config->maxRank));
-  *pusch_Config->maxRank = 1;
+  *pusch_Config->maxRank = ul_max_layers;
+  
   pusch_Config->rbg_Size = NULL;
   pusch_Config->uci_OnPUSCH = NULL;
   pusch_Config->tp_pi2BPSK = NULL;
