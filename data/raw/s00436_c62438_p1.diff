--- a/openair2/UTIL/OTG/otg_models.c
+++ b/openair2/UTIL/OTG/otg_models.c
@@ -100,6 +100,16 @@ double tarmaCalculateSample( double inputSamples[], tarmaProcess_t *proc)
   }
 
   LOG_D(OTG,"TARMA_DEBUG: tarmaCalculateSamples called: Z=%f\n",Z);
+  
+  /* Clamp the output value to prevent buffer overruns in downstream string operations */
+  if (Z > 1000000.0) {
+    LOG_W(OTG, "TARMA: Clamping large value %f to 1000000.0 to prevent buffer overrun\n", Z);
+    Z = 1000000.0;
+  } else if (Z < -1000000.0) {
+    LOG_W(OTG, "TARMA: Clamping large negative value %f to -1000000.0 to prevent buffer overrun\n", Z);
+    Z = -1000000.0;
+  }
+  
   //tarmaPrintProc(proc);
   return Z;
 }
