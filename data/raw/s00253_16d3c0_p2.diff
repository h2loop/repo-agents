+/**
+ * @brief Get maximum MCS capability based on UE category
+ * @return Maximum MCS value (conservative: Category 2 -> MCS 21)
+ */
+static uint8_t get_ue_max_mcs_capability(void) {
+  // Conservative approach: assume Category 2 capabilities for MBMS
+  // Category 2 supports up to MCS 21 with 16QAM
+  // This ensures compatibility with most UEs while maintaining reliability
+  return 21;
+}
+
+/**
+ * @brief Map CQI value to MCS using standard 3GPP mapping table
+ * @param cqi Average CQI value across UEs (1-15)
+ * @return MCS value (0-28)
+ */
+static uint8_t map_cqi_to_mcs(uint8_t cqi) {
+  // Standard CQI-to-MCS mapping based on 3GPP TS 36.213
+  // Conservative mapping to ensure reliable transmission for broadcast
+  static const uint8_t cqi_to_mcs_table[16] = {
+    0,  // CQI 0  -> MCS 0 (out of range)
+    0,  // CQI 1  -> MCS 0 (QPSK)
+    0,  // CQI 2  -> MCS 0 (QPSK)
+    2,  // CQI 3  -> MCS 2 (QPSK)
+    4,  // CQI 4  -> MCS 4 (QPSK)
+    6,  // CQI 5  -> MCS 6 (QPSK)
+    8,  // CQI 6  -> MCS 8 (QPSK)
+    10, // CQI 7  -> MCS 10 (16QAM)
+    12, // CQI 8  -> MCS 12 (16QAM)
+    13, // CQI 9  -> MCS 13 (16QAM)
+    15, // CQI 10 -> MCS 15 (16QAM)
+    17, // CQI 11 -> MCS 17 (16QAM)
+    19, // CQI 12 -> MCS 19 (16QAM)
+    20, // CQI 13 -> MCS 20 (16QAM)
+    21, // CQI 14 -> MCS 21 (16QAM)
+    22  // CQI 15 -> MCS 22 (64QAM)
+  };
+  
+  if (cqi > 15) cqi = 15;
+  return cqi_to_mcs_table[cqi];
+}
+
+/**
+ * @brief Calculate average CQI across all active UEs
+ * @param Mod_id eNB module ID
+ * @return Average CQI value (1-15)
+ */
+static uint8_t calculate_average_cqi(uint8_t Mod_id) {
+  // For now, return a conservative default CQI value
+  // In a full implementation, this would iterate through all active UE contexts
+  // and calculate the average of their reported CQI values
+  // Default to moderate channel quality (CQI 8 -> MCS 12)
+  return 8;
+}
