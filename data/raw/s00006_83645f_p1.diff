+// clear all jobs from the list to prevent stale protocol state
+void
+clear_job_list (job_list ** list)
+{
+  job_list *current, *next;
+
+  if (list == NULL || *list == NULL) {
+    return;
+  }
+
+  current = *list;
+  while (current != NULL) {
+    next = current->next;
+    if (current->pair != NULL) {
+      if (current->pair->b != NULL) {
+        if (current->pair->b->mob != NULL) {
+          free (current->pair->b->mob);
