+/*
+ * Stop all running 5GMM timers as per 3GPP TS 24.501 protocol requirements
+ * This function should be called when authentication is rejected
+ */
+static void _stop_all_running_timers(nr_user_nas_t *UE) {
+  LOG_I(NAS, "Stopping all running 5GMM timers due to authentication reject\n");
+  
+  /* Stop T3510 - Registration timer */
+  if (UE->emm_data && UE->emm_data->T3510.id != NAS_TIMER_INACTIVE_ID) {
+    LOG_I(NAS, "Stopping timer T3510 (%d)\n", UE->emm_data->T3510.id);
+    UE->emm_data->T3510.id = nas_timer_stop(UE->emm_data->T3510.id);
+  }
+  
+  /* Stop T3516 - Authentication timer */
+  if (UE->emm_data && UE->emm_data->T3516.id != NAS_TIMER_INACTIVE_ID) {
+    LOG_I(NAS, "Stopping timer T3516 (%d)\n", UE->emm_data->T3516.id);
+    UE->emm_data->T3516.id = nas_timer_stop(UE->emm_data->T3516.id);
+  }
+  
+  /* Stop T3517 - Service request timer */
+  if (UE->emm_data && UE->emm_data->T3517.id != NAS_TIMER_INACTIVE_ID) {
+    LOG_I(NAS, "Stopping timer T3517 (%d)\n", UE->emm_data->T3517.id);
+    UE->emm_data->T3517.id = nas_timer_stop(UE->emm_data->T3517.id);
+  }
+  
+  /* Stop T3519 - De-registration timer */
+  if (UE->emm_data && UE->emm_data->T3519.id != NAS_TIMER_INACTIVE_ID) {
+    LOG_I(NAS, "Stopping timer T3519 (%d)\n", UE->emm_data->T3519.id);
+    UE->emm_data->T3519.id = nas_timer_stop(UE->emm_data->T3519.id);
+  }
+  
+  /* Stop T3520 - Configuration update timer */
+  if (UE->emm_data && UE->emm_data->T3520.id != NAS_TIMER_INACTIVE_ID) {
+    LOG_I(NAS, "Stopping timer T3520 (%d)\n", UE->emm_data->T3520.id);
+    UE->emm_data->T3520.id = nas_timer_stop(UE->emm_data->T3520.id);
+  }
+}
