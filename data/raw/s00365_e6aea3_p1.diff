+void SGSauthenticationReject(void *msg, nr_user_nas_t *UE) {
+  LOG_I(NAS, "Received Authentication Reject message\n");
+  
+  /* Stop all running 5GMM timers as per 3GPP TS 24.501 */
+  _stop_all_running_timers(UE);
+  
+  /* Clear security context */
+  if (UE->security) {
+    memset(UE->security, 0, sizeof(*UE->security));
+  }
+  
+  /* Consider the USIM invalid */
+  if (UE->uicc) {
+    UE->uicc->usim_is_valid = false;
+  }
+  
+  /* Abort any ongoing 5GMM procedures */
+  LOG_W(NAS, "Authentication rejected by network - entering appropriate state\n");
+  
+  /* Trigger NAS state change to handle authentication failure */
+  ue_nas_schedule();
+}
+
+void SGSauthenticationReject(void *msg, nr_user_nas_t *UE) {
+  LOG_W(NAS, "Received Authentication Reject message - network rejected authentication\n");
+  
+  /* Stop all running timers as per 3GPP TS 24.501 section 5.4.2.5.2 */
+  _stop_all_running_timers(UE);
+  
+  /* Clean up security context */
+  if (UE->emm_data && UE->emm_data->security) {
+    UE->emm_data->security->ng_ksi = 0;
+    UE->emm_data->security->key_set = 0;
+  }
+  
+  /* Set UE state to 5GMM-DEREGISTERED */
+  if (UE->emm_data) {
+    UE->emm_data->state = GMM_DEREGISTERED;
+  }
+  
+  /* Abort any ongoing NAS signalling procedures */
+  SGSabortNet(msg, UE);
+}
+
+void SGSauthenticationReject(void *msg, nr_user_nas_t *UE) {
+  LOG_I(NAS, "Received Authentication Reject message\n");
+  
+  /* Stop all running 5GMM timers as required by 3GPP TS 24.501 */
+  _stop_all_running_timers(UE);
+  
+  /* Abort any ongoing 5GMM procedures */
+  if (UE->emm_data) {
+    UE->emm_data->procedure_in_progress = 0;
+    UE->emm_data->auth_failed = true;
+  }
+  
+  /* Set the 5GMM state to 5GMM-DEREGISTERED */
+  if (UE->emm_data) {
+    UE->emm_data->state = GMM_DEREGISTERED;
+  }
+  
+  LOG_W(NAS, "Authentication rejected by network, entering deregistered state\n");
+}
