 //       INTEN bit without impacting FSM control bits. Use NVIC_EnableIRQ/NVIC_DisableIRQ instead for interrupt control.\n   139\t    I2C_T *i2c_base = (I2C_T *) NU_MODBASE(obj->i2c.i2c);\n   140\t    i2c_base->CTL0 |= (I2C_CTL0_INTEN_Msk | I2C_CTL0_I2CEN_Msk);\n   141\t\n   142\t    // Enable sync-mode vector interrupt.\n   143\t    struct nu_i2c_var *var = (struct nu_i2c_var *) modinit->var;\n   144\t    var->obj = obj;\n   145\t    obj->i2c.tran_ctrl = 0;\n   146\t    obj->i2c.stop = 0;\n   147\t    i2c_enable_vector_interrupt(obj, (uint32_t) var->vec, 1);\n   148\t\n   149\t    // Mark this module to be inited.\n   150\t    int i = modinit - i2c_modinit_tab;\n   151\t    i2c_modinit_mask |= 1 << i;\n   152\t}\n   153\t\n   154\tvoid i2c_free(i2c_t *obj)\n   155\t{\n   156\t    const struct nu_modinit_s *modinit = get_modinit(obj->i2c.i2c, i2c_modinit_tab);\n   157\t    MBED_ASSERT(modinit != NULL);\n   158\t    MBED_ASSERT(modinit->modname == (int) obj->i2c.i2c);\n   159\t\n   160\t    /* Disable I2C interrupt */\n   161\t    NVIC_DisableIRQ(modinit->irq_n);\n   162\t\n   163\t    I2C_T *i2c_base = (I2C_T *) NU_MODBASE(obj->i2c.i2c);\n   164\t\n   165\t    /* Disable I2C module */\n   166\t    I2C_Close(i2c_base);\n   167\t\n   168\t    /* Disable IP clock\n   169\t     *\n   170\t     * NOTE: We must call secure version (from non-secure domain) because SYS/CLK regions are secure.\n   171\t     */\n   172\t    CLK_DisableModuleClock_S(modinit->clkidx);\n   173\t\n   174\t    // Mark this module to be deinited.\n   175\t    int i = modinit - i2c_modinit_tab;\n   176\t    i2c_modinit_mask &= ~(1 << i);\n   177\t\n   178\t    /* Free up pins */\n   179\t    gpio_set(obj->i2c.pin_sda);\n   180\t    gpio_set(obj->i2c.pin_scl);\n   181\t    obj->i2c.pin_sda = NC;\n   182\t    obj->i2c.pin_scl = NC;\n   183\t}\n   184\t\n   185\tint i2c_start(i2c_t *obj)\n   186\t{\n   187\t    return i2c_do_trsn(obj, I2C_CTL0_STA_Msk | I2C_CTL0_SI_Msk, 1);\n   188\t}\n   189\t\n   19