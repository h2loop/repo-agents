+#include <stdio.h>
+#include <arm_neon.h>
+
+// Simplified test to understand the data layout
+
+int main() {
+    printf("Understanding vector layouts:\n");
+    
+    // Simple test case: (3 + 4i) and (1 + 2i)
+    // Expected: (3*1 - 4*2) + (3*2 + 4*1)i = -5 + 10i
+    
+    int16_t a_data[8] = {3, 4, 0, 0, 0, 0, 0, 0};  // First complex: 3 + 4i
+    int16_t b_data[8] = {1, 2, 0, 0, 0, 0, 0, 0};  // Second complex: 1 + 2i
+    
+    int16x8_t a = vld1q_s16(a_data);
+    int16x8_t b = vld1q_s16(b_data);
+    
+    printf("a = [%d, %d, %d, %d, %d, %d, %d, %d]\n", 
+           a_data[0], a_data[1], a_data[2], a_data[3], 
+           a_data[4], a_data[5], a_data[6], a_data[7]);
+           
+    printf("b = [%d, %d, %d, %d, %d, %d, %d, %d]\n", 
+           b_data[0], b_data[1], b_data[2], b_data[3], 
+           b_data[4], b_data[5], b_data[6], b_data[7]);
+    
+    // To do complex multiplication correctly, we need b2 to contain
+    // the imaginary parts in the real positions and vice versa
+    // For b = [1, 2, ...], b2 should be [2, 1, ...] for the right computation
+    
+    // But let's see what vrev32q_s16 does
+    int16x8_t b_flipped = vrev32q_s16(b);
+    int16_t b_flipped_array[8];
+    vst1q_s16(b_flipped_array, b_flipped);
+    printf("b_flipped = [%d, %d, %d, %d, %d, %d, %d, %d]\n", 
+           b_flipped_array[0], b_flipped_array[1], b_flipped_array[2], b_flipped_array[3],
+           b_flipped_array[4], b_flipped_array[5], b_flipped_array[6], b_flipped_array[7]);
+    
+    return 0;
+}
