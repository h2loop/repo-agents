index 2938898aff..844e2e211c 100644
--- a/openair2/F1AP/lib/f1ap_lib_common.c
+++ b/openair2/F1AP/lib/f1ap_lib_common.c
@@ -99,3 +99,139 @@ uint8_t *cp_octet_string(const OCTET_STRING_t *os, int *len)
   *len = os->size;
   return buf;
 }
+
+/* Helper function to compare f1ap_up_tnl_t structures */
+static bool eq_f1ap_up_tnl(const f1ap_up_tnl_t *a, const f1ap_up_tnl_t *b)
+{
+  if (a == NULL && b == NULL) return true;
+  if (a == NULL || b == NULL) return false;
+  
+  _F1_EQ_CHECK_INT(a->tl_address, b->tl_address);
+  _F1_EQ_CHECK_INT(a->teid, b->teid);
+  _F1_EQ_CHECK_INT(a->port, b->port);
+  return true;
+}
+
+/* Helper function to compare f1ap_qos_characteristics_t structures */
+static bool eq_f1ap_qos_characteristics(const f1ap_qos_characteristics_t *a, const f1ap_qos_characteristics_t *b)
+{
+  if (a == NULL && b == NULL) return true;
+  if (a == NULL || b == NULL) return false;
+  
+  _F1_EQ_CHECK_INT(a->qos_type, b->qos_type);
+  
+  if (a->qos_type == NON_DYNAMIC) {
+    _F1_EQ_CHECK_LONG(a->non_dynamic.fiveqi, b->non_dynamic.fiveqi);
+    _F1_EQ_CHECK_LONG(a->non_dynamic.qos_priority_level, b->non_dynamic.qos_priority_level);
+  } else { /* DYNAMIC */
+    _F1_EQ_CHECK_LONG(a->dynamic.fiveqi, b->dynamic.fiveqi);
+    _F1_EQ_CHECK_LONG(a->dynamic.qos_priority_level, b->dynamic.qos_priority_level);
+    _F1_EQ_CHECK_LONG(a->dynamic.packet_delay_budget, b->dynamic.packet_delay_budget);
+    _F1_EQ_CHECK_LONG(a->dynamic.packet_error_rate.per_scalar, b->dynamic.packet_error_rate.per_scalar);
+    _F1_EQ_CHECK_LONG(a->dynamic.packet_error_rate.per_exponent, b->dynamic.packet_error_rate.per_exponent);
+  }
+  return true;
+}
+
+/* Helper function to compare f1ap_ngran_allocation_retention_priority_t structures */
+static bool eq_f1ap_alloc_reten_priority(const f1ap_ngran_allocation_retention_priority_t *a, const f1ap_ngran_allocation_retention_priority_t *b)
+{
+  if (a == NULL && b == NULL) return true;
+  if (a == NULL || b == NULL) return false;
+  
+  _F1_EQ_CHECK_INT(a->priority_level, b->priority_level);
+  _F1_EQ_CHECK_INT(a->preemption_capability, b->preemption_capability);
+  _F1_EQ_CHECK_INT(a->preemption_vulnerability, b->preemption_vulnerability);
+  return true;
+}
+
+/* Helper function to compare f1ap_qos_flow_level_qos_parameters_t structures */
+static bool eq_f1ap_qos_flow_level_qos_parameters(const f1ap_qos_flow_level_qos_parameters_t *a, const f1ap_qos_flow_level_qos_parameters_t *b)
+{
+  if (a == NULL && b == NULL) return true;
+  if (a == NULL || b == NULL) return false;
+  
+  if (!eq_f1ap_qos_characteristics(&a->qos_characteristics, &b->qos_characteristics))
+    return false;
+  if (!eq_f1ap_alloc_reten_priority(&a->alloc_reten_priority, &b->alloc_reten_priority))
+    return false;
+  return true;
+}
+
+/* Helper function to compare f1ap_flows_mapped_to_drb_t structures */
+static bool eq_f1ap_flows_mapped_to_drb(const f1ap_flows_mapped_to_drb_t *a, const f1ap_flows_mapped_to_drb_t *b)
+{
+  if (a == NULL && b == NULL) return true;
+  if (a == NULL || b == NULL) return false;
+  
+  _F1_EQ_CHECK_LONG(a->qfi, b->qfi);
+  if (!eq_f1ap_qos_flow_level_qos_parameters(&a->qos_params, &b->qos_params))
+    return false;
+  return true;
+}
+
+/* Helper function to compare f1ap_drb_information_t structures */
+static bool eq_f1ap_drb_information(const f1ap_drb_information_t *a, const f1ap_drb_information_t *b)
+{
+  if (a == NULL && b == NULL) return true;
+  if (a == NULL || b == NULL) return false;
+  
+  if (!eq_f1ap_qos_flow_level_qos_parameters(&a->drb_qos, &b->drb_qos))
+    return false;
+    
+  _F1_EQ_CHECK_INT(a->flows_to_be_setup_length, b->flows_to_be_setup_length);
+  
+  if (a->flows_to_be_setup_length > 0) {
+    if (a->flows_mapped_to_drb == NULL || b->flows_mapped_to_drb == NULL)
+      return false;
+      
+    for (int i = 0; i < a->flows_to_be_setup_length; i++) {
+      if (!eq_f1ap_flows_mapped_to_drb(&a->flows_mapped_to_drb[i], &b->flows_mapped_to_drb[i]))
+        return false;
+    }
+  } else {
+    if (a->flows_mapped_to_drb != NULL || b->flows_mapped_to_drb != NULL)
+      return false;
+  }
+  
+  return true;
+}
+
+bool eq_drb_to_setup(const f1ap_drb_to_be_setup_t *a, const f1ap_drb_to_be_setup_t *b)
+{
+  if (a == NULL && b == NULL) return true;
+  if (a == NULL || b == NULL) return false;
+  
+  _F1_EQ_CHECK_LONG(a->drb_id, b->drb_id);
+  
+  _F1_EQ_CHECK_INT(a->up_ul_tnl_length, b->up_ul_tnl_length);
+  if (a->up_ul_tnl_length > 0) {
+    for (int i = 0; i < a->up_ul_tnl_length; i++) {
+      if (!eq_f1ap_up_tnl(&a->up_ul_tnl[i], &b->up_ul_tnl[i]))
+        return false;
+    }
+  }
+  
+  _F1_EQ_CHECK_INT(a->up_dl_tnl_length, b->up_dl_tnl_length);
+  if (a->up_dl_tnl_length > 0) {
+    for (int i = 0; i < a->up_dl_tnl_length; i++) {
+      if (!eq_f1ap_up_tnl(&a->up_dl_tnl[i], &b->up_dl_tnl[i]))
+        return false;
+    }
+  }
+  
+  if (!eq_f1ap_drb_information(&a->drb_info, &b->drb_info))
+    return false;
+    
+  _F1_EQ_CHECK_INT(a->rlc_mode, b->rlc_mode);
+  
+  _F1_EQ_CHECK_INT(a->nssai.sst, b->nssai.sst);
+  _F1_EQ_CHECK_INT(a->nssai.sd, b->nssai.sd);
+  
+  return true;
+}
+
+bool eq_f1ap_drb_to_be_setup(const f1ap_drb_to_be_setup_t *a, const f1ap_drb_to_be_setup_t *b)
+{
+  return eq_drb_to_setup(a, b);
+}
