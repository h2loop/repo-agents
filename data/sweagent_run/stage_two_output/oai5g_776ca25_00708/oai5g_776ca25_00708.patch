 #include "ngap_common.h"
 #include "NGAP_NGAP-PDU.h"
+#include "UTILS/conversions.h"
 
 
 int asn1_xer_print = 0;
@@ -39,3 +41,27 @@ int asn1_xer_print = 0;
 void ngap_handle_criticality(NGAP_Criticality_t criticality)
 {
 }
+
+
+int decode_ngap_nssai(
+  const NGAP_AllowedNSSAI_Item_t *nssai_asn,
+  ngap_allowed_NSSAI_t *nssai)
+{
+  if ((nssai_asn == NULL) || (nssai == NULL)) {
+    return -1;
+  }
+
+  // Decode SST (Single Slice Type)
+  OCTET_STRING_TO_INT8(&nssai_asn->s_NSSAI.sST, nssai->sST);
+
+  // Initialize SD flag to 0
+  nssai->sD_flag = 0;
+  
+  // Check if SD (Slice Differentiator) is present and decode it
+  if (nssai_asn->s_NSSAI.sD != NULL) {
+    nssai->sD_flag = 1;
+    memcpy(nssai->sD, nssai_asn->s_NSSAI.sD->buf, sizeof(nssai->sD));
+  }
+
+  return 0;
+}
