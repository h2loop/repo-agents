+ * @brief Check if pattern2 is configured
+ */
+static bool is_pattern2_config(struct NR_TDD_UL_DL_Pattern *pattern2)
+{
+  if (pattern2 == NULL) {
+    return false;
+  }
+  
+  // Check if pattern2 has valid configuration
+  // Using 320 as threshold as seen in fix_scc function
+  if (pattern2->dl_UL_TransmissionPeriodicity > 320) {
+    return false;
+  }
+  
+  return true;
