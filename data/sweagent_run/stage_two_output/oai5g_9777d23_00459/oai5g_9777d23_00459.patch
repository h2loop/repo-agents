+// Local implementation of time_now_us function
+static inline int64_t time_now_us(void)
+{
+  struct timespec ts;
+  clock_gettime(CLOCK_REALTIME, &ts);
+  return (int64_t)ts.tv_sec * 1000000LL + (int64_t)ts.tv_nsec / 1000LL;
+}
+
+// Implementation of get_ngran_name function
+static const char* get_ngran_name(ngran_node_t node_type)
+{
+  static const char* ngran_names[] = {
+    "eNB",
+    "ng-eNB",
+    "gNB",
+    "eNB-CU",
+    "ng-eNB-CU",
+    "gNB-CU",
+    "eNB-DU",
+    "gNB-DU",
+    "eNB-MBMS-STA",
+    "gNB-CUCP",
+    "gNB-CUUP"
+  };
+
+  if (node_type >= END_NGRAN_NODE_TYPE) {
+    return "Unknown";
+  }
+
+  return ngran_names[node_type];
+}
+
+// Helper function implementations
+char* cp_ba_to_str(byte_array_t ba)
+{
+  char* str = malloc(ba.len + 1);
+  if (str) {
+    memcpy(str, ba.buf, ba.len);
+    str[ba.len] = '\0';
+  }
+  return str;
+}
+
+byte_array_t cp_str_to_ba(const char* str)
+{
+  byte_array_t ba = {0};
+  if (str) {
+    ba.len = strlen(str);
+    ba.buf = malloc(ba.len);
+    if (ba.buf) {
+      memcpy(ba.buf, str, ba.len);
+    }
+  }
+  return ba;
+}
+
+meas_info_format_1_lst_t cp_meas_info_format_1_lst(const meas_info_format_1_lst_t* src)
+{
+  meas_info_format_1_lst_t dst = {0};
+  if (src) {
+    dst.meas_type.type = src->meas_type.type;
+    dst.meas_type.name.len = src->meas_type.name.len;
+    if (src->meas_type.name.buf) {
+      dst.meas_type.name.buf = malloc(dst.meas_type.name.len);
+      if (dst.meas_type.name.buf) {
+        memcpy(dst.meas_type.name.buf, src->meas_type.name.buf, dst.meas_type.name.len);
+      }
+    }
+  }
+  return dst;
+}
