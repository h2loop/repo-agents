+
+/**\brief Extract C-RNTI from UL MAC CE in MAC PDU
+   \param pduP           pointer to MAC PDU
+   \param pdu_len        length of MAC PDU
+   \returns              extracted C-RNTI value or 0 if not found/invalid */
+uint16_t extract_01_c_rnti(uint8_t *pduP, int32_t pdu_len)
+{
+  if (!pduP || pdu_len <= 0) {
+    LOG_W(NR_MAC, "Invalid PDU pointer or length in %s\n", __FUNCTION__);
+    return 0;
+  }
+
+  uint8_t *current_pdu = pduP;
+  int32_t remaining_len = pdu_len;
+  
+  LOG_D(NR_MAC, "In %s: processing PDU of length %d\n", __FUNCTION__, pdu_len);
+
+  while (remaining_len > 0) {
+    // Check minimum size for a subheader
+    if (remaining_len < (int)sizeof(NR_MAC_SUBHEADER_FIXED)) {
+      LOG_D(NR_MAC, "Not enough bytes left for a subheader in %s\n", __FUNCTION__);
+      break;
+    }
+    
+    // Read the LCID from the fixed subheader
+    uint8_t lcid = ((NR_MAC_SUBHEADER_FIXED *)current_pdu)->LCID;
+    LOG_D(NR_MAC, "Processing subheader with LCID 0x%02x\n", lcid);
+    
+    // Check if this is a C-RNTI MAC CE
+    if (lcid == UL_SCH_LCID_C_RNTI) {
+      // Fixed size subheader (1 byte) + C-RNTI MAC CE (2 bytes) = 3 bytes total
+      if (remaining_len < 3) {
+        LOG_W(NR_MAC, "Not enough bytes for C-RNTI MAC CE in %s\n", __FUNCTION__);
+        return 0;
+      }
+      
+      // Extract the 16-bit C-RNTI value
+      uint16_t c_rnti;
+      memcpy(&c_rnti, current_pdu + 1, sizeof(c_rnti)); // +1 to skip subheader
+      LOG_D(NR_MAC, "Found C-RNTI MAC CE with value 0x%04x\n", c_rnti);
+      return c_rnti;
+    }
+    
+    // Handle different types of subheaders to move to the next one
+    uint16_t subheader_len = 0;
+    uint16_t ce_or_sdu_len = 0;
+    
+    // Check if it's a fixed-size subheader (no length field)
+    if (lcid >= UL_SCH_LCID_C_RNTI && lcid <= UL_SCH_LCID_PADDING) {
+      // These are fixed-size MAC CEs or padding
+      subheader_len = sizeof(NR_MAC_SUBHEADER_FIXED);
+      
+      // Handle fixed-size MAC CEs
+      switch (lcid) {
+        case UL_SCH_LCID_C_RNTI:
+          ce_or_sdu_len = 2; // Already handled above, but just for completeness
+          break;
+        case UL_SCH_LCID_S_TRUNCATED_BSR:
+        case UL_SCH_LCID_S_BSR:
+        case UL_SCH_LCID_SINGLE_ENTRY_PHR:
+          ce_or_sdu_len = 1;
+          break;
+        case UL_SCH_LCID_MULTI_ENTRY_PHR_1_OCT:
+        case UL_SCH_LCID_CONFIGURED_GRANT_CONFIRMATION:
+        case UL_SCH_LCID_RECOMMENDED_BITRATE_QUERY:
+          ce_or_sdu_len = 1;
+          break;
+        case UL_SCH_LCID_MULTI_ENTRY_PHR_4_OCT:
+          ce_or_sdu_len = 4;
+          break;
+        case UL_SCH_LCID_L_TRUNCATED_BSR:
+        case UL_SCH_LCID_L_BSR:
+          // Variable size, need to parse length
+          if (get_mac_len(current_pdu, remaining_len, &ce_or_sdu_len, &subheader_len)) {
+            LOG_D(NR_MAC, "Variable-size MAC CE with length %d\n", ce_or_sdu_len);
+          } else {
+            LOG_W(NR_MAC, "Failed to get length for variable-size MAC CE\n");
+            return 0;
+          }
+          break;
+        case UL_SCH_LCID_PADDING:
+          // Padding extends to the end of the buffer
+          LOG_D(NR_MAC, "Padding to end of buffer\n");
+          return 0; // No C-RNTI found
+        default:
+          // Regular logical channels or unknown LCIDs
+          if (lcid < UL_SCH_LCID_C_RNTI) {
+            // Regular SDUs with variable length
+            if (get_mac_len(current_pdu, remaining_len, &ce_or_sdu_len, &subheader_len)) {
+              LOG_D(NR_MAC, "SDU with length %d\n", ce_or_sdu_len);
+            } else {
+              LOG_W(NR_MAC, "Failed to get length for SDU\n");
+              return 0;
+            }
+          } else {
+            LOG_W(NR_MAC, "Unknown LCID 0x%02x\n", lcid);
+            return 0;
+          }
+          break;
+      }
+    } else {
+      // Regular SDUs with variable length
+      if (get_mac_len(current_pdu, remaining_len, &ce_or_sdu_len, &subheader_len)) {
+        LOG_D(NR_MAC, "SDU with length %d\n", ce_or_sdu_len);
+      } else {
+        LOG_W(NR_MAC, "Failed to get length for SDU\n");
+        return 0;
+      }
+    }
+    
+    // Move to the next subheader
+    int total_element_size = subheader_len + ce_or_sdu_len;
+    if (total_element_size > remaining_len) {
+      LOG_W(NR_MAC, "Element size exceeds remaining buffer in %s\n", __FUNCTION__);
+      return 0;
+    }
+    
+    current_pdu += total_element_size;
+    remaining_len -= total_element_size;
+    LOG_D(NR_MAC, "Moved to next element, remaining length: %d\n", remaining_len);
+  }
+  
+  LOG_D(NR_MAC, "No C-RNTI MAC CE found in PDU\n");
+  return 0;
+}
