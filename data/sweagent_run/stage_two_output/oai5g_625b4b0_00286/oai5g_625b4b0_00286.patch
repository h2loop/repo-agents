+ *      contact@openairinterface.org
+ */
+
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+#include <errno.h>
+#include <sys/epoll.h>
+#include <pthread.h>
+
+// Include our header
+#include "fapi_nvIPC.h"
+
+int some_socket_fd = 0; // Dummy socket fd for compilation
+
+void* create_recv_thread(void* args) {
+    printf("Creating receive thread\n");
+    setup_epoll_communication();
+    return NULL;
+}
+
+int setup_epoll_communication() {
+    int epoll_fd;
+    struct epoll_event ev;
+    int result;
+    int saved_errno; // To preserve errno
+    
+    // Fixed errno usage in epoll_create1 - capturing errno immediately
+    epoll_fd = epoll_create1(0);
+    if (epoll_fd == -1) {
+        saved_errno = errno; // Capture errno immediately
+        perror("epoll_create1 failed");
+        fprintf(stderr, "Error: %s\n", strerror(saved_errno));
+        return -1;
+    }
+    
+    // Setup event
+    memset(&ev, 0, sizeof(ev));
+    ev.events = EPOLLIN;
+    ev.data.fd = some_socket_fd;
+    
+    // Fixed errno usage in epoll_ctl - capturing errno immediately
+    result = epoll_ctl(epoll_fd, EPOLL_CTL_ADD, some_socket_fd, &ev);
+    if (result == -1) {
+        saved_errno = errno; // Capture errno immediately
+        perror("epoll_ctl failed");
+        fprintf(stderr, "Error: %s\n", strerror(saved_errno));
+        close(epoll_fd);
+        return -1;
+    }
+    
+    // Improved epoll_wait errno handling logic
+    struct epoll_event events[10];
+    int nfds = epoll_wait(epoll_fd, events, 10, -1);
+    if (nfds == -1) {
+        saved_errno = errno; // Capture errno immediately
+        if (saved_errno == EINTR) {
+            printf("epoll_wait interrupted\n");
+            close(epoll_fd); // Proper resource cleanup
+            return 0;
+        }
+        perror("epoll_wait failed");
+        fprintf(stderr, "Error: %s\n", strerror(saved_errno));
+        close(epoll_fd); // Proper resource cleanup
+        return -1;
+    }
+    
+    // Handle events...
+    for (int i = 0; i < nfds; i++) {
+        if (events[i].data.fd == some_socket_fd) {
+            printf("Data available on socket\n");
+        }
+    }
+    
+    close(epoll_fd);
+    return 0;
+}
