+/*
+ * Map RSRP/RSRQ values to CQI values
+ * This function converts the measured RSRP and RSRQ to a CQI value
+ * based on typical LTE performance mappings
+ */
+static int _map_channel_quality_to_cqi(int rsrp, int rsrq)
+{
+  int cqi = 1; // Default to lowest CQI
+  
+  // Convert RSRP (-140 to -44 dBm) to CQI scale (1-15)
+  if (rsrp >= 26) {
+    cqi = 15; // Excellent signal
+  } else if (rsrp >= 23) {
+    cqi = 12; // Good signal
+  } else if (rsrp >= 20) {
+    cqi = 9;  // Medium signal
+  } else if (rsrp >= 17) {
+    cqi = 6;  // Fair signal
+  } else if (rsrp >= 14) {
+    cqi = 3;  // Poor signal
+  } else {
+    cqi = 1;  // Very poor signal
+  }
+  
+  // Adjust based on RSRQ (-19.5dB to -3dB) if needed
+  if (rsrq < 10 && cqi > 3) {
+    cqi -= 2; // Reduce CQI for poor RSRQ
+  } else if (rsrq < 20 && cqi > 6) {
+    cqi -= 1; // Slightly reduce CQI for fair RSRQ
+  }
+  
+  // Ensure CQI is within valid range
+  if (cqi < 1) cqi = 1;
+  if (cqi > 15) cqi = 15;
+  
+  return cqi;
+}
+
+/*
+ * Map CQI values to appropriate QCI based on channel quality
+ * Lower QCI values typically indicate stricter QoS requirements (e.g., voice)
+ * Higher CQI indicates better channel quality, which can support stricter QoS
+ */
+static int _map_cqi_to_qci(int cqi)
+{
+  if (cqi >= 13) {
+    return 1; // Excellent channel quality -> Conversational Voice (QCI 1)
+  } else if (cqi >= 10) {
+    return 2; // Good channel quality -> Conversational Video (QCI 2)
+  } else if (cqi >= 7) {
+    return 3; // Medium channel quality -> Real-time Gaming (QCI 3)
+  } else if (cqi >= 4) {
+    return 4; // Fair channel quality -> Non-conversational Video (QCI 4)
+  } else {
+    return 5; // Poor channel quality -> Default internet access (QCI 5)
+  }
+}
 
