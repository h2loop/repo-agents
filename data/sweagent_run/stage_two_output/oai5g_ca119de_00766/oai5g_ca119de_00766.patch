+/* ====================================
+ * TRP Information Type Response Item
+ * ==================================== */
+
+/**
+ * @brief TRP Information Type Response Item encoding
+ */
+F1AP_TRPInformationTypeResponseItem_t encode_trp_info_type_response_item(const f1ap_trp_info_type_response_item_t *msg)
+{
+  F1AP_TRPInformationTypeResponseItem_t trp_info_item = {0};
+  
+  /* Based on the ASN.1 definition, TRPInformationTypeResponseItem is a CHOICE type.
+   * The actual implementation would depend on which choice is selected.
+   */
+  
+  /* Copy the appropriate choice based on the input message type */
+  switch (msg->present) {
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_NOTHING:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_NOTHING;
+      break;
+      
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_PCI_NR:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_pCI_NR;
+      trp_info_item.choice.pCI_NR = msg->choice.pci_nr;
+      break;
+      
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_NG_RAN_CGI:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_nG_RAN_CGI;
+      /* Implementation would go here for NRCGI */
+      break;
+      
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_NR_ARFCN:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_nRARFCN;
+      /* Implementation would go here for NRARFCN */
+      break;
+      
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_PRS_CONFIGURATION:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_pRSConfiguration;
+      /* Implementation would go here for PRSConfiguration */
+      break;
+      
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_SSB_INFORMATION:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_sSBinformation;
+      /* Implementation would go here for SSBInformation */
+      break;
+      
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_SFN_INITIALISATION_TIME:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_sFNInitialisationTime;
+      /* Implementation would go here for SFNInitialisationTime */
+      break;
+      
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_SPATIAL_DIRECTION_INFORMATION:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_spatialDirectionInformation;
+      /* Implementation would go here for SpatialDirectionInformation */
+      break;
+      
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_GEOGRAPHICAL_COORDINATES:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_geographicalCoordinates;
+      /* Implementation would go here for GeographicalCoordinates */
+      break;
+      
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_CHOICE_EXTENSION:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_choice_extension;
+      /* Implementation would go here for ProtocolIE-SingleContainer */
+      break;
+      
+    default:
+      trp_info_item.present = F1AP_TRPInformationTypeResponseItem_PR_NOTHING;
+      break;
+  }
+  
+  return trp_info_item;
+}
+
+bool decode_trp_info_type_response_item(const F1AP_TRPInformationTypeResponseItem_t *pdu, f1ap_trp_info_type_response_item_t *out)
+{
+  if (!pdu || !out) return false;
+  
+  memset(out, 0, sizeof(*out));
+  
+  out->present = pdu->present;
+  
+  switch (pdu->present) {
+    case F1AP_TRPInformationTypeResponseItem_PR_NOTHING:
+      /* Nothing to decode */
+      break;
+      
+    case F1AP_TRPInformationTypeResponseItem_PR_pCI_NR:
+      out->present = F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_PCI_NR;
+      /* Implementation would go here for decoding NRPCI */
+      break;
+      
+    case F1AP_TRPInformationTypeResponseItem_PR_nG_RAN_CGI:
+      out->present = F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_NG_RAN_CGI;
+      /* Implementation would go here for decoding NRCGI */
+      break;
+      
+    case F1AP_TRPInformationTypeResponseItem_PR_nRARFCN:
+      out->present = F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_NR_ARFCN;
+      /* Implementation would go here for decoding NRARFCN */
+      break;
+      
+    case F1AP_TRPInformationTypeResponseItem_PR_pRSConfiguration:
+      out->present = F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_PRS_CONFIGURATION;
+      /* Implementation would go here for decoding PRSConfiguration */
+      break;
+      
+    case F1AP_TRPInformationTypeResponseItem_PR_sSBinformation:
+      out->present = F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_SSB_INFORMATION;
+      /* Implementation would go here for decoding SSBInformation */
+      break;
+      
+    case F1AP_TRPInformationTypeResponseItem_PR_sFNInitialisationTime:
+      out->present = F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_SFN_INITIALISATION_TIME;
+      /* Implementation would go here for decoding SFNInitialisationTime */
+      break;
+      
+    case F1AP_TRPInformationTypeResponseItem_PR_spatialDirectionInformation:
+      out->present = F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_SPATIAL_DIRECTION_INFORMATION;
+      /* Implementation would go here for decoding SpatialDirectionInformation */
+      break;
+      
+    case F1AP_TRPInformationTypeResponseItem_PR_geographicalCoordinates:
+      out->present = F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_GEOGRAPHICAL_COORDINATES;
+      /* Implementation would go here for decoding GeographicalCoordinates */
+      break;
+      
+    case F1AP_TRPInformationTypeResponseItem_PR_choice_extension:
+      out->present = F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_CHOICE_EXTENSION;
+      /* Implementation would go here for decoding ProtocolIE-SingleContainer */
+      break;
+      
+    default:
+      return false;
+  }
+  
+  return true;
+}
+
+f1ap_trp_info_type_response_item_t cp_trp_info_type_response_item(const f1ap_trp_info_type_response_item_t *msg)
+{
+  if (!msg) return (f1ap_trp_info_type_response_item_t){0};
+  
+  f1ap_trp_info_type_response_item_t ret = *msg;
+  /* Deep copy would go here if needed for complex types */
+  
+  return ret;
+}
+
+bool eq_trp_info_type_response_item(const f1ap_trp_info_type_response_item_t *a, const f1ap_trp_info_type_response_item_t *b)
+{
+  if (!a && !b) return true;
+  if (!a || !b) return false;
+  
+  if (a->present != b->present) return false;
+  
+  switch (a->present) {
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_NOTHING:
+      return true;
+      
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_PCI_NR:
+      return a->choice.pci_nr == b->choice.pci_nr;
+      
+    /* Add comparison cases for each choice */
+    default:
+      return false;
+  }
+}
+
+void free_trp_info_type_response_item(const f1ap_trp_info_type_response_item_t *msg)
+{
+  if (!msg) return;
+  
+  /* Free any allocated memory inside the structure */
+  /* Since our structure doesn't currently contain pointers, nothing to free */
+  switch (msg->present) {
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_NOTHING:
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_PCI_NR:
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_NG_RAN_CGI:
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_NR_ARFCN:
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_PRS_CONFIGURATION:
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_SSB_INFORMATION:
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_SFN_INITIALISATION_TIME:
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_SPATIAL_DIRECTION_INFORMATION:
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_GEOGRAPHICAL_COORDINATES:
+    case F1AP_TRP_INFORMATION_TYPE_RESPONSE_ITEM_CHOICE_EXTENSION:
+      /* No special freeing needed for basic types */
+      break;
+      
+    default:
+      break;
+  }
+}
