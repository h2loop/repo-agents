 {
-  if (pcc == NULL || pcc->present == NR_SetupRelease_PUCCH_ConfigCommon_PR_NOTHING)
+  // Enhanced validation checks
+  if (pcc == NULL) {
+    LOG_W(NR_RRC, "clone_pucch_configcommon: input parameter is NULL\n");
     return NULL;
+  }
+  
+  if (pcc->present == NR_SetupRelease_PUCCH_ConfigCommon_PR_NOTHING) {
+    LOG_D(NR_RRC, "clone_pucch_configcommon: PUCCH Config Common is set to NOTHING\n");
+    return NULL;
