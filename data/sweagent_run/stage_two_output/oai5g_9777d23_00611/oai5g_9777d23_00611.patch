+  
   NR_SetupRelease_PUCCH_ConfigCommon_t *clone = calloc_or_fail(1, sizeof(*clone));
   clone->present = pcc->present;
-  if (clone->present == NR_SetupRelease_PUCCH_ConfigCommon_PR_release)
+  
+  if (clone->present == NR_SetupRelease_PUCCH_ConfigCommon_PR_release) {
+    LOG_D(NR_RRC, "clone_pucch_configcommon: PUCCH Config Common is set to release\n");
     return clone;
+  }
+  
+  // Validate that setup choice is not NULL when present is setup
+  if (pcc->present == NR_SetupRelease_PUCCH_ConfigCommon_PR_setup && pcc->choice.setup == NULL) {
+    LOG_E(NR_RRC, "clone_pucch_configcommon: setup choice is NULL but present indicates setup\n");
+    free(clone);
+    return NULL;
+  }
 
   uint8_t buf[1024];
   asn_enc_rval_t enc_rval = uper_encode_to_buffer(&asn_DEF_NR_PUCCH_ConfigCommon, NULL, pcc->choice.setup, buf, sizeof(buf));
-  AssertFatal(enc_rval.encoded > 0 && enc_rval.encoded < sizeof(buf), "could not clone NR_PUCCH_ConfigCommon: problem while encoding\n");
+  if (enc_rval.encoded <= 0 || enc_rval.encoded >= sizeof(buf)) {
+    LOG_E(NR_RRC, "clone_pucch_configcommon: could not encode NR_PUCCH_ConfigCommon (encoded=%ld)\n", enc_rval.encoded);
+    free(clone);
+    return NULL;
+  }
+  
   asn_dec_rval_t dec_rval = uper_decode(NULL, &asn_DEF_NR_PUCCH_ConfigCommon, (void **)&clone->choice.setup, buf, enc_rval.encoded, 0, 0);
-  AssertFatal(dec_rval.code == RC_OK && dec_rval.consumed == enc_rval.encoded, "could not clone NR_PUCCH_ConfigCommon: problem while decoding\n");
+  if (dec_rval.code != RC_OK || dec_rval.consumed != enc_rval.encoded) {
+    LOG_E(NR_RRC, "clone_pucch_configcommon: could not decode NR_PUCCH_ConfigCommon (code=%d, consumed=%zu, encoded=%ld)\n", 
+          dec_rval.code, dec_rval.consumed, enc_rval.encoded);
+    free(clone);
+    return NULL;
+  }
+  
+  // Consistency validation after cloning
+  if (clone->present == NR_SetupRelease_PUCCH_ConfigCommon_PR_setup && clone->choice.setup == NULL) {
+    LOG_E(NR_RRC, "clone_pucch_configcommon: cloned setup choice is NULL\n");
+    free(clone);
+    return NULL;
+  }
+  
+  // Additional consistency checks for critical fields
+  if (clone->present == NR_SetupRelease_PUCCH_ConfigCommon_PR_setup) {
+    NR_PUCCH_ConfigCommon_t *setup = clone->choice.setup;
+    if (setup->hoppingId != NULL && *setup->hoppingId > 1023) {
+      LOG_W(NR_RRC, "clone_pucch_configcommon: hoppingId value (%lu) exceeds maximum allowed (1023)\n", *setup->hoppingId);
+    }
+    
+    if (setup->p0_nominal != NULL && (*setup->p0_nominal < -202 || *setup->p0_nominal > 24)) {
+      LOG_W(NR_RRC, "clone_pucch_configcommon: p0_nominal value (%ld) outside valid range [-202, 24]\n", *setup->p0_nominal);
+    }
+  }
+  
+  LOG_D(NR_RRC, "clone_pucch_configcommon: successfully cloned PUCCH Config Common\n");
   return clone;
 }
 
