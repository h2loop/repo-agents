+/*! \file f1ap_positioning.c
+ * \brief F1AP positioning procedures for both CU and DU
+ * \author OpenAirInterface Software Alliance
+ * \date 2024
+ * \version 0.1
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ */
+
+#include "f1ap_positioning.h"
+#include "f1ap_common.h"
+#include "F1AP_PositioningMeasurementUpdate.h"
+#include "F1AP_IE-Extensions.h"
+#include "oai_asn1.h"
+
+int CU_handle_PositioningMeasurementUpdate(instance_t instance, sctp_assoc_t assoc_id, uint32_t stream, F1AP_F1AP_PDU_t *pdu) {
+    LOG_D(F1AP, "CU_handle_PositioningMeasurementUpdate\n");
+
+    if (pdu == NULL) {
+        LOG_E(F1AP, "Error: NULL PDU received\n");
+        return -1;
+    }
+
+    if (pdu->present != F1AP_F1AP_PDU_PR_initiatingMessage) {
+        LOG_E(F1AP, "Error: Not an initiating message\n");
+        return -1;
+    }
+
+    F1AP_PositioningMeasurementUpdate_t *positioning_measurement_update_p = 
+        &pdu->choice.initiatingMessage->value.choice.PositioningMeasurementUpdate;
+
+    // Check if the protocolIEs list exists
+    if (positioning_measurement_update_p->protocolIEs.list.array == NULL) {
+        LOG_W(F1AP, "Warning: NULL protocolIEs array in PositioningMeasurementUpdate\n");
+        // This may be valid if there are no IEs, continue processing
+    }
+
+    F1AP_PositioningMeasurementUpdateIEs_t *ie = NULL;
+    int i = 0;
+
+    // Process each IE in the container
+    for (i = 0; i < positioning_measurement_update_p->protocolIEs.list.count; i++) {
+        if (positioning_measurement_update_p->protocolIEs.list.array == NULL) {
+            LOG_E(F1AP, "Error: NULL protocolIEs array but count > 0\n");
+            return -1;
+        }
+        
+        ie = positioning_measurement_update_p->protocolIEs.list.array[i];
+        
+        if (ie == NULL) {
+            LOG_W(F1AP, "Warning: NULL IE at index %d\n", i);
+            continue;
+        }
+        
+        switch (ie->id) {
+            case F1AP_ProtocolIE_ID_id_TransactionID:
+                // Handle transaction ID
+                LOG_D(F1AP, "Processing TransactionID IE\n");
+                break;
+            case F1AP_ProtocolIE_ID_id_LMF_MeasurementID:
+                // Handle LMF Measurement ID
+                LOG_D(F1AP, "Processing LMF Measurement ID IE\n");
+                break;
+            case F1AP_ProtocolIE_ID_id_RAN_MeasurementID:
+                // Handle RAN Measurement ID
+                LOG_D(F1AP, "Processing RAN Measurement ID IE\n");
+                break;
+            case F1AP_ProtocolIE_ID_id_SRSConfiguration:
+                // Handle SRS Configuration (optional)
+                LOG_D(F1AP, "Processing SRS Configuration IE\n");
+                break;
+            default:
+                LOG_W(F1AP, "Unknown IE id %ld\n", ie->id);
+                break;
+        }
+    }
+
+    // Note: The positioning measurement update structure is freed by the caller
+    // in f1ap_handle_message() using ASN_STRUCT_FREE
+
+    return 0;
+}
+
+int DU_handle_PositioningMeasurementUpdate(instance_t instance, sctp_assoc_t assoc_id, uint32_t stream, F1AP_F1AP_PDU_t *pdu) {
+    LOG_D(F1AP, "DU_handle_PositioningMeasurementUpdate\n");
+
+    if (pdu == NULL) {
+        LOG_E(F1AP, "Error: NULL PDU received\n");
+        return -1;
+    }
+
+    if (pdu->present != F1AP_F1AP_PDU_PR_initiatingMessage) {
+        LOG_E(F1AP, "Error: Not an initiating message\n");
+        return -1;
+    }
+
+    F1AP_PositioningMeasurementUpdate_t *positioning_measurement_update_p = 
+        &pdu->choice.initiatingMessage->value.choice.PositioningMeasurementUpdate;
+
+    // Check if the protocolIEs list exists
+    if (positioning_measurement_update_p->protocolIEs.list.array == NULL) {
+        LOG_W(F1AP, "Warning: NULL protocolIEs array in PositioningMeasurementUpdate\n");
+        // This may be valid if there are no IEs, continue processing
+    }
+
+    F1AP_PositioningMeasurementUpdateIEs_t *ie = NULL;
+    int i = 0;
+
+    // Process each IE in the container
+    for (i = 0; i < positioning_measurement_update_p->protocolIEs.list.count; i++) {
+        if (positioning_measurement_update_p->protocolIEs.list.array == NULL) {
+            LOG_E(F1AP, "Error: NULL protocolIEs array but count > 0\n");
+            return -1;
+        }
+        
+        ie = positioning_measurement_update_p->protocolIEs.list.array[i];
+        
+        if (ie == NULL) {
+            LOG_W(F1AP, "Warning: NULL IE at index %d\n", i);
+            continue;
+        }
+        
+        switch (ie->id) {
+            case F1AP_ProtocolIE_ID_id_TransactionID:
+                // Handle transaction ID
+                LOG_D(F1AP, "Processing TransactionID IE\n");
+                break;
+            case F1AP_ProtocolIE_ID_id_LMF_MeasurementID:
+                // Handle LMF Measurement ID
+                LOG_D(F1AP, "Processing LMF Measurement ID IE\n");
+                break;
+            case F1AP_ProtocolIE_ID_id_RAN_MeasurementID:
+                // Handle RAN Measurement ID
+                LOG_D(F1AP, "Processing RAN Measurement ID IE\n");
+                break;
+            case F1AP_ProtocolIE_ID_id_SRSConfiguration:
+                // Handle SRS Configuration (optional)
+                LOG_D(F1AP, "Processing SRS Configuration IE\n");
+                break;
+            default:
+                LOG_W(F1AP, "Unknown IE id %ld\n", ie->id);
+                break;
+        }
+    }
+
+    // Note: The positioning measurement update structure is freed by the caller
+    // in f1ap_handle_message() using ASN_STRUCT_FREE
+
+    return 0;
+}
+
+void free_positioning_measurement_update(F1AP_PositioningMeasurementUpdate_t *positioning_measurement_update) {
+    // This function provides a way to free positioning measurement update structures
+    // if needed outside of the normal message handling flow
+    
+    if (positioning_measurement_update == NULL) {
+        return;
+    }
+    
+    // Use the ASN1 library function to free the structure completely
+    // This prevents segmentation faults when the function is called externally
+    ASN_STRUCT_FREE(asn_DEF_F1AP_PositioningMeasurementUpdate, positioning_measurement_update);
+}
