+/*! \file f1ap_positioning.c
+ * \brief F1AP positioning procedures
+ * \author OpenAirInterface Software Alliance
+ * \date 2021
+ * \version 1.0
+ */
+
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <stdint.h>
+#include <string.h>
+
+#include "assertions.h"
+#include "common/utils/LOG/log.h"
+
+#include "f1ap_common.h"
+#include "f1ap_positioning.h"
+#include "f1ap_lib_includes.h"
+#include "F1AP_PositioningInformationRequest.h"
+#include "F1AP_PositioningInformationResponse.h"
+
+bool decode_positioning_information_req(
+    f1ap_positioning_information_request_t *positioning_information_request,
+    const F1AP_PositioningInformationRequest_t *positioningInformationRequest) {
+
+    DevAssert(positioning_information_request != NULL);
+    DevAssert(positioningInformationRequest != NULL);
+
+    memset(positioning_information_request, 0, sizeof(f1ap_positioning_information_request_t));
+
+    F1AP_PositioningInformationRequestIEs_t *ie = NULL;
+    // First, check mandatory IEs and validate their types immediately
+    for (int i = 0; i < positioningInformationRequest->protocolIEs.list.count; i++) {
+        ie = positioningInformationRequest->protocolIEs.list.array[i];
+
+        switch (ie->id) {
+            case F1AP_ProtocolIE_ID_id_gNB_CU_UE_F1AP_ID: {
+                if (ie->criticality == F1AP_Criticality_reject &&
+                    ie->value.present != F1AP_PositioningInformationRequestIEs__value_PR_GNB_CU_UE_F1AP_ID) {
+                    LOG_E(F1AP, "Failed to decode id-gNB-CU-UE-F1AP-ID of PositioningInformationRequest\n");
+                    return false;
+                }
+
+                positioning_information_request->gNB_CU_UE_F1AP_ID = ie->value.choice.GNB_CU_UE_F1AP_ID;
+                break;
+            }
+
+            case F1AP_ProtocolIE_ID_id_gNB_DU_UE_F1AP_ID: {
+                if (ie->criticality == F1AP_Criticality_reject &&
+                    ie->value.present != F1AP_PositioningInformationRequestIEs__value_PR_GNB_DU_UE_F1AP_ID) {
+                    LOG_E(F1AP, "Failed to decode id-gNB-DU-UE-F1AP-ID of PositioningInformationRequest\n");
+                    return false;
+                }
+
+                positioning_information_request->gNB_DU_UE_F1AP_ID = ie->value.choice.GNB_DU_UE_F1AP_ID;
+                break;
+            }
+
+            case F1AP_ProtocolIE_ID_id_RequestedSRSTransmissionCharacteristics: {
+                if (ie->value.present != F1AP_PositioningInformationRequestIEs__value_PR_RequestedSRSTransmissionCharacteristics) {
+                    LOG_W(F1AP, "Failed to decode id-RequestedSRSTransmissionCharacteristics of PositioningInformationRequest\n");
+                    break;
+                }
+
+                // Decode optional SRS transmission characteristics
+                positioning_information_request->requested_srs_transmission_characteristics_present = true;
+                
+                // Copy the bit string data
+                if (ie->value.choice.RequestedSRSTransmissionCharacteristics.size > 0) {
+                    positioning_information_request->requested_srs_transmission_characteristics_size = 
+                        ie->value.choice.RequestedSRSTransmissionCharacteristics.size;
+                    
+                    positioning_information_request->requested_srs_transmission_characteristics = 
+                        malloc(ie->value.choice.RequestedSRSTransmissionCharacteristics.size);
+                    if (positioning_information_request->requested_srs_transmission_characteristics) {
+                        memcpy(positioning_information_request->requested_srs_transmission_characteristics,
+                               ie->value.choice.RequestedSRSTransmissionCharacteristics.buf,
+                               ie->value.choice.RequestedSRSTransmissionCharacteristics.size);
+                    } else {
+                        LOG_E(F1AP, "Failed to allocate memory for SRS transmission characteristics\n");
+                        positioning_information_request->requested_srs_transmission_characteristics_size = 0;
+                        positioning_information_request->requested_srs_transmission_characteristics_present = false;
+                        // Continue processing other IEs
+                    }
+                }
+                break;
+            }
+
+            default:
+                LOG_W(F1AP, "Unknown IE %ld in PositioningInformationRequest\n", ie->id);
+                break;
+        }
+    }
+
+    return true;
+}
+
+bool encode_positioning_information_resp(
+    F1AP_PositioningInformationResponse_t *positioningInformationResponse,
+    const f1ap_positioning_information_response_t *positioning_information_response) {
+
+    DevAssert(positioningInformationResponse != NULL);
+    DevAssert(positioning_information_response != NULL);
+
+    // TODO: Implement positioning information response encoding
+    // This is a placeholder for future implementation
+    
+    return true;
+}
+
+void free_positioning_information_request(f1ap_positioning_information_request_t *positioning_information_request) {
+    if (positioning_information_request == NULL) {
+        return;
+    }
+
+    if (positioning_information_request->requested_srs_transmission_characteristics) {
+        free(positioning_information_request->requested_srs_transmission_characteristics);
+        positioning_information_request->requested_srs_transmission_characteristics = NULL;
+        positioning_information_request->requested_srs_transmission_characteristics_size = 0;
+    }
+
+    positioning_information_request->requested_srs_transmission_characteristics_present = false;
+}
