+
+#ifndef TEST_UTIL_H
+#define TEST_UTIL_H
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <stdint.h>
+#include <string.h>
+#include "common/utils/utils.h"
+
+/* Global variable to store length of last HL conversion */
+extern unsigned int hl_last_length;
+
+/* Hex conversion utilities */
+static inline int hex_char_to_int(char c) {
+    if (c >= '0' && c <= '9') return c - '0';
+    if (c >= 'A' && c <= 'F') return c - 'A' + 10;
+    if (c >= 'a' && c <= 'f') return c - 'a' + 10;
+    return -1;
+}
+
+/* HL macro implementation - converts hex literal string to binary data */
+static inline uint8_t* HL(const char* hex_str) {
+    static unsigned int last_length = 0;
+    
+    int len = strlen(hex_str);
+    int byte_len = len / 2;
+    
+    if (len % 2 != 0) {
+        fprintf(stderr, "Invalid hex string length: %d\n", len);
+        hl_last_length = 0;
+        return NULL;
+    }
+    
+    // Allocate memory for the data
+    uint8_t *data = (uint8_t*)malloc(byte_len);
+    if (!data) {
+        fprintf(stderr, "Memory allocation failed\n");
+        hl_last_length = 0;
+        return NULL;
+    }
+    
+    hl_last_length = byte_len;
+    last_length = byte_len;
+    
+    for (int i = 0; i < byte_len; i++) {
+        int high = hex_char_to_int(hex_str[2 * i]);
+        int low = hex_char_to_int(hex_str[2 * i + 1]);
+        
+        if (high == -1 || low == -1) {
+            fprintf(stderr, "Invalid hex character in string: %s\n", hex_str);
+            free(data);
+            hl_last_length = 0;
+            last_length = 0;
+            return NULL;
+        }
+        
+        data[i] = (high << 4) | low;
+    }
+    
+    return data;
+}
+
+/* Get length of last HL conversion */
+static inline unsigned int HL_LENGTH(void) {
+    return hl_last_length;
+}
+
+/* Free hex data */
+static inline void free_hex_data(uint8_t *data) {
+    if (data) {
+        free(data);
+    }
+}
+
+/* Buffer comparison function */
+static inline int compare_buffer(const uint8_t *buf1, unsigned len1, const uint8_t *buf2, unsigned len2) {
+    if (len1 != len2) return -1;
+    return memcmp(buf1, buf2, len1);
+}
+
+/* Test failure function */
+static inline void fail(const char *message) {
+    fprintf(stderr, "%s\n", message);
+    exit(EXIT_FAILURE);
+}
+
+#endif /* TEST_UTIL_H */
