+
+#include <string.h>
+#include <stdlib.h>
+
+#include "common/utils/assertions.h"
+#include "openair3/UTILS/conversions.h"
+#include "common/utils/oai_asn1.h"
+#include "common/utils/utils.h"
+
+#include "f1ap_positioning.h"
+#include "f1ap_lib_common.h"
+#include "f1ap_lib_includes.h"
+#include "f1ap_messages_types.h"
+
+// Forward declarations for ASN.1 structures that will be generated
+// These are placeholders until the actual ASN.1 compilation happens
+typedef struct F1AP_PositioningInformationRequest F1AP_PositioningInformationRequest_t;
+typedef struct F1AP_PositioningInformationRequestIEs F1AP_PositioningInformationRequestIEs_t;
+typedef struct F1AP_PositioningInformationResponse F1AP_PositioningInformationResponse_t;
+typedef struct F1AP_PositioningInformationResponseIEs F1AP_PositioningInformationResponseIEs_t;
+
+// Mock enums for IE values (these will be generated by ASN.1 compiler)
+#define F1AP_PositioningInformationRequestIEs__value_PR_GNB_CU_UE_F1AP_ID 1
+#define F1AP_PositioningInformationRequestIEs__value_PR_GNB_DU_UE_F1AP_ID 2
+
+F1AP_F1AP_PDU_t *encode_positioning_information_request(const f1ap_positioning_information_request_t *msg)
+{
+  F1AP_F1AP_PDU_t *pdu = calloc(1, sizeof(F1AP_F1AP_PDU_t));
+  AssertFatal(pdu != NULL, "could not allocate memory for F1AP PDU\n");
+  
+  pdu->present = F1AP_F1AP_PDU_PR_initiatingMessage;
+  asn1cCalloc(pdu->choice.initiatingMessage, tmp);
+  tmp->procedureCode = 49; // id-PositioningInformationExchange
+  tmp->criticality = F1AP_Criticality_reject;
+  asn1cCalloc(tmp->value.choice.PositioningInformationRequest, out);
+  
+  // Add mandatory IEs: gNB-CU-UE-F1AP-ID
+  {
+    F1AP_PositioningInformationRequestIEs_t *ie = NULL;
+    asn1cSequenceAdd(out->protocolIEs.list, F1AP_PositioningInformationRequestIEs_t, ie);
+    
+    ie->id = F1AP_ProtocolIE_ID_id_gNB_CU_UE_F1AP_ID;
+    ie->criticality = F1AP_Criticality_reject;
+    ie->value.present = F1AP_PositioningInformationRequestIEs__value_PR_GNB_CU_UE_F1AP_ID;
+    ie->value.choice.GNB_CU_UE_F1AP_ID = msg->gNB_CU_ue_id;
+  }
+  
+  // Add mandatory IEs: gNB-DU-UE-F1AP-ID
+  {
+    F1AP_PositioningInformationRequestIEs_t *ie = NULL;
+    asn1cSequenceAdd(out->protocolIEs.list, F1AP_PositioningInformationRequestIEs_t, ie);
+    
+    ie->id = F1AP_ProtocolIE_ID_id_gNB_DU_UE_F1AP_ID;
+    ie->criticality = F1AP_Criticality_reject;
+    ie->value.present = F1AP_PositioningInformationRequestIEs__value_PR_GNB_DU_UE_F1AP_ID;
+    ie->value.choice.GNB_DU_UE_F1AP_ID = msg->gNB_DU_ue_id;
+  }
+  
+  return pdu;
+}
+
+bool decode_positioning_information_req(const F1AP_F1AP_PDU_t *pdu, f1ap_positioning_information_request_t *out)
+{
+  DevAssert(pdu != NULL && out != NULL);
+  
+  memset(out, 0, sizeof(*out));
+
+  const F1AP_PositioningInformationRequest_t *container;
+  const F1AP_PositioningInformationRequestIEs_t *ie;
+
+  container = &pdu->choice.initiatingMessage->value.choice.PositioningInformationRequest;
+  
+  // Initialize flags to track mandatory IEs
+  bool gnb_cu_ue_id_found = false;
+  bool gnb_du_ue_id_found = false;
+
+  // Iterate through all IEs in the container
+  for (int i = 0; i < container->protocolIEs.list.count; i++) {
+    ie = container->protocolIEs.list.array[i];
+    
+    switch (ie->id) {
+      case F1AP_ProtocolIE_ID_id_gNB_CU_UE_F1AP_ID:
+        // Validate type immediately upon discovery
+        if (ie->value.present != F1AP_PositioningInformationRequestIEs__value_PR_GNB_CU_UE_F1AP_ID) {
+          LOG_E(F1AP, "PositioningInformationRequest IE id_gNB_CU_UE_F1AP_ID has wrong type\n");
+          return false;
+        }
+        
+        out->gNB_CU_ue_id = ie->value.choice.GNB_CU_UE_F1AP_ID;
+        gnb_cu_ue_id_found = true;
+        break;
+        
+      case F1AP_ProtocolIE_ID_id_gNB_DU_UE_F1AP_ID:
+        // Validate type immediately upon discovery
+        if (ie->value.present != F1AP_PositioningInformationRequestIEs__value_PR_GNB_DU_UE_F1AP_ID) {
+          LOG_E(F1AP, "PositioningInformationRequest IE id_gNB_DU_UE_F1AP_ID has wrong type\n");
+          return false;
+        }
+        
+        out->gNB_DU_ue_id = ie->value.choice.GNB_DU_UE_F1AP_ID;
+        gnb_du_ue_id_found = true;
+        break;
+        
+      default:
+        LOG_W(F1AP, "Unknown IE %ld in PositioningInformationRequest\n", ie->id);
+        break;
+    }
+  }
+
+  // Ensure all mandatory IEs were found
+  if (!gnb_cu_ue_id_found || !gnb_du_ue_id_found) {
+    LOG_E(F1AP, "Missing mandatory IEs in PositioningInformationRequest\n");
+    return false;
+  }
+  
+  return true;
+}
+
+f1ap_positioning_information_request_t cp_positioning_information_request(const f1ap_positioning_information_request_t *msg)
+{
+  f1ap_positioning_information_request_t ret = {0};
+  if (msg) {
+    ret.gNB_CU_ue_id = msg->gNB_CU_ue_id;
+    ret.gNB_DU_ue_id = msg->gNB_DU_ue_id;
+    
+    // Copy optional fields
+    if (msg->requested_srs_transmission_characteristics && msg->requested_srs_transmission_characteristics_length > 0) {
+      ret.requested_srs_transmission_characteristics = malloc(msg->requested_srs_transmission_characteristics_length);
+      if (ret.requested_srs_transmission_characteristics) {
+        memcpy(ret.requested_srs_transmission_characteristics, 
+               msg->requested_srs_transmission_characteristics, 
+               msg->requested_srs_transmission_characteristics_length);
+        ret.requested_srs_transmission_characteristics_length = msg->requested_srs_transmission_characteristics_length;
+      }
+    }
+  }
+  return ret;
+}
+
+bool eq_positioning_information_request(const f1ap_positioning_information_request_t *a,
+                                       const f1ap_positioning_information_request_t *b)
+{
+  if (a == b) return true;
+  if (a == NULL || b == NULL) return false;
+  
+  // Compare basic fields
+  if (a->gNB_CU_ue_id != b->gNB_CU_ue_id ||
+      a->gNB_DU_ue_id != b->gNB_DU_ue_id) {
+    return false;
+  }
+  
+  // Compare optional fields
+  if ((a->requested_srs_transmission_characteristics == NULL) != (b->requested_srs_transmission_characteristics == NULL)) {
+    return false;
+  }
+  
+  if (a->requested_srs_transmission_characteristics && b->requested_srs_transmission_characteristics) {
+    if (a->requested_srs_transmission_characteristics_length != b->requested_srs_transmission_characteristics_length) {
+      return false;
+    }
+    if (memcmp(a->requested_srs_transmission_characteristics, 
+               b->requested_srs_transmission_characteristics, 
+               a->requested_srs_transmission_characteristics_length) != 0) {
+      return false;
+    }
+  }
+  
+  return true;
+}
+
+void free_positioning_information_request(const f1ap_positioning_information_request_t *msg)
+{
+  if (msg) {
+    if (msg->requested_srs_transmission_characteristics) {
+      free(msg->requested_srs_transmission_characteristics);
+    }
+  }
+}
+
+F1AP_F1AP_PDU_t *encode_positioning_information_response(const f1ap_positioning_information_response_t *msg)
+{
+  F1AP_F1AP_PDU_t *pdu = calloc(1, sizeof(F1AP_F1AP_PDU_t));
+  AssertFatal(pdu != NULL, "could not allocate memory for F1AP PDU\n");
+  
+  pdu->present = F1AP_F1AP_PDU_PR_successfulOutcome;
+  asn1cCalloc(pdu->choice.successfulOutcome, tmp);
+  tmp->procedureCode = 49; // id-PositioningInformationExchange
+  tmp->criticality = F1AP_Criticality_reject;
+  asn1cCalloc(tmp->value.choice.PositioningInformationResponse, out);
+  
+  // Add mandatory IEs: gNB-CU-UE-F1AP-ID
+  {
+    F1AP_PositioningInformationResponseIEs_t *ie = NULL;
+    asn1cSequenceAdd(out->protocolIEs.list, F1AP_PositioningInformationResponseIEs_t, ie);
+    
+    ie->id = F1AP_ProtocolIE_ID_id_gNB_CU_UE_F1AP_ID;
+    ie->criticality = F1AP_Criticality_reject;
+    ie->value.present = F1AP_PositioningInformationResponseIEs__value_PR_GNB_CU_UE_F1AP_ID;
+    ie->value.choice.GNB_CU_UE_F1AP_ID = msg->gNB_CU_ue_id;
+  }
+  
+  // Add mandatory IEs: gNB-DU-UE-F1AP-ID
+  {
+    F1AP_PositioningInformationResponseIEs_t *ie = NULL;
+    asn1cSequenceAdd(out->protocolIEs.list, F1AP_PositioningInformationResponseIEs_t, ie);
+    
+    ie->id = F1AP_ProtocolIE_ID_id_gNB_DU_UE_F1AP_ID;
+    ie->criticality = F1AP_Criticality_reject;
+    ie->value.present = F1AP_PositioningInformationResponseIEs__value_PR_GNB_DU_UE_F1AP_ID;
+    ie->value.choice.GNB_DU_UE_F1AP_ID = msg->gNB_DU_ue_id;
+  }
+  
+  return pdu;
+}
+
+bool decode_positioning_information_response(const F1AP_F1AP_PDU_t *pdu, f1ap_positioning_information_response_t *out)
+{
+  DevAssert(pdu != NULL && out != NULL);
+  
+  memset(out, 0, sizeof(*out));
+
+  const F1AP_PositioningInformationResponse_t *container;
+  const F1AP_PositioningInformationResponseIEs_t *ie;
+
+  container = &pdu->choice.successfulOutcome->value.choice.PositioningInformationResponse;
+  
+  // Initialize flags to track mandatory IEs
+  bool gnb_cu_ue_id_found = false;
+  bool gnb_du_ue_id_found = false;
+
+  // Iterate through all IEs in the container
+  for (int i = 0; i < container->protocolIEs.list.count; i++) {
+    ie = container->protocolIEs.list.array[i];
+    
+    switch (ie->id) {
+      case F1AP_ProtocolIE_ID_id_gNB_CU_UE_F1AP_ID:
+        // Validate type immediately upon discovery
+        if (ie->value.present != F1AP_PositioningInformationResponseIEs__value_PR_GNB_CU_UE_F1AP_ID) {
+          LOG_E(F1AP, "PositioningInformationResponse IE id_gNB_CU_UE_F1AP_ID has wrong type\n");
+          return false;
+        }
+        
+        out->gNB_CU_ue_id = ie->value.choice.GNB_CU_UE_F1AP_ID;
+        gnb_cu_ue_id_found = true;
+        break;
+        
+      case F1AP_ProtocolIE_ID_id_gNB_DU_UE_F1AP_ID:
+        // Validate type immediately upon discovery
+        if (ie->value.present != F1AP_PositioningInformationResponseIEs__value_PR_GNB_DU_UE_F1AP_ID) {
+          LOG_E(F1AP, "PositioningInformationResponse IE id_gNB_DU_UE_F1AP_ID has wrong type\n");
+          return false;
+        }
+        
+        out->gNB_DU_ue_id = ie->value.choice.GNB_DU_UE_F1AP_ID;
+        gnb_du_ue_id_found = true;
+        break;
+        
+      default:
+        LOG_W(F1AP, "Unknown IE %ld in PositioningInformationResponse\n", ie->id);
+        break;
+    }
+  }
+
+  // Ensure all mandatory IEs were found
+  if (!gnb_cu_ue_id_found || !gnb_du_ue_id_found) {
+    LOG_E(F1AP, "Missing mandatory IEs in PositioningInformationResponse\n");
+    return false;
+  }
+  
+  return true;
+}
+
+f1ap_positioning_information_response_t cp_positioning_information_response(const f1ap_positioning_information_response_t *msg)
+{
+  f1ap_positioning_information_response_t ret = {0};
+  if (msg) {
+    ret.gNB_CU_ue_id = msg->gNB_CU_ue_id;
+    ret.gNB_DU_ue_id = msg->gNB_DU_ue_id;
+    
+    // Copy optional fields
+    if (msg->srs_configuration && msg->srs_configuration_length > 0) {
+      ret.srs_configuration = malloc(msg->srs_configuration_length);
+      if (ret.srs_configuration) {
+        memcpy(ret.srs_configuration, 
+               msg->srs_configuration, 
+               msg->srs_configuration_length);
+        ret.srs_configuration_length = msg->srs_configuration_length;
+      }
+    }
+    
+    if (msg->sfn_initialisation_time) {
+      ret.sfn_initialisation_time = malloc(sizeof(uint32_t));
+      if (ret.sfn_initialisation_time) {
+        *ret.sfn_initialisation_time = *msg->sfn_initialisation_time;
+      }
+    }
+  }
+  return ret;
+}
+
+bool eq_positioning_information_response(const f1ap_positioning_information_response_t *a,
+                                        const f1ap_positioning_information_response_t *b)
+{
+  if (a == b) return true;
+  if (a == NULL || b == NULL) return false;
+  
+  // Compare basic fields
+  if (a->gNB_CU_ue_id != b->gNB_CU_ue_id ||
+      a->gNB_DU_ue_id != b->gNB_DU_ue_id) {
+    return false;
+  }
+  
+  // Compare optional fields - srs_configuration
+  if ((a->srs_configuration == NULL) != (b->srs_configuration == NULL)) {
+    return false;
+  }
+  
+  if (a->srs_configuration && b->srs_configuration) {
+    if (a->srs_configuration_length != b->srs_configuration_length) {
+      return false;
+    }
+    if (memcmp(a->srs_configuration, 
+               b->srs_configuration, 
+               a->srs_configuration_length) != 0) {
+      return false;
+    }
+  }
+  
+  // Compare optional fields - sfn_initialisation_time
+  if ((a->sfn_initialisation_time == NULL) != (b->sfn_initialisation_time == NULL)) {
+    return false;
+  }
+  
+  if (a->sfn_initialisation_time && b->sfn_initialisation_time) {
+    if (*a->sfn_initialisation_time != *b->sfn_initialisation_time) {
+      return false;
+    }
+  }
+  
+  return true;
+}
+
+void free_positioning_information_response(const f1ap_positioning_information_response_t *msg)
+{
+  if (msg) {
+    if (msg->srs_configuration) {
+      free(msg->srs_configuration);
+    }
+    if (msg->sfn_initialisation_time) {
+      free(msg->sfn_initialisation_time);
+    }
+  }
+}
