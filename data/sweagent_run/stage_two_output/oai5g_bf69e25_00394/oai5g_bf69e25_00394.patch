+static void print_ether_addr_safe(const char *pre, int num_ether, int max_ether, const struct rte_ether_addr *addrs)
+{
+  int safe_count = (num_ether < max_ether) ? num_ether : max_ether;
+  if (safe_count < 0) safe_count = 0;
+  
+  printf("%s [", pre);
+  for (int i = 0; i < safe_count; ++i) {
+    char buf[18];
+    rte_ether_format_addr(buf, 18, &addrs[i]);
+    printf("%s", buf);
+    if (i != safe_count - 1)
+      printf(", ");
+  }
+  printf("]\n");
+}
