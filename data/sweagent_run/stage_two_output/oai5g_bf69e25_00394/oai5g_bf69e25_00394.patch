+    print_ether_addr_safe("  p_o_ru_addr", num_ru_addr, fh_init->xran_ports * fh_init->io_cfg.num_vfs, (struct rte_ether_addr *)fh_init->p_o_ru_addr);
+  } else if (fh_init->p_o_du_addr) {
+    // When p_o_du_addr is allocated, we're configured as RU
+    // Number of DU addresses equals the number of DU ports (which is xran_ports in RU configuration)
+    int num_du_addr = fh_init->xran_ports;
+    print_ether_addr_safe("  p_o_du_addr", num_du_addr, fh_init->xran_ports * fh_init->io_cfg.num_vfs, (struct rte_ether_addr *)fh_init->p_o_du_addr);
