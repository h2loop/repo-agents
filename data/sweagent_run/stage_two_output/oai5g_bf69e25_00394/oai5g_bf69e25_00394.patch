+#ifdef OAI_MPLANE
+  // For M-Plane case, calculate the correct number of addresses
+  int num_ru_addr = (fh_init->io_cfg.one_vf_cu_plane) ? fh_init->xran_ports : 2*fh_init->xran_ports;
+  if (fh_init->p_o_ru_addr) 
+    print_ether_addr_safe("  p_o_ru_addr", num_ru_addr, fh_init->xran_ports * fh_init->io_cfg.num_vfs, (struct rte_ether_addr *)fh_init->p_o_ru_addr);
+#else
+  // For regular case, calculate the correct number of addresses based on the configuration
+  if (fh_init->p_o_ru_addr) {
+    // When p_o_ru_addr is allocated, we're configured as DU
+    // Number of RU addresses follows the same formula as M-Plane case
