+void *rrc_enb_process_itti_msg(void *notUsed) {
+  MessageDef                         *msg_p;
+  // Wait for a message
+  itti_poll_msg(TASK_RRC_ENB, &msg_p);
+  while (msg_p) {
+    rrc_enb_process_one_itti_msg(msg_p);
     itti_poll_msg(TASK_RRC_ENB, &msg_p);
   }
