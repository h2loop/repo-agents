 }
 
+int rrc_enb_process_itti_msg_one_shot(void) {
+  MessageDef *msg_p;
+  int count = 0;
+  
+  // Process all available messages without blocking
+  if (itti_poll_msg(TASK_RRC_ENB, &msg_p) == 0 && msg_p != NULL) {
+    do {
+      rrc_enb_process_one_itti_msg(msg_p);
+      count++;
+    } while (itti_poll_msg(TASK_RRC_ENB, &msg_p) == 0 && msg_p != NULL);
+  }
+  
+  return count;
+}
