@@ -73,6 +89,30 @@ rrc_config_buffer(
 {
   Srb_info->Rx_buffer.payload_size = 0;
   Srb_info->Tx_buffer.payload_size = 0;
+  
+  // Configure LCHAN_DESC based on logical channel type
+  switch (Lchan_type) {
+    case 0: // CCCH
+      memcpy(&Srb_info->Lchan_desc[0], &CCCH_LCHAN_DESC, LCHAN_DESC_SIZE);
+      memcpy(&Srb_info->Lchan_desc[1], &CCCH_LCHAN_DESC, LCHAN_DESC_SIZE);
+      break;
+      
+    case 1: // DCCH
+      memcpy(&Srb_info->Lchan_desc[0], &DCCH_LCHAN_DESC, LCHAN_DESC_SIZE);
+      memcpy(&Srb_info->Lchan_desc[1], &DCCH_LCHAN_DESC, LCHAN_DESC_SIZE);
+      break;
+      
+    case 3: // BCCH
+      memcpy(&Srb_info->Lchan_desc[0], &CCCH_LCHAN_DESC, LCHAN_DESC_SIZE);  // BCCH uses similar config as CCCH
+      memcpy(&Srb_info->Lchan_desc[1], &CCCH_LCHAN_DESC, LCHAN_DESC_SIZE);
+      break;
+      
+    default:
+      // Use CCCH as default for unknown types
+      memcpy(&Srb_info->Lchan_desc[0], &CCCH_LCHAN_DESC, LCHAN_DESC_SIZE);
+      memcpy(&Srb_info->Lchan_desc[1], &CCCH_LCHAN_DESC, LCHAN_DESC_SIZE);
+      break;
+  }
