   void mac_destroy(mac_t *mac) {
     mac_internal_t *instance = (mac_internal_t *)mac;
+    
+    // Close sockets if they were opened
+    if(instance->rx_sock >= 0) {
+      close(instance->rx_sock);
+    }
+    if(instance->tx_sock >= 0) {
+      close(instance->tx_sock);
+    }
+    
     delete instance->mac;
     free(instance);
