+int decode_ng_handover_request(
+  NGAP_HandoverRequest_t *handover_request_p,
+  const uint8_t *const buffer,
+  const uint32_t length)
+{
+  asn_dec_rval_t dec_ret;
+  DevAssert(handover_request_p != NULL);
+  DevAssert(buffer != NULL);
+  
+  memset(handover_request_p, 0, sizeof(NGAP_HandoverRequest_t));
+  
+  asn_codec_ctx_t st = {.max_stack_size = 100 * 1000}; // if we enable asn1c debug the stack size become large
+  dec_ret = aper_decode(&st, 
+                        &asn_DEF_NGAP_HandoverRequest, 
+                        (void **)&handover_request_p, 
+                        buffer, 
+                        length, 
+                        0, 
+                        0);
+
+  if (dec_ret.code != RC_OK) {
+    NGAP_ERROR("Failed to decode HandoverRequest\n");
+    return -1;
+  }
+
+  return 0;
+}
