@@ -69,6 +69,7 @@ struct socket_id_s {
   char rhost[SOCKET_HOSTNAME_SIZE]; /* remote hostname    */
   struct sockaddr_storage addr; /* remote address   */
   int fd; /* socket file descriptor */
+  pthread_mutex_t mutex; /* mutex for synchronization */
 };
 
 /* Set socket option at the sockets API level (SOL_SOCKET) */
@@ -221,6 +222,7 @@ void* socket_udp_open(int type, const char* host, const char* port)
     sid->type = type;
     sid->port = atoi (port);
     sid->fd = sfd;
+    pthread_mutex_init(&sid->mutex, NULL);
   } else {
     close (sfd);
   }
@@ -248,8 +250,10 @@ void* socket_udp_open(int type, const char* host, const char* port)
 void socket_close(void* id)
 {
   if (id) {
-    close (((socket_id_t*) id)->fd);
-    free (id);
+    socket_id_t* sid = (socket_id_t*) id;
+    close (sid->fd);
+    pthread_mutex_destroy(&sid->mutex);
+    free (sid);
   }
 }
 
@@ -283,9 +287,13 @@ ssize_t socket_recv(void* id, char* buffer, size_t length)
     struct sockaddr_storage addr;
     socklen_t addrlen = sizeof(addr);
 
-    /* Receive data from the socket and retreive the remote host address */
+    /* Receive data from the socket and retrieve the remote host address */
     rbytes = recvfrom (sid->fd, buffer, length, 0, (struct sockaddr *) &addr, &addrlen);
+    
+    /* Protect modification of sid->addr with mutex */
+    pthread_mutex_lock(&sid->mutex);
     sid->addr = addr;
+    pthread_mutex_unlock(&sid->mutex);
   }
 
   if (errno == EINTR) {
@@ -326,8 +334,10 @@ ssize_t socket_send(const void* id, const char* buffer, size_t length)
     /* Send data to the connected socket */
     sbytes = send (sid->fd, buffer, length, 0);
   } else if (sid->type == SOCKET_SERVER) {
-    /* Send data to the socket using the remote host address */
+    /* Protect reading of sid->addr with mutex */
+    pthread_mutex_lock((pthread_mutex_t*)&sid->mutex);
     sbytes = sendto (sid->fd, buffer, length, 0, (struct sockaddr *) &sid->addr, (socklen_t) sizeof(sid->addr));
+    pthread_mutex_unlock((pthread_mutex_t*)&sid->mutex);
   }
 
   if (errno == EINTR) {
