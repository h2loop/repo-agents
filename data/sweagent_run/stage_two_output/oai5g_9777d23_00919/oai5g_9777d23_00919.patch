@@ -532,6 +532,42 @@ void ra_preambles_config(NR_PRACH_RESOURCES_t *prach_resources, NR_UE_MAC_INST_t
 // - check if SSB or CSI-RS have not changed since the selection in the last RA Preamble tranmission
 // - Contention-based RA preamble selection:
 // -- selection of SSB with SS-RSRP above rsrp-ThresholdSSB else select any SSB
+static int get_ssb_ro_preambles_2step(NR_UE_MAC_INST_t *mac,
+                                      NR_RACH_ConfigDedicated_t *rach_ConfigDedicated,
+                                      uint8_t ssb_resource_idx)
+{
+  RA_config_t *ra = &mac->ra;
+  
+  if (rach_ConfigDedicated) {
+    // Check standard CFRA configuration
+    if (rach_ConfigDedicated->cfra && 
+        rach_ConfigDedicated->cfra->resources.choice.ssb &&
+        rach_ConfigDedicated->cfra->resources.choice.ssb->ssb_ResourceList.list.count > ssb_resource_idx) {
+      
+      ra->ra_PreambleIndex = rach_ConfigDedicated->cfra->resources.choice.ssb->ssb_ResourceList.list.array[ssb_resource_idx]->ra_PreambleIndex;
+      LOG_D(MAC, "Selected RA preamble index %d for 2-step contention-free random access procedure for SSB with Id %d\n",
+            ra->ra_PreambleIndex,
+            ssb_resource_idx);
+      return 0;
+    }
+    
+    // Check Rel-16 2-step CFRA configuration
+    if (rach_ConfigDedicated->ext1 && 
+        rach_ConfigDedicated->ext1->cfra_TwoStep_r16 &&
+        rach_ConfigDedicated->ext1->cfra_TwoStep_r16->cfra_SSB_ResourceList_r16.list.count > ssb_resource_idx) {
+      
+      ra->ra_PreambleIndex = rach_ConfigDedicated->ext1->cfra_TwoStep_r16->cfra_SSB_ResourceList_r16.list.array[ssb_resource_idx]->ra_PreambleIndex_r16;
+      LOG_D(MAC, "Selected RA preamble index %d for Rel-16 2-step contention-free random access procedure for SSB with Id %d\n",
+            ra->ra_PreambleIndex,
+            ssb_resource_idx);
+      return 0;
+    }
+  }
+  
+  LOG_W(NR_MAC, "Failed to get SSB resource for 2-step RA with index %d\n", ssb_resource_idx);
+  return -1;
+}
