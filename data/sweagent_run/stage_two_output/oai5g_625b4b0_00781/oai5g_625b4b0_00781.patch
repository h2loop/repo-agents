+  // For example, if length=5: complete_words=1 (4 bytes), remaining_bytes=1 (1 byte)
+  uint32_t complete_words = src->length / 4;
+  uint32_t remaining_bytes = src->length % 4;
+  
+  // Copy complete 32-bit words (all bytes in these words are valid)
+  for (uint32_t i = 0; i < complete_words; ++i) {
     dst->value[i] = src->value[i];
   }
+  
+  // Handle partial word - copy only valid bytes and zero-pad the rest
+  // This ensures padding bytes don't contain garbage values
+  if (remaining_bytes > 0) {
+    // Create mask to keep only valid bytes
+    // For remaining_bytes=n, we keep the n least significant bytes
+    // Example: remaining_bytes=1 => mask=0x000000FF (keep LSB)
+    uint32_t mask = (1ULL << (8 * remaining_bytes)) - 1;
+    
+    // Copy only the valid bytes and zero-pad the padding bytes
+    dst->value[complete_words] = src->value[complete_words] & mask;
+  }
 }
 
