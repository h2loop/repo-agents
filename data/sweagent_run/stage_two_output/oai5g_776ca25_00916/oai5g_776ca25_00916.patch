+/*! \file f1ap_positioning.c
+ * \brief F1AP positioning functions implementation
+ * \author OpenAirInterface Software Alliance
+ * \date 2022
+ * \version 1.0
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ */
+
+#include "f1ap_positioning.h"
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <assert.h>
+
+// Mutex for protecting shared counter in TRP info comparisons
+pthread_mutex_t trp_info_mutex;
+
+// Shared counter for TRP information type response items
+static int trp_info_comparison_counter = 0;
+
+// Placeholder ASN.1 header includes
+// In a real implementation, these would be generated from ASN.1 specifications
+#include "TRPInformationType.h"  // Placeholder for actual ASN.1 generated headers
+
+/**
+ * Compare two TRP information type response items.
+ * Thread-safe function that uses mutex to protect shared counter.
+ * Returns 1 if items are equal, 0 if not equal, -1 on error.
+ */
+int eq_trp_info_type_response_item(TRP_Information_Type_Item *item1, TRP_Information_Type_Item *item2)
+{
+    // Check for null pointers
+    if (item1 == NULL || item2 == NULL) {
+        fprintf(stderr, "NULL pointer passed to eq_trp_info_type_response_item\n");
+        return -1; // Error condition
+    }
+
+    // Lock the mutex before accessing shared counter
+    if (pthread_mutex_lock(&trp_info_mutex) != 0) {
+        fprintf(stderr, "Failed to lock trp_info_mutex\n");
+        return -1; // Error condition
+    }
+
+    // Increment the shared counter (this was causing race conditions)
+    trp_info_comparison_counter++;
+
+    // Store current counter value for logging/debugging purposes
+    int current_count = trp_info_comparison_counter;
+
+    // Unlock the mutex as soon as possible
+    if (pthread_mutex_unlock(&trp_info_mutex) != 0) {
+        fprintf(stderr, "Failed to unlock trp_info_mutex\n");
+        return -1; // Error condition
+    }
+
+    // Perform actual comparison of TRP information type response items
+    // This is a simplified example - in reality, this would involve
+    // comparing the actual fields of the TRP information items
+    
+    // For now, we just check if both pointers are valid and point to the same memory
+    // In a real implementation, we would compare the actual contents
+    int result = (item1 == item2) ? 1 : 0;
+    
+    // Log the comparison for debugging (in a thread-safe manner)
+    if (pthread_mutex_lock(&trp_info_mutex) == 0) {
+        printf("TRP Info Comparison #%d: item1=%p, item2=%p, result=%d\n", 
+               current_count, (void*)item1, (void*)item2, result);
+        pthread_mutex_unlock(&trp_info_mutex);
+    }
+    
+    return result;
+}
+
+int init_trp_positioning(void)
+{
+    // Initialize the mutex
+    int ret = pthread_mutex_init(&trp_info_mutex, NULL);
+    if (ret != 0) {
+        fprintf(stderr, "Failed to initialize trp_info_mutex\n");
+        return -1;
+    }
+    
+    // Reset the counter
+    trp_info_comparison_counter = 0;
+    
+    return 0; // Success
+}
+
+void cleanup_trp_positioning(void)
+{
+    // Destroy the mutex
+    pthread_mutex_destroy(&trp_info_mutex);
+    
+    // Reset the counter
+    trp_info_comparison_counter = 0;
+}
