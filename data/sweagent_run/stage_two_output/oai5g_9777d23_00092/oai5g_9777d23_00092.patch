-    pOut[2] = (in & 0xFF00) >> 8;
-    pOut[3] = (in & 0xFF);
-#else
-    pOut[0] = (in & 0xFF);
-    pOut[1] = (in & 0xFF00) >> 8;
-    pOut[2] = (in & 0xFF0000) >> 16;
-    pOut[3] = (in & 0xFF000000) >> 24;
-#endif
