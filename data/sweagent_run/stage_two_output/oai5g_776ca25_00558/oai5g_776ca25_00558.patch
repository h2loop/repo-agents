+    if (m->ids[i].state == M3ID_STATE_SOURCE_OVERALL &&
+        t->tti > m->ids[i].tm3_reloc_overall_start + t->tm3_reloc_overall) {
+      LOG_I(M3AP, "M3 timeout reloc overall\n");
+      /* tm3_reloc_overall timed out */
+      cause = M3AP_TM3_RELOC_OVERALL_TIMEOUT;
+      goto timeout;
+    }
+
+    /* no timeout -> check next UE */
+    continue;
+
+  timeout:
+    /* TODO: inform target about timeout */
+    /* For now, just skip sending to target and only inform RRC */
+    /* target = m3ap_id_get_target(m, i); */
+    /* Need to find equivalent M3 function for: */
+    /* m3ap_eNB_generate_m3_handover_cancel(instance_p, target, i, cause); */
+
+    /* inform RRC of cancellation */
+    msg = itti_alloc_new_message(TASK_M3AP, 0, M3AP_HANDOVER_CANCEL);
+    M3AP_HANDOVER_CANCEL(msg).rnti  = m3ap_id_get_rnti(m, i);
+    M3AP_HANDOVER_CANCEL(msg).cause = cause;
+    itti_send_msg_to_task(TASK_RRC_ENB, instance_p->instance, msg);
+
+    /* remove UE from M3AP */
+    m3ap_release_id(m, i);
+  }
+
+  if (m3_ongoing && t->tti % 1000 == 0)
+    LOG_I(M3AP, "M3 has %d process ongoing\n", m3_ongoing);
 }
 
 uint64_t m3ap_timer_get_tti(m3ap_timers_t *t)
