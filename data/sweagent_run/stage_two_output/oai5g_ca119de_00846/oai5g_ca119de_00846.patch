@@ -922,6 +922,19 @@ _activate_default_eps_bearer_context_accept(
 {
   int index = 0;
 
+  /* EPS bearer identity */
+  index += snprintf(buffer + index, length - index, "EBI = %d", 
+                    msg->epsbeareridentity);
+  
+  /* Procedure transaction identity */
+  index += snprintf(buffer + index, length - index, ", PTI = %d", 
+                    msg->proceduretransactionidentity);
+  
+  /* Protocol configuration options */
+  if (msg->presencemask & ACTIVATE_DEFAULT_EPS_BEARER_CONTEXT_ACCEPT_PROTOCOL_CONFIGURATION_OPTIONS_PRESENT) {
+    index += snprintf(buffer + index, length - index, ", PCO = present");
+  }
+
   return (index);
 }
 
