diff --git a/openair3/NAS/UE/API/USER/at_command.c b/openair3/NAS/UE/API/USER/at_command.c
index a6591c6748..f164be747d 100644
--- a/openair3/NAS/UE/API/USER/at_command.c
+++ b/openair3/NAS/UE/API/USER/at_command.c
@@ -317,10 +317,17 @@ int at_command_get_list(const char** buffer, int n_max)
 {
   LOG_FUNC_IN;
 
+  /* Check for null pointer */
+  if (buffer == NULL) {
+    LOG_TRACE(ERROR, "USR-API   - Null pointer encountered in at_command_get_list");
+    LOG_FUNC_RETURN(0);
+  }
+
   int handler_index = 0;
 
-  while ( (strcmp(_at_command_handler[handler_index].command, "null") != 0) &&
-          (handler_index < n_max) ) {
+  /* Fixed the condition order to prevent out-of-bounds access */
+  while ( (handler_index < n_max) &&
+          (strcmp(_at_command_handler[handler_index].command, "null") != 0) ) {
     *buffer++ = _at_command_handler[handler_index++].command;
   }
 
