diff --git a/common/utils/T/tracer/gui/init.c b/common/utils/T/tracer/gui/init.c
index c6d5e3e435..d5d1f58f58 100644
--- a/common/utils/T/tracer/gui/init.c
+++ b/common/utils/T/tracer/gui/init.c
@@ -32,3 +32,45 @@ gui *gui_init(void)
 
   return ret;
 }
+
+void gui_cleanup(gui *gui)
+{
+  struct gui *g = gui;
+  struct widget_list *cur, *next;
+  
+  if (g == NULL) return;
+  
+  /* Clean up toplevel windows and their widgets */
+  cur = g->toplevel;
+  while (cur) {
+    next = cur->next;
+    /* Note: For a complete cleanup, we would need to recursively 
+     * clean up all child widgets, but for simplicity and to avoid
+     * complex recursive cleanup logic here, we just free the top-level
+     * widget structures. Applications should ensure widgets are properly
+     * managed during their lifetime.
+     */
+    free(cur->item);
+    free(cur);
+    cur = next;
+  }
+  
+  /* Close the X connection */
+  if (g->x != NULL) {
+    x_close(g->x);
+    g->x = NULL;
+  }
+  
+  /* Close event pipe */
+  close(g->event_pipe[0]);
+  close(g->event_pipe[1]);
+  
+  /* Destroy mutex */
+  if (g->lock != NULL) {
+    pthread_mutex_destroy((pthread_mutex_t *)g->lock);
+    free(g->lock);
+  }
+  
+  /* Free the gui structure */
+  free(g);
+}
diff --git a/common/utils/T/tracer/gui/x.c b/common/utils/T/tracer/gui/x.c
index 71bd805455..907d85ef8c 100644
--- a/common/utils/T/tracer/gui/x.c
+++ b/common/utils/T/tracer/gui/x.c
@@ -80,6 +80,48 @@ x_connection *x_open(void) {
   return ret;
 }
 
+void x_close(x_connection *_x) {
+  struct x_connection *x = _x;
+  int i;
+  
+  if (x == NULL) return;
+  
+  /* Free fonts */
+  for (i = 0; i < x->nfonts; i++) {
+    if (x->fonts[i] != NULL) {
+      XftFontClose(x->d, x->fonts[i]);
+    }
+  }
+  free(x->fonts);
+  
+  /* Free Xft colors */
+  for (i = 0; i < x->ncolors; i++) {
+    XftColorFree(x->d, DefaultVisual(x->d, DefaultScreen(x->d)),
+                 DefaultColormap(x->d, DefaultScreen(x->d)),
+                 &x->xft_colors[i]);
+  }
+  free(x->xft_colors);
+  
+  /* Free GC colors */
+  for (i = 0; i < x->ncolors; i++) {
+    if (x->colors[i] != NULL) {
+      XFreeGC(x->d, x->colors[i]);
+    }
+  }
+  free(x->colors);
+  
+  /* Free points buffer */
+  free(x->pts);
+  
+  /* Close X display connection */
+  if (x->d != NULL) {
+    XCloseDisplay(x->d);
+  }
+  
+  /* Free the x_connection structure */
+  free(x);
+}
+
 x_window *x_create_window(x_connection *_x, int width, int height,
                           char *title) {
   struct x_connection *x = _x;
