--- a/openair3/NAS/UE/nas_proc.c
+++ b/openair3/NAS/UE/nas_proc.c
@@ -135,6 +135,8 @@ void nas_proc_cleanup(nas_user_t *user)
     LOG_TRACE(ERROR, "NAS-PROC  - Failed to detach from the network");
   }
 
+  /* Reset signal quality to unknown state */
+  nas_proc_reset_signal_quality(user);
 
   /* Perform the EPS Mobility Manager's clean up procedure */
   emm_main_cleanup(user);
@@ -361,6 +363,30 @@ int nas_proc_get_signal_quality(nas_user_t *user, int *rsrq, int *rsrp)
   LOG_FUNC_RETURN (RETURNok);
 }
 
+/****************************************************************************
+ **                                                                        **
+ ** Name:    nas_proc_reset_signal_quality()                               **
+ **                                                                        **
+ ** Description: Reset the signal strength/quality parameters to unknown   **
+ **                                                                        **
+ ** Inputs:  user:      Pointer to the NAS user context            **
+ **      Others:    None                                       **
+ **                                                                        **
+ ** Outputs:     None                                                      **
+ **      Return:    None                                       **
+ **      Others:    user->proc.rsrq, user->proc.rsrp           **
+ **                                                                        **
+ ***************************************************************************/
+void nas_proc_reset_signal_quality(nas_user_t *user)
+{
+  LOG_FUNC_IN;
+
+  user->proc.rsrq = NAS_PROC_RSRQ_UNKNOWN;
+  user->proc.rsrp = NAS_PROC_RSRP_UNKNOWN;
+
+  LOG_FUNC_OUT;
+}
+
 /****************************************************************************
  **                                                                        **
  ** Name:    nas_proc_register()                                       **
@@ -580,6 +606,9 @@ int nas_proc_detach(nas_user_t *user, bool switch_off)
     rc = emm_sap_send(user, &emm_sap);
   }
 
+  /* Reset signal quality to unknown state since we're detaching */
+  nas_proc_reset_signal_quality(user);
+
   LOG_FUNC_RETURN (rc);
 }
 
@@ -604,6 +633,9 @@ int nas_proc_attach(nas_user_t *user)
   emm_sap_t emm_sap;
   int rc = RETURNok;
 
+  /* Reset signal quality to unknown state before attaching */
+  nas_proc_reset_signal_quality(user);
+
   if ( !emm_main_is_attached(user->emm_data) ) {
     /* Initiate an Attach procedure */
     emm_sap.primitive = EMMREG_ATTACH_INIT;
