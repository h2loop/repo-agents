diff --git a/openair3/NAS/UE/EMM/emm_main.c b/openair3/NAS/UE/EMM/emm_main.c
index 3deabbe9be..f94e01221a 100644
--- a/openair3/NAS/UE/EMM/emm_main.c
+++ b/openair3/NAS/UE/EMM/emm_main.c
@@ -314,6 +314,35 @@ void emm_main_initialize(nas_user_t *user, emm_indication_callback_t cb, const c
 
     user->emm_data->status = user->usim_data.epsloci.status;
 
+    /* Map EPS update status to network registration status */
+    switch (user->usim_data.epsloci.status) {
+      case USIM_EPSLOCI_UPDATED:
+        /* UE was successfully registered */
+        if (TAI_IS_VALID(user->usim_data.epsloci.tai)) {
+          if (PLMNS_ARE_EQUAL(user->emm_data->hplmn, user->usim_data.epsloci.tai.plmn)) {
+            user->emm_data->stat = NET_REG_STATE_HN;  /* Home network */
+          } else {
+            user->emm_data->stat = NET_REG_STATE_ROAMING;  /* Roaming */
+          }
+        } else {
+          /* Valid status but invalid TAI - registration state unknown */
+          user->emm_data->stat = NET_REG_STATE_UNKNOWN;
+        }
+        break;
+      case USIM_EPSLOCI_NOT_UPDATED:
+        /* UE was not registered, currently trying to attach */
+        user->emm_data->stat = NET_REG_STATE_ON;
+        break;
+      case USIM_EPSLOCI_ROAMING_NOT_ALLOWED:
+        /* Registration denied due to roaming restrictions */
+        user->emm_data->stat = NET_REG_STATE_DENIED;
+        break;
+      default:
+        /* Unknown status, default to OFF */
+        user->emm_data->stat = NET_REG_STATE_OFF;
+        break;
+    }
+
     /* Get NAS configuration parameters */
     user->emm_data->NAS_SignallingPriority =
       user->usim_data.nasconfig.NAS_SignallingPriority.value[0];
