+/**
+ * \brief Deliver UE context release command to lower layers
+ * \param deliver_pdu_data Contains context data for the release command
+ * \param ue_id UE identifier
+ * \param srb_id Signaling Radio Bearer identifier
+ * \param buf Pointer to the RRC container buffer (memory management handled by PDCP layer)
+ * \param size Size of the buffer
+ * \param sdu_id SDU identifier
+ * 
+ * This function allocates memory for the rrc_container byte array structure on the heap
+ * and ensures it is properly freed after being processed by lower layers.
+ * The buf parameter is managed by the PDCP layer and should not be freed by this function.
+ */
 static void rrc_deliver_ue_ctxt_release_cmd(void *deliver_pdu_data, ue_id_t ue_id, int srb_id, char *buf, int size, int sdu_id)
 {
   DevAssert(deliver_pdu_data != NULL);
   deliver_ue_ctxt_release_data_t *data = deliver_pdu_data;
-  byte_array_t rrc_cont = {.buf = (uint8_t *)buf, .len = size};
-  data->release_cmd->rrc_container = &rrc_cont;
+  
+  // Allocate byte_array_t structure on heap to ensure proper memory management
+  byte_array_t *rrc_cont = calloc(1, sizeof(byte_array_t));
+  AssertFatal(rrc_cont != NULL, "Memory allocation failed for rrc_container\n");
+  
+  rrc_cont->buf = (uint8_t *)buf;
+  rrc_cont->len = size;
+  
+  data->release_cmd->rrc_container = rrc_cont;
   data->rrc->mac_rrc.ue_context_release_command(data->assoc_id, data->release_cmd);
+  
+  // Free the heap-allocated byte_array_t structure
+  // Note: Lower layers make their own copy via cp_ue_context_rel_cmd, so we can safely free ours
+  free(rrc_cont);
 }
 
