+      if (abs_freq_ssb >= 0 && abs_freq_ssb <= INT_MAX) {
+        n.absoluteFrequencySSB = (int)abs_freq_ssb;
+      } else {
+        LOG_W(GNB_APP, "Invalid absoluteFrequencySSB value: %ld, setting to 0\n", abs_freq_ssb);
+        n.absoluteFrequencySSB = 0;
+      }
+      
       n.tac = *NeighbourCellParamList.paramarray[l][GNB_CONFIG_N_CELL_TAC_IDX].uptr;
 
       char neighbour_plmn_path[CONFIG_MAXOPTLENGTH];
