diff --git a/nfapi/open-nFAPI/fapi/src/nr_fapi_p7_utils.c b/nfapi/open-nFAPI/fapi/src/nr_fapi_p7_utils.c
new file mode 100644
index 0000000000..71f5ae4f1d
--- /dev/null
+++ b/nfapi/open-nFAPI/fapi/src/nr_fapi_p7_utils.c
@@ -0,0 +1,72 @@
+/*
+ * Copyright 2019-2021 OpenAirInterface (OAI) Software Alliance
+ * 
+ * Licensed under the Apache License, Version 2.0 (the "License");
+ * you may not use this file except in compliance with the License.
+ * You may obtain a copy of the License at
+ * 
+ *      http://www.apache.org/licenses/LICENSE-2.0
+ * 
+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+#include <stdlib.h>
+#include <string.h>
+#include "nr_fapi_p7_utils.h"
+
+int copy_uci_indication_PUSCH(nfapi_nr_uci_pusch_pdu_t *dest, const nfapi_nr_uci_pusch_pdu_t *src)
+{
+    if (!dest || !src) {
+        return -1;
+    }
+
+    // Shallow copy first
+    *dest = *src;
+
+    // Handle HARQ payload
+    if (src->harq.harq_payload && src->harq.harq_bit_len > 0) {
+        dest->harq.harq_payload = malloc(sizeof(uint8_t) * ((src->harq.harq_bit_len + 7) / 8));
+        if (!dest->harq.harq_payload) {
+            return -1;
+        }
+        memcpy(dest->harq.harq_payload, src->harq.harq_payload, sizeof(uint8_t) * ((src->harq.harq_bit_len + 7) / 8));
+    }
+
+    // Handle CSI Part 1 payload
+    if (src->csi_part1.csi_part1_payload && src->csi_part1.csi_part1_bit_len > 0) {
+        dest->csi_part1.csi_part1_payload = malloc(sizeof(uint8_t) * ((src->csi_part1.csi_part1_bit_len + 7) / 8));
+        if (!dest->csi_part1.csi_part1_payload) {
+            // Free previously allocated memory
+            if (dest->harq.harq_payload) {
+                free(dest->harq.harq_payload);
+                dest->harq.harq_payload = NULL;
+            }
+            return -1;
+        }
+        memcpy(dest->csi_part1.csi_part1_payload, src->csi_part1.csi_part1_payload, sizeof(uint8_t) * ((src->csi_part1.csi_part1_bit_len + 7) / 8));
+    }
+
+    // Handle CSI Part 2 payload
+    if (src->csi_part2.csi_part2_payload && src->csi_part2.csi_part2_bit_len > 0) {
+        dest->csi_part2.csi_part2_payload = malloc(sizeof(uint8_t) * ((src->csi_part2.csi_part2_bit_len + 7) / 8));
+        if (!dest->csi_part2.csi_part2_payload) {
+            // Free previously allocated memory
+            if (dest->harq.harq_payload) {
+                free(dest->harq.harq_payload);
+                dest->harq.harq_payload = NULL;
+            }
+            if (dest->csi_part1.csi_part1_payload) {
+                free(dest->csi_part1.csi_part1_payload);
+                dest->csi_part1.csi_part1_payload = NULL;
+            }
+            return -1;
+        }
+        memcpy(dest->csi_part2.csi_part2_payload, src->csi_part2.csi_part2_payload, sizeof(uint8_t) * ((src->csi_part2.csi_part2_bit_len + 7) / 8));
+    }
+
+    return 0;
+}
\ No newline at end of file
