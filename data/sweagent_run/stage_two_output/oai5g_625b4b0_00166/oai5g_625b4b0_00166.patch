+#ifndef _NR_FAPI_P7_UTILS_H_
+#define _NR_FAPI_P7_UTILS_H_
+
+#include "nfapi_nr_interface_scf.h"
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/** Copy UCI indication PUSCH PDU with proper memory allocation for dynamic payloads
+ *
+ * @param dest Destination PUSCH PDU
+ * @param src Source PUSCH PDU
+ * @return 0 on success, -1 on failure
+ */
+int copy_uci_indication_PUSCH(nfapi_nr_uci_pusch_pdu_t *dest, const nfapi_nr_uci_pusch_pdu_t *src);
+
+#ifdef __cplusplus
+}
+#endif
