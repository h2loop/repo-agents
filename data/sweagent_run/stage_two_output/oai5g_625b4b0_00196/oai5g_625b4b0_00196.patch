+int32_t get_prs_max_dl_toa(PHY_VARS_NR_UE *ue, uint8_t gNB_id, uint8_t rsc_id) {
+  // Validate input parameters
+  if (ue == NULL) {
+    LOG_E(PHY, "get_prs_max_dl_toa: NULL UE pointer provided\n");
+    return -1;
+  }
+
+  if (gNB_id >= NUMBER_OF_CONNECTED_gNB_MAX) {
+    LOG_E(PHY, "get_prs_max_dl_toa: Invalid gNB_id %d, max allowed %d\n", gNB_id, NUMBER_OF_CONNECTED_gNB_MAX-1);
+    return -1;
+  }
+
+  if (ue->prs_vars[gNB_id] == NULL) {
+    LOG_E(PHY, "get_prs_max_dl_toa: PRS variables not initialized for gNB_id %d\n", gNB_id);
+    return -1;
+  }
+
+  if (rsc_id >= NR_MAX_PRS_RESOURCES_PER_SET) {
+    LOG_E(PHY, "get_prs_max_dl_toa: Invalid rsc_id %d, max allowed %d\n", rsc_id, NR_MAX_PRS_RESOURCES_PER_SET-1);
+    return -1;
+  }
+
+  if (ue->prs_vars[gNB_id]->prs_resource[rsc_id].prs_meas == NULL) {
+    LOG_E(PHY, "get_prs_max_dl_toa: PRS measurements not initialized for gNB_id %d, rsc_id %d\n", gNB_id, rsc_id);
+    return -1;
+  }
+
+  // Get the number of receive antennas from frame parameters
+  uint8_t nb_antennas_rx = ue->frame_parms.nb_antennas_rx;
+  if (nb_antennas_rx == 0) {
+    LOG_E(PHY, "get_prs_max_dl_toa: No receive antennas configured\n");
+    return -1;
+  }
+
+  // Find the maximum dl_toa across all receive antennas
+  int32_t max_dl_toa = -1; // Initialize to -1 to indicate no valid measurement found yet
+  bool valid_measurement_found = false;
+
+  for (uint8_t rxAnt = 0; rxAnt < nb_antennas_rx; rxAnt++) {
+    if (ue->prs_vars[gNB_id]->prs_resource[rsc_id].prs_meas[rxAnt] != NULL) {
+      int32_t current_dl_toa = ue->prs_vars[gNB_id]->prs_resource[rsc_id].prs_meas[rxAnt]->dl_toa;
+      // Since dl_toa represents an index within the OFDM symbol, it should be non-negative
+      if (current_dl_toa >= 0 && (max_dl_toa == -1 || current_dl_toa > max_dl_toa)) {
+        max_dl_toa = current_dl_toa;
+      }
+      valid_measurement_found = true;
+    }
+  }
+
+  if (!valid_measurement_found) {
+    LOG_W(PHY, "get_prs_max_dl_toa: No valid PRS measurements found for gNB_id %d, rsc_id %d\n", gNB_id, rsc_id);
+    return -1;
+  }
+
+  // If we still have -1, it means no valid non-negative dl_toa was found
+  if (max_dl_toa == -1) {
+    LOG_W(PHY, "get_prs_max_dl_toa: No valid positive dl_toa measurements found for gNB_id %d, rsc_id %d\n", gNB_id, rsc_id);
+    return -1;
+  }
+
+  return max_dl_toa;
+}
