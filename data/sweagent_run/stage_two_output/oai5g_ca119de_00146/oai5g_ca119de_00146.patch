@@ -213,6 +213,8 @@ void dump_mobile_identity_xml(MobileIdentity *mobileidentity, uint8_t iei)
     printf("    <digit13>%u</digit13>\n", imeisv->digit13);
     printf("    <digit14>%u</digit14>\n", imeisv->digit14);
     printf("    <digit15>%u</digit15>\n", imeisv->digit15);
+    printf("    <digit16>%u</digit16>\n", imeisv->digit16);
+    printf("    <parity>%u</parity>\n", imeisv->parity);
   } else if (mobileidentity->tmsi.typeofidentity == MOBILE_IDENTITY_TMSI) {
     TmsiMobileIdentity_t* tmsi = &mobileidentity->tmsi;
     printf("    <odd even>%u</odd even>\n", tmsi->oddeven);
@@ -381,6 +383,9 @@ static int decode_imeisv_mobile_identity(ImeisvMobileIdentity_t *imeisv, uint8_t
   decoded++;
   imeisv->digit14 = *(buffer + decoded) & 0xf;
   imeisv->digit15 = (*(buffer + decoded) >> 4) & 0xf;
+  decoded++;
+  imeisv->digit16 = *(buffer + decoded) & 0xf;
+  imeisv->parity = (*(buffer + decoded) >> 4) & 0xf;
 
   /*
    * IMEISV is coded using BCD coding. If the number of identity digits is
@@ -391,6 +396,13 @@ static int decode_imeisv_mobile_identity(ImeisvMobileIdentity_t *imeisv, uint8_t
     return (TLV_ENCODE_VALUE_DOESNT_MATCH);
   }
 
+  /*
+   * Validate parity field according to spec
+   */
+  if ((imeisv->parity != EVEN_PARITY) && (imeisv->parity != IMEI_ODD_PARITY)) {
+    return (TLV_ENCODE_VALUE_DOESNT_MATCH);
+  }
+
   decoded++;
   return decoded;
 }
