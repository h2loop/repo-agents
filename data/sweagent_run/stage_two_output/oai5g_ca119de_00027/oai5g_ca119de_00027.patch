diff --git a/common/utils/T/tracer/database.c b/common/utils/T/tracer/database.c
index 347ca7cfcf..de8e22185d 100644
--- a/common/utils/T/tracer/database.c
+++ b/common/utils/T/tracer/database.c
@@ -249,21 +249,22 @@ char *format_get_next_token(char **cur)
   start = *cur;
 
   /* remove spaces */
-  while (*start && isspace(*start)) start ++;
+  while (*start && isspace(*start)) start++;
   if (*start == 0) return NULL;
 
-  /* special cases: ',' and ':' */
-  if (*start == ',' || *start == ':') { end = start + 1; goto special; }
-
-  end = start;
-
-  /* go to end of token */
