+  /* Find the timer entry that corresponds to the expired ITTI timer_id */
+  nas_timer_entry_t *te = _nas_timer_db_find_by_timer_id(timer_id);
+  
+  if (te != NULL) {
+    /* Execute the callback for the specific timer that expired */
+    te->cb(te->args);
+  }
+  /* Note: If the timer entry is not found, it might have been stopped or already processed */
 }
 
 
