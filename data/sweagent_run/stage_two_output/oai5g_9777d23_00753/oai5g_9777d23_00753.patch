   return false;
 }
 
+/****************************************************************************
+ **                                                                        **
+ ** Name:    _nas_timer_db_find_by_timer_id()                          **
+ **                                                                        **
+ ** Description: Finds a timer entry based on its ITTI timer_id            **
+ **                                                                        **
+ ** Inputs:  timer_id:  The ITTI timer identifier                      **
+ **      Others:    _nas_timer_db                              **
+ **                                                                        **
+ ** Outputs:     None                                                      **
+ **      Return:    A pointer to the timer entry if found;     **
+ **             NULL otherwise                             **
+ **      Others:    None                                       **
+ **                                                                        **
+ ***************************************************************************/
+static nas_timer_entry_t *_nas_timer_db_find_by_timer_id(long timer_id)
+{
+  timer_queue_t *current;
+  
+  /* Iterate through the timer queue starting from the head */
+  for (current = _nas_timer_db.head; current != NULL; current = current->next) {
+    if (current->entry != NULL && current->entry->timer_id == timer_id) {
+      return current->entry;
+    }
+  }
+  
+  return NULL;
+}
