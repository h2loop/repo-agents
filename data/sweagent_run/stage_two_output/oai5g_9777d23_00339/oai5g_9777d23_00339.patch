+/*! \file nfapi/open-nFAPI/fapi/src/nr_fapi_p7_utils.c
+ * \brief
+ * \author OpenAirInterface Software Alliance
+ * \date 2024
+ * \version 0.1
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ * \note
+ * \warning
+ */
+
+#include "nr_fapi_p7_utils.h"
+#include <stdlib.h>
+
+void free_uci_indication(nfapi_nr_uci_indication_t *ind)
+{
+  if (ind == NULL) {
+    return;
+  }
+
+  if (ind->uci_list != NULL) {
+    for (int i = 0; i < ind->num_ucis; i++) {
+      switch (ind->uci_list[i].pdu_type) {
+        case NFAPI_NR_UCI_PUSCH_PDU_TYPE:
+          // Handle PUSCH PDU type if needed
+          // Currently no dynamic allocation in PUSCH according to existing code
+          break;
+
+        case NFAPI_NR_UCI_FORMAT_0_1_PDU_TYPE:
+          // Handle PUCCH Format 0/1 PDU type if needed
+          // Currently commented out in existing code, no dynamic allocation handled
+          break;
+
+        case NFAPI_NR_UCI_FORMAT_2_3_4_PDU_TYPE: {
+          // Handle PUCCH Format 2/3/4 PDU type
+          nfapi_nr_uci_pucch_pdu_format_2_3_4_t *pdu = &ind->uci_list[i].pucch_pdu_format_2_3_4;
+          
+          // Free dynamically allocated payloads
+          if (pdu->harq.harq_payload != NULL) {
+            free(pdu->harq.harq_payload);
+            pdu->harq.harq_payload = NULL;
+          }
+          
+          if (pdu->sr.sr_payload != NULL) {
+            free(pdu->sr.sr_payload);
+            pdu->sr.sr_payload = NULL;
+          }
+          
+          if (pdu->csi_part1.csi_part1_payload != NULL) {
+            free(pdu->csi_part1.csi_part1_payload);
+            pdu->csi_part1.csi_part1_payload = NULL;
+          }
+          
+          if (pdu->csi_part2.csi_part2_payload != NULL) {
+            free(pdu->csi_part2.csi_part2_payload);
+            pdu->csi_part2.csi_part2_payload = NULL;
+          }
+          break;
+        }
+        
+        default:
+          // Unknown PDU type, nothing to free
+          break;
+      }
+    }
+    
+    // Free the uci_list array itself
+    free(ind->uci_list);
+    ind->uci_list = NULL;
+  }
+  
+  // Note: We don't free the ind structure itself as it might be stack allocated
+  // The caller is responsible for freeing the ind structure if it was heap allocated
+}
