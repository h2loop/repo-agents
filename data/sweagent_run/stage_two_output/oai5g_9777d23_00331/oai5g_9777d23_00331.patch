diff --git a/openair2/LAYER2/nr_rlc/nr_rlc_pdu.c b/openair2/LAYER2/nr_rlc/nr_rlc_pdu.c
index c5b1eb04e7..c2b6dcd217 100644
--- a/openair2/LAYER2/nr_rlc/nr_rlc_pdu.c
+++ b/openair2/LAYER2/nr_rlc/nr_rlc_pdu.c
@@ -96,6 +96,21 @@ nr_rlc_pdu_t *nr_rlc_pdu_list_add(
 void nr_rlc_pdu_decoder_init(nr_rlc_pdu_decoder_t *decoder,
                              char *buffer, int size)
 {
+  if (decoder == NULL) {
+    LOG_E(RLC, "%s:%d:%s: decoder is NULL\n", __FILE__, __LINE__, __FUNCTION__);
+    exit(1);
+  }
+  
+  if (buffer == NULL) {
+    LOG_E(RLC, "%s:%d:%s: buffer is NULL\n", __FILE__, __LINE__, __FUNCTION__);
+    exit(1);
+  }
+  
+  if (size <= 0) {
+    LOG_E(RLC, "%s:%d:%s: invalid size %d\n", __FILE__, __LINE__, __FUNCTION__, size);
+    exit(1);
+  }
+
   decoder->error = 0;
   decoder->byte = 0;
   decoder->bit = 0;
@@ -149,6 +164,21 @@ int nr_rlc_pdu_decoder_get_bits(nr_rlc_pdu_decoder_t *decoder, int count)
 void nr_rlc_pdu_encoder_init(nr_rlc_pdu_encoder_t *encoder,
                              char *buffer, int size)
 {
+  if (encoder == NULL) {
+    LOG_E(RLC, "%s:%d:%s: encoder is NULL\n", __FILE__, __LINE__, __FUNCTION__);
+    exit(1);
+  }
+  
+  if (buffer == NULL) {
+    LOG_E(RLC, "%s:%d:%s: buffer is NULL\n", __FILE__, __LINE__, __FUNCTION__);
+    exit(1);
+  }
+  
+  if (size <= 0) {
+    LOG_E(RLC, "%s:%d:%s: invalid size %d\n", __FILE__, __LINE__, __FUNCTION__, size);
+    exit(1);
+  }
+
   encoder->byte = 0;
   encoder->bit = 0;
   encoder->buffer = (unsigned char *)buffer;
@@ -162,6 +192,11 @@ static void put_bit(nr_rlc_pdu_encoder_t *encoder, int bit)
     exit(1);
   }
 
+  // Initialize byte to 0 if we're starting to encode in a new byte
+  if (encoder->bit == 0) {
+    encoder->buffer[encoder->byte] = 0;
+  }
+
   encoder->buffer[encoder->byte] <<= 1;
   if (bit)
     encoder->buffer[encoder->byte] |= 1;
