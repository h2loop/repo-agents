+/*------------------------------------------------------------------------------*/
+int set_plmn_config(f1ap_plmn_t *plmn, uint16_t mcc, uint16_t mnc, uint8_t mnc_digit_length) {
+  // Validate inputs
+  if (plmn == NULL) {
+    return -1;
+  }
+  
+  // Validate MCC range (0-999)
+  if (mcc > 999) {
+    return -1;
+  }
+  
+  // Validate MNC range (0-999)
+  if (mnc > 999) {
+    return -1;
+  }
+  
+  // Validate MNC digit length (must be 2 or 3)
+  if (mnc_digit_length != 2 && mnc_digit_length != 3) {
+    return -1;
+  }
+  
+  // Set the PLMN fields
+  plmn->mcc = mcc;
+  plmn->mnc = mnc;
+  plmn->mnc_digit_length = mnc_digit_length;
+  
+  return 0;
+}
