@@ -22,6 +22,7 @@
 #include <stdio.h>
 #include <stdlib.h>
 #include <stdint.h>
+#include <string.h>
 
 
 #include "TLVEncoder.h"
@@ -89,7 +90,24 @@ void dump_lcs_client_identity_xml(LcsClientIdentity *lcsclientidentity, uint8_t
     /* Don't display IEI if = 0 */
     printf("    <IEI>0x%X</IEI>\n", iei);
 
-  printf("%s",dump_octet_string_xml(&lcsclientidentity->lcsclientidentityvalue));
+  // Get the XML output from dump_octet_string_xml
+  char *octet_string_xml = dump_octet_string_xml(&lcsclientidentity->lcsclientidentityvalue);
