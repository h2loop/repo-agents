+#include <atomic>
+#include <cstdint>
+#include <cstdio>
+#include <cstring>
+#include <cstdlib>
+
+// Define the instruction structure
+struct instruction {
+    int32_t moduleId;
+    int32_t dumpId;
+    void* userData;
+};
+
+// Shared atomic instruction variable
+static std::atomic<instruction*> void_instruction{nullptr};
+
+// Function to dump scope data
+bool dumpScopeData(int32_t moduleId, int32_t dumpId, void* userData) {
+    // Create a new instruction for this dump request
+    instruction* newInstruction = (instruction*)malloc(sizeof(instruction));
+    if (!newInstruction) {
+        return false;
+    }
+    
+    newInstruction->moduleId = moduleId;
+    newInstruction->dumpId = dumpId;
+    newInstruction->userData = userData;
+    
+    // Buggy version (before fix):
+    // static instruction void_instruction_expected = {-1, -1, nullptr}; // Shared variable
+    // instruction* expected = &void_instruction_expected; // Reusing the same shared variable
+    // if (void_instruction.compare_exchange_weak(expected, newInstruction)) {
+    //     // On failure, compare_exchange_weak would modify void_instruction_expected
+    //     // which is shared across all calls, causing corruption
+    // }
+    
+    // FIX: Create a fresh expected variable with default values for each compare_exchange_weak call
+    // This prevents corruption of any shared state when compare_exchange_weak fails
+    instruction expected = {-1, -1, nullptr}; // Fresh expected value for each call
+    
+    // Try to atomically exchange the instruction
+    instruction* expected_ptr = &expected;
+    if (void_instruction.compare_exchange_weak(expected_ptr, newInstruction)) {
+        // Successfully exchanged, the new instruction is now in place
+        return true;
+    } else {
+        // Exchange failed, another thread beat us to it or there was already an instruction
+        // In the buggy version, 'expected' would now contain the actual value of void_instruction
+        // but since we're using a fresh 'expected' variable each time, this doesn't affect future calls
+        free(newInstruction);
+        return false;
+    }
+}
+
+// Function to get and clear the current instruction
+instruction* getAndClearInstruction() {
+    instruction* current = void_instruction.exchange(nullptr);
+    return current;
+}
