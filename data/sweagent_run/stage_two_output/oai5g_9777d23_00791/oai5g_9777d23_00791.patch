+/****************************************************************************
+ **                                                                        **
+ ** Name:  _user_api_connection_handler()                            **
+ **                                                                        **
+ ** Description: Procedure executed upon receiving connection status       **
+ **    notification whenever the user API connection is established  **
+ **    or terminated.                                            **
+ **    The connection status data are then displayed to the user.  **
+ **                                                                        **
+ ** Inputs:  id:    Connection status AT command identifier        **
+ **    data:    Generic pointer to the connection status data  **
+ **    size:    Not used                                   **
+ **      Others:  None                                       **
+ **                                                                        **
+ ** Outputs:   None                                                      **
+ **    Return:  The number of bytes actually sent to the   **
+ **       user application                           **
+ **      Others:  None                                       **
+ **                                                                        **
+ ***************************************************************************/
+static int _user_api_connection_handler(user_api_id_t *user_api_id, unsigned char id, const void* data,
+    size_t size)
+{
+  LOG_FUNC_IN;
+
+  /* Get connection status notification data */
+  user_ind_conn_t* conn = (user_ind_conn_t*)data;
+
+  /* Setup AT command unsolicited result response message using CGEV for connection events */
+  at_response_t at_response;
+  at_response.id = AT_CGEV;
+  at_response.type = AT_COMMAND_GET;
+  at_response.mask = AT_RESPONSE_CGEV_MASK;
+  
+  /* Use CGEV response structure to indicate connection status */
+  /* Map connection status to a meaningful CGEV event */
+  if (conn->status == NET_REG_STATE_OFF) {
+    /* Connection closed - use deactivation event with special CID */
+    at_response.response.cgev.cid = 0; /* Special value to indicate connection termination */
+    at_response.response.cgev.code = NET_PDN_NW_DEFAULT_DEACT;
+  } else {
+    /* Connection opened - use activation event */
+    at_response.response.cgev.cid = 0; /* Special value to indicate connection establishment */
+    at_response.response.cgev.code = NET_PDN_MT_DEFAULT_ACT;
+  }
+
+  /* Encode and send the AT command response message to the user */
+  int bytes = _user_api_send(user_api_id, &at_response);
+
+  LOG_FUNC_RETURN (bytes);
+}
+
