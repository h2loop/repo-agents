+
+  // Add back carry outs from top 16 bits to low 16 bits
+  sum = (sum >> 16) + (sum & 0xFFFF);  // Add high-16 to low-16
+  sum += (sum >> 16);                  // Add carry
+  answer = ~sum;                       // Truncate to 16 bits and complement
   return(answer);
 }
 
