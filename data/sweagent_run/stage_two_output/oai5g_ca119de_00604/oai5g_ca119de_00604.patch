+  imeisv->digittac01 = *(buffer + decoded) & 0xf;
+  decoded++;
+
+  imeisv->digittac02 = (*(buffer + decoded) >> 4) & 0xf;
+  imeisv->digittac03 = *(buffer + decoded) & 0xf;
+  decoded++;
