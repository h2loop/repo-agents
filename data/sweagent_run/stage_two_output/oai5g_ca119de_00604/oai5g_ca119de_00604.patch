+  imeisv->digittac06 = (*(buffer + decoded) >> 4) & 0xf;
+  imeisv->digittac07 = *(buffer + decoded) & 0xf;
+  decoded++;
+
+  imeisv->digittac08 = (*(buffer + decoded) >> 4) & 0xf;
+  imeisv->digit09 = *(buffer + decoded) & 0xf;
+  decoded++;
+
+  imeisv->digit10 = (*(buffer + decoded) >> 4) & 0xf;
+  imeisv->digit11 = *(buffer + decoded) & 0xf;
+  decoded++;
+
+  imeisv->digit12 = (*(buffer + decoded) >> 4) & 0xf;
+  imeisv->digit13 = *(buffer + decoded) & 0xf;
+  decoded++;
+
+  imeisv->digit14 = (*(buffer + decoded) >> 4) & 0xf;
+  imeisv->digitsv1 = *(buffer + decoded) & 0xf;
+  decoded++;
+
+  imeisv->digitsv2 = (*(buffer + decoded) >> 4) & 0xf;
+  imeisv->spare = *(buffer + decoded) & 0xf;
+  decoded++;
+
+  return decoded;
+}
