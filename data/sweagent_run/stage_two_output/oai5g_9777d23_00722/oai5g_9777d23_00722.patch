 /*********************************************************
 
+Implementation of crc32_init_lut function
+
+*********************************************************/
+void crc32_init_lut(const uint32_t poly, uint32_t *lut)
+{
+  unsigned char c = 0;
+
+  do {
+    lut[c] = crcbit(&c, 1, poly);
+  } while (++c);
+}
