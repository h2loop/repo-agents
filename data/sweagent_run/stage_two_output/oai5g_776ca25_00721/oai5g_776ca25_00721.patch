diff --git a/openair1/PHY/NR_TRANSPORT/nr_prs.c b/openair1/PHY/NR_TRANSPORT/nr_prs.c
index 382e995a65..c3f84c2122 100644
--- a/openair1/PHY/NR_TRANSPORT/nr_prs.c
+++ b/openair1/PHY/NR_TRANSPORT/nr_prs.c
@@ -43,13 +43,19 @@ int nr_generate_prs(int slot,
     
     // QPSK modulation
     uint32_t *gold = nr_gold_prs(prs_cfg->NPRSID, slot, l);
-    for (int m = 0; m < (12/prs_cfg->CombSize) * prs_cfg->NumRB; m++) {
+    int max_m = (12/prs_cfg->CombSize) * prs_cfg->NumRB;
+    // Ensure we don't exceed the bounds of the gold sequence array
+    // gold array has NR_MAX_PRS_INIT_LENGTH_DWORD = 102 elements
+    // We access gold[m>>4], so maximum valid m is 1631 ((102-1)<<4)
+    if (max_m > 1632) max_m = 1632; // Ensures m never exceeds 1631
+    
+    for (int m = 0; m < max_m; m++) {
       idx = (((gold[(m << 1) >> 5]) >> ((m << 1) & 0x1f)) & 3);
       mod_prs[m<<1] = nr_qpsk_mod_table[idx<<1];
       mod_prs[(m<<1)+1] = nr_qpsk_mod_table[(idx<<1) + 1];
       
 #ifdef DEBUG_PRS_MOD
-      LOG_D("m %d idx %d gold seq %d mod_prs %d %d\n", m, idx, nr_gold_prs[l][(m<<1)>>5], mod_prs[m<<1], mod_prs[(m<<1)+1]);
+      LOG_D("m %d idx %d gold seq %d mod_prs %d %d\n", m, idx, gold[(m<<1)>>5], mod_prs[m<<1], mod_prs[(m<<1)+1]);
 #endif
       
 #ifdef DEBUG_PRS_MAP
