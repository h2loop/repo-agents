+
+  // Handle measurement timers
+  handle_meas_timers(rrc);
 }
 
 int nr_rrc_get_T304(long t304)
@@ -630,3 +633,43 @@ void reset_rlf_timers_and_constants(NR_UE_Timers_Constants_t *tac)
   tac->N310_cnt = 0;
