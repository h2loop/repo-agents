+/** \brief Compute PUSCH transmit power for NR UE
+    @param ue Pointer to UE PHY variables
+    @param proc Pointer to UE processing parameters
+    @param gNB_id Index of connected gNB
+    @param nb_rb Number of resource blocks allocated
+    @param mcs MCS index
+    @param delta_tf Delta TF parameter
+    @param f_pusch Accumulated TPC commands
+    @returns PUSCH transmit power in dBm
+*/
+int16_t get_pusch_power_ue(PHY_VARS_NR_UE *ue,
+                           UE_nr_rxtx_proc_t *proc,
+                           uint8_t gNB_id,
+                           uint16_t nb_rb,
+                           uint8_t mcs,
+                           int8_t delta_tf,
+                           int8_t f_pusch);
+
+/** \brief Check if a slot is configured for uplink in TDD
+    @param ue Pointer to UE PHY variables
+    @param slot_index Slot index to check
+    @returns true if slot is configured for uplink, false otherwise
+*/
+bool is_tdd_slot_configured_for_ul(PHY_VARS_NR_UE *ue, int slot_index);
+
