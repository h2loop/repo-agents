+
+// Extended structure to store both queue message and original function pointer
+typedef struct telnetsrv_qmsg_ext {
+  telnetsrv_qmsg_t qmsg;         // Base queue message
+  cmdfunc_t orig_cmdfunc;        // Original 3-parameter function pointer
+} telnetsrv_qmsg_ext_t;
+
+// Wrapper function to adapt cmdfunc_t signatures to qcmdfunc_t signatures
+static int cmdfunc_wrapper(char *cmdbuff, int debug, telnet_printfunc_t prnt, void *arg) {
+  // arg points to the extended structure
+  telnetsrv_qmsg_ext_t *ext_msg = (telnetsrv_qmsg_ext_t *)arg;
+  // Call the original 3-parameter function
+  if (ext_msg->orig_cmdfunc != NULL) {
+    return ext_msg->orig_cmdfunc(cmdbuff, debug, prnt);
+  }
+  return -1; // Error case
+}
