+
+    // Check if tasks array is initialized
+    if (tasks == NULL) {
+      LOG_E(ITTI, "Tasks array is not initialized\n");
+      return -1;
+    }
+
+    // Check if the specific task is initialized
+    if (tasks[destination_task_id] == NULL) {
