+/** time_manager.c
+ *
+ * \brief Time management for IQ samples
+ * \author: OpenAirInterface Software Alliance
+ */
+
+#include "time_manager.h"
+#include <stdlib.h>
+#include <string.h>
+#include <sys/time.h>
+#include <time.h>
+#include "common/utils/LOG/log.h"
+
+// Static variables for the time manager
+static bool time_manager_initialized = false;
+static struct timespec start_time;
+static openair0_timestamp start_timestamp;
+static time_manager_stats_t stats;
+static double sample_rate = 30.72e6; // Default sample rate for LTE/NR
+
+int time_manager_init(void) {
+  if (time_manager_initialized) {
+    return 0; // Already initialized
+  }
+
+  // Get the current time as the start time
+  if (clock_gettime(CLOCK_MONOTONIC, &start_time) != 0) {
+    LOG_E(HW, "Failed to get current time for time manager\n");
+    return -1;
+  }
+
+  start_timestamp = 0;
+  memset(&stats, 0, sizeof(stats));
+  time_manager_initialized = true;
+  
+  LOG_I(HW, "Time manager initialized\n");
+  return 0;
+}
+
+void time_manager_cleanup(void) {
+  if (!time_manager_initialized) {
+    return;
+  }
+
+  time_manager_initialized = false;
+  LOG_I(HW, "Time manager cleaned up\n");
+}
+
+int time_manager_iq_samples(openair0_timestamp *ptimestamp, int nsamps) {
+  if (!time_manager_initialized) {
+    LOG_E(HW, "Time manager not initialized\n");
+    return -1;
+  }
+
+  if (ptimestamp == NULL || nsamps <= 0) {
+    LOG_E(HW, "Invalid parameters for time_manager_iq_samples\n");
+    return -1;
+  }
+
+  struct timespec current_time;
+  if (clock_gettime(CLOCK_MONOTONIC, &current_time) != 0) {
+    LOG_E(HW, "Failed to get current time\n");
+    return -1;
+  }
+
+  // Calculate expected timestamp based on elapsed time
+  double elapsed_secs = (current_time.tv_sec - start_time.tv_sec) +
+                        (current_time.tv_nsec - start_time.tv_nsec) / 1e9;
+  
+  openair0_timestamp expected_timestamp = start_timestamp + (openair0_timestamp)(elapsed_secs * sample_rate);
+
+  // Compare with requested timestamp
+  openair0_timestamp diff = *ptimestamp - expected_timestamp;
+  
+  if (diff > 0) {
+    // Samples are early, we might need to wait
+    stats.early_samples++;
+    // In a real implementation, we might sleep here
+    // For now, we just log it
+    LOG_D(HW, "IQ samples early by %ld samples\n", diff);
+  } else if (diff < 0) {
+    // Samples are late
+    stats.late_samples++;
+    LOG_D(HW, "IQ samples late by %ld samples\n", -diff);
+  } else {
+    // Samples are on time
+    stats.on_time_samples++;
+    LOG_D(HW, "IQ samples on time\n");
+  }
+
+  stats.total_samples_processed += nsamps;
+  
+  // Adjust our reference timestamp for next call
+  start_timestamp = *ptimestamp;
+  start_time = current_time;
+  
+  return 0;
+}
+
+const time_manager_stats_t* time_manager_get_stats(void) {
+  if (!time_manager_initialized) {
+    return NULL;
+  }
+  
+  return &stats;
+}
