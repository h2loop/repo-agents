+// Helper functions for hex string conversion and buffer comparison
+static uint8_t hex_char_to_int(char c)
+{
+  if (c >= '0' && c <= '9') return c - '0';
+  if (c >= 'A' && c <= 'F') return c - 'A' + 10;
+  if (c >= 'a' && c <= 'f') return c - 'a' + 10;
+  return 0;
+}
+
+static uint8_t* decode_hex_dup(const char* hex_string)
+{
+  size_t len = strlen(hex_string);
+  // Count actual hex characters (excluding spaces)
+  size_t hex_len = 0;
+  for (size_t i = 0; i < len; i++) {
+    if (hex_string[i] != ' ') {
+      hex_len++;
+    }
+  }
+  
+  size_t out_len = hex_len / 2;
+  uint8_t* result = malloc(out_len);
+  
+  size_t hex_index = 0;
+  for (size_t i = 0; i < len && hex_index < hex_len; i++) {
+    if (hex_string[i] != ' ') {
+      if (hex_index % 2 == 0) {
+        result[hex_index / 2] = hex_char_to_int(hex_string[i]) << 4;
+      } else {
+        result[hex_index / 2] |= hex_char_to_int(hex_string[i]);
+      }
+      hex_index++;
+    }
+  }
+  
+  return result;
+}
+
+static uint32_t decode_hex_length(const char* hex_string)
+{
+  return strlen(hex_string) / 2;
+}
+
+static int compare_buffer(uint8_t *buffer, uint32_t length_buffer,
+                          uint8_t *pattern, uint32_t length_pattern)
+{
+  int i;
+
+  if (length_buffer != length_pattern) {
+    printf("Length mismatch, expecting %u bytes, got %u bytes\n", length_pattern,
+           length_buffer);
+    for (i = 0; i < length_buffer; i++) {
+      printf("%02x ", buffer[i]);
+    }
+    printf("\n");
+    return -1;
+  }
+
+  for (i = 0; i < length_buffer; i++) {
+    if (pattern[i] != buffer[i]) {
+      for (int j = 0; j < length_buffer; j++) {
+        printf("%02x ", buffer[j]);
+      }
+      printf("\nMismatch found in byte %d\nExpecting 0x%02x, got 0x%02x\n",
+             i, pattern[i], buffer[i]);
+      return -1;
+    }
+  }
+
+  return 0;
+}
+
+#define H(x)  decode_hex_dup(x)
+#define HL(x) decode_hex_dup(x), decode_hex_length(x)
