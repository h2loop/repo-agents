+// Helper function to create port string from ueid
+char *make_port_str_from_ueid(const char *base_port_str, int ueid) {
+  int port;
+  int base_port;
+  char *endptr = NULL;
+
+  base_port = strtol(base_port_str, &endptr, 10);
+  if ( base_port_str == endptr ) {
+    return NULL;
+  }
+
+  port = base_port + ueid;
+  if ( port<1 || port > 65535 ) {
+    return NULL;
+  }
+
+  // Simple integer to string conversion (itoa is not standard)
+  char *port_str = malloc(10);
+  if (port_str == NULL) {
+    return NULL;
+  }
+  sprintf(port_str, "%d", port);
+  return port_str;
+}
