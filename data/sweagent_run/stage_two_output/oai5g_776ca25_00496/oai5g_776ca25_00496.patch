+    return false;
+  }
+
   AssertFatal(num_rus == 1 || num_rus == 2, "only support 1 or 2 RUs as of now\n");
   AssertFatal(ru_idx < num_rus, "illegal ru_idx %d: must be < %d\n", ru_idx, num_rus);
   DevAssert(oai0->tx_num_channels > 0 && oai0->rx_num_channels > 0);
