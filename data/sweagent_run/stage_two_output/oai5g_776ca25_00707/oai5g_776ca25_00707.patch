@@ -121,17 +121,52 @@ extern "C"
     uint32_t tx_byte_count;
 
     mac_private *mac;
+    
+    volatile int stop_thread;
+    pthread_t mac_rx_thread;
 
   } mac_internal_t;
 
   mac_t *mac_create(uint8_t wireshark_test_mode) {
     mac_internal_t *instance = (mac_internal_t *)malloc(sizeof(mac_internal_t));
+    if (instance == NULL) {
+      return NULL;
+    }
+    
+    memset(instance, 0, sizeof(mac_internal_t));
     instance->mac = new mac_private((wireshark_test_mode >= 1));
+    instance->stop_thread = 0;
+    instance->rx_sock = -1;
+    instance->tx_sock = -1;
     return (mac_t *)instance;
   }
 
   void mac_destroy(mac_t *mac) {
+    if (mac == NULL) {
+      return;
+    }
+    
     mac_internal_t *instance = (mac_internal_t *)mac;
+    
+    // Signal the rx thread to stop
+    instance->stop_thread = 1;
+    
+    // Close the rx socket to unblock the recvfrom call
+    if (instance->rx_sock >= 0) {
+      close(instance->rx_sock);
+    }
+    
+    // Wait for the rx thread to finish
+    if (instance->mac_rx_thread != 0) {  // Check if thread was actually created
+      pthread_join(instance->mac_rx_thread, NULL);
+    }
+    
+    // Close the tx socket
+    if (instance->tx_sock >= 0) {
+      close(instance->tx_sock);
+    }
+    
+    // Clean up the mac private data
     delete instance->mac;
     free(instance);
   }
