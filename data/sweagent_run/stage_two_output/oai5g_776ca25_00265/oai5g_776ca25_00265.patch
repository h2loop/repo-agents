+/*! \file f1ap_positioning.c
+ * \brief F1AP positioning procedures for both CU and DU
+ * \author OpenAirInterface Software Alliance
+ * \date 2023
+ * \version 0.1
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ */
+
+#include "f1ap_positioning.h"
+#include "f1ap_common.h"
+#include "f1ap_encoder.h"
+
+static inline
+int f1ap_generate_unsuccessful_outcome(
+    uint8_t **buffer,
+    uint32_t *length,
+    F1ap_ProcedureCode_t procedureCode,
+    F1ap_Criticality_t criticality,
+    asn_TYPE_descriptor_t *type,
+    void *sptr)
+{
+    F1AP_F1AP_PDU_t  pdu;
+    F1AP_UnsuccessfulOutcome_t init;
+    int ret;
+
+    memset(&pdu, 0, sizeof(pdu));
+    pdu.present = F1AP_F1AP_PDU_PR_unsuccessfulOutcome;
+    pdu.choice.unsuccessfulOutcome = &init;
+    init.procedureCode = procedureCode;
+    init.criticality = criticality;
+    ANY_fromType_APER(&init.value, type, sptr);
+
+    if (asn1_xer_print) {
+        xer_fprint(stdout, &asn_DEF_F1AP_F1AP_PDU, &pdu);
+    }
+
+    ret = f1ap_encode_pdu(&pdu, buffer, length);
+    
+    ASN_STRUCT_FREE_CONTENTS_ONLY(asn_DEF_F1AP_F1AP_PDU, &pdu);
+
+    return ret;
+}
+
+int encode_positioning_measurement_failure(
+    F1ap_PositioningMeasurementFailureIEs_t *positioningMeasurementFailureIEs,
+    uint8_t **buffer,
+    uint32_t *length)
+{
+    F1ap_PositioningMeasurementFailure_t positioning_measurement_failure;
+    F1ap_PositioningMeasurementFailure_t *positioning_measurement_failure_p = &positioning_measurement_failure;
+
+    DevAssert(positioningMeasurementFailureIEs != NULL);
+    DevAssert(buffer != NULL);
+    DevAssert(length != NULL);
+
+    memset((void *)positioning_measurement_failure_p, 0, sizeof(F1ap_PositioningMeasurementFailure_t));
+
+    if (f1ap_encode_f1ap_positioningmeasurementfailureies(
+            positioning_measurement_failure_p, positioningMeasurementFailureIEs) < 0) {
+        F1AP_ERROR("Failed to encode PositioningMeasurementFailureIEs\n");
+        return -1;
+    }
+
+    return f1ap_generate_unsuccessful_outcome(buffer,
+                                              length,
+                                              F1ap_ProcedureCode_id_PositioningMeasurementExchange,
+                                              F1ap_Criticality_reject,
+                                              &asn_DEF_F1AP_PositioningMeasurementFailure,
+                                              positioning_measurement_failure_p);
+}
