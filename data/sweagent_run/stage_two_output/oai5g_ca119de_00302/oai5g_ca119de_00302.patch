+void ue_context_modification_refuse(const f1ap_ue_context_modif_fail_t *fail)
+{
+  /* Handle UE context modification failure */
+  gNB_MAC_INST *mac = RC.nrmac[0];
+  
+  LOG_E(NR_MAC, "UE context modification failed for RNTI %04x, cause: %d, cause_value: %ld\n", 
+        fail->rnti, fail->cause, fail->cause_value);
+  
+  NR_SCHED_LOCK(&mac->sched_lock);
+  NR_UE_info_t *UE = find_nr_UE(&mac->UE_info, fail->rnti);
+  
+  if (UE != NULL) {
+    /* Mark the UE context modification as failed */
+    /* In a real implementation, we might want to rollback any partial changes */
+    /* For now, we just log the failure and notify upper layers if needed */
+    
+    /* TODO: Implement proper rollback mechanism if needed */
+    LOG_W(NR_MAC, "UE context modification rollback not implemented\n");
+  } else {
+    LOG_W(NR_MAC, "UE with RNTI %04x not found for context modification failure\n", fail->rnti);
+  }
+  
+  NR_SCHED_UNLOCK(&mac->sched_lock);
+  
+  /* Free any allocated RRC container */
+  if (fail->rrc_container)
+    free(fail->rrc_container);
+}
