+    f1ap_msg->rrc_container_length = fail->rrc_container_length;
+    memcpy(f1ap_msg->rrc_container, fail->rrc_container, fail->rrc_container_length);
+  }
+  itti_send_msg_to_task(TASK_CU_F1, 0, msg);
