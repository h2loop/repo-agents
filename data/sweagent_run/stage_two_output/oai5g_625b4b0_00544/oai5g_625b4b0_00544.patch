   m2ap_eNB_instance_t    *inst;
   struct m2ap_eNB_data_s *elm;
 
+  /* Validate PCI range - PCI values should be in range 0-503 according to 3GPP specs */
+  if (pci > 503) {
+    M2AP_WARN("[m2ap] Invalid PCI value %u, should be in range 0-503\n", pci);
+    return NULL;
+  }
+
+  M2AP_DEBUG("[m2ap] Searching for eNB with PCI %u\n", pci);
+
   STAILQ_FOREACH(inst, &m2ap_eNB_internal_data.m2ap_eNB_instances_head, m2ap_eNB_entries) {
     RB_FOREACH(elm, m2ap_enb_map, &inst->m2ap_enb_head) {
-      for (int i = 0; i<elm->num_cc; i++) {
+      /* Validate num_cc bounds before iterating */
+      if (elm->num_cc < 0 || elm->num_cc > MAX_NUM_CCs) {
+        M2AP_WARN("[m2ap] Invalid num_cc value %d for eNB (should be 0-%d)\n", elm->num_cc, MAX_NUM_CCs);
+        continue;
+      }
+      
+      M2AP_DEBUG("[m2ap] Checking eNB %s with %d component carriers\n", 
+                 elm->eNB_name ? elm->eNB_name : "Unknown", elm->num_cc);
+                 
+      for (int i = 0; i < elm->num_cc; i++) {
+        /* Additional bounds check for array access */
+        if (i >= MAX_NUM_CCs) {
+          M2AP_WARN("[m2ap] Array index %d exceeds MAX_NUM_CCs %d\n", i, MAX_NUM_CCs);
+          break;
+        }
+        
+        M2AP_DEBUG("[m2ap] Comparing PCI %u with Nid_cell[%d] = %u\n", pci, i, elm->Nid_cell[i]);
+        
+        /* Note: Nid_cell values might need interpretation depending on context
+         * In some implementations, Nid_cell might represent different values
+         * Check if this needs adjustment based on actual usage */
         if (elm->Nid_cell[i] == pci) {
+          M2AP_DEBUG("[m2ap] Found matching eNB for PCI %u\n", pci);
           return elm;
         }
       }
     }
   }
+  
+  M2AP_DEBUG("[m2ap] No eNB found with PCI %u\n", pci);
   return NULL;
 }
 
