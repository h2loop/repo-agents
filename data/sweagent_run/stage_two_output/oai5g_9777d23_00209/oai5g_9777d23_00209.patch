+#include <stdio.h>
+#include <stdlib.h>
+#include <assert.h>
+#include "common/utils/assertions.h"
+#include "f1ap_positioning.h"
+
+void free_positioning_information_resp(const f1ap_positioning_information_response_t *msg)
+{
+  DevAssert(msg != NULL);
+  
+  // Free SRS Configuration data if present
+  if (msg->srs_configuration_data != NULL) {
+    free(msg->srs_configuration_data);
+  }
+  
+  // Free SFN Initialisation Time data if present
+  if (msg->sfn_initialisation_time_data != NULL) {
+    free(msg->sfn_initialisation_time_data);
+  }
+  
+  // Note: criticality_diagnostics is a simple uint16_t field, no need to free it
+}
