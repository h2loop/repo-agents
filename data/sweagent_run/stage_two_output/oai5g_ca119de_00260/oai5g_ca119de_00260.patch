diff --git a/common/utils/ocp_itti/intertask_interface.cpp b/common/utils/ocp_itti/intertask_interface.cpp
index b0d05c6aca..614bac3c7a 100644
--- a/common/utils/ocp_itti/intertask_interface.cpp
+++ b/common/utils/ocp_itti/intertask_interface.cpp
@@ -433,6 +433,17 @@ extern "C" {
 
   // void for compatibility
   void itti_send_terminate_message(task_id_t task_id) {
+    // Broadcast TERMINATE_MESSAGE to all registered tasks except the calling task
+    for (int i = 0; i < nb_queues; i++) {
+      if (tasks[i] != NULL && i != (int)task_id) {
+        MessageDef *terminate_message = itti_alloc_new_message(task_id, 0, TERMINATE_MESSAGE);
+        if (terminate_message != NULL) {
+          itti_send_msg_to_task((task_id_t)i, 0, terminate_message);
+        } else {
+          LOG_E(ITTI, "Failed to allocate TERMINATE_MESSAGE for task %d\n", i);
+        }
+      }
+    }
   }
 
   sem_t itti_sem_block;
