+      }
       break;
     }
   }
@@ -249,7 +254,10 @@ int load_module_version_shlib(char *modname, char *version, loader_shlibfunc_t *
 load_module_shlib_exit:
   if (shlib_path) free(shlib_path);
   if (afname)     free(afname);
-  if (lib_handle) dlclose(lib_handle);
+  // Don't close the library handle as we need to keep the function pointers valid
