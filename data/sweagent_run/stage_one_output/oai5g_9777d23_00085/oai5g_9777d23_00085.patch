@@ -142,6 +142,11 @@ int load_module_version_shlib(char *modname, char *version, loader_shlibfunc_t *
       printf("[LOADER] library %s has been loaded previously, reloading function pointers\n",
              shlib_path);
       lib_idx = i;
+      // Close the previous library handle if it exists
+      if (loader_data.shlibs[lib_idx].lib_handle) {
+        dlclose(loader_data.shlibs[lib_idx].lib_handle);
