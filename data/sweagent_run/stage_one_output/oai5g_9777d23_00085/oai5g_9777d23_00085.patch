 }
 
@@ -267,10 +275,45 @@ void * get_shlibmodule_fptr(char *modname, char *fname)
     return NULL;
 }
 
+void loader_cleanup(void)
+{
+    for (int i = 0; i < loader_data.numshlibs; i++) {
+        if (loader_data.shlibs[i].lib_handle) {
+            dlclose(loader_data.shlibs[i].lib_handle);
+            loader_data.shlibs[i].lib_handle = NULL;
+        }
+        // Free other allocated memory
+        if (loader_data.shlibs[i].name) {
+            free(loader_data.shlibs[i].name);
+            loader_data.shlibs[i].name = NULL;
+        }
+        if (loader_data.shlibs[i].thisshlib_path) {
+            free(loader_data.shlibs[i].thisshlib_path);
+            loader_data.shlibs[i].thisshlib_path = NULL;
+        }
+        if (loader_data.shlibs[i].funcarray) {
+            for (int j = 0; j < loader_data.shlibs[i].numfunc; j++) {
+                if (loader_data.shlibs[i].funcarray[j].fname) {
+                    free(loader_data.shlibs[i].funcarray[j].fname);
+                }
+            }
+            free(loader_data.shlibs[i].funcarray);
+            loader_data.shlibs[i].funcarray = NULL;
+        }
+    }
+    loader_data.numshlibs = 0;
+    loader_data.shlibs = NULL;
+}
+
 void loader_reset()
 {
   for (int i = 0; i < loader_data.numshlibs && loader_data.shlibs[i].name != NULL; i++) {
     loader_shlibdesc_t *shlib = &loader_data.shlibs[i];
+    // Close the library handle if it exists
+    if (shlib->lib_handle) {
+      dlclose(shlib->lib_handle);
+      shlib->lib_handle = NULL;
+    }
     free(shlib->name);
     free(shlib->thisshlib_path);
     for (int j = 0; j < shlib->numfunc; ++j)
@@ -284,4 +327,5 @@ void loader_reset()
     loader_data.shlibpath=NULL;
   }
   free(loader_data.shlibs);
+  loader_data.shlibs = NULL;
 }
