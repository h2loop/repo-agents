--- a/openair2/F1AP/lib/f1ap_lib_common.c
+++ b/openair2/F1AP/lib/f1ap_lib_common.c
@@ -26,6 +26,15 @@
 #include "common/utils/utils.h"
 #include "common/utils/assertions.h"
 #include "common/utils/utils.h"
+#include "common/5g_platform_types.h"
+
+/* Forward struct declarations */
+struct f1ap_up_tnl_t;
+struct nssai_s;
+struct f1ap_qos_flow_level_qos_parameters_t;
+struct f1ap_flows_mapped_to_drb_t;
+struct f1ap_drb_information_t;
+struct f1ap_drb_to_be_setup_t;
 
 bool eq_f1ap_plmn(const f1ap_plmn_t *a, const f1ap_plmn_t *b)
 {
@@ -92,6 +101,137 @@ bool eq_f1ap_sys_info(const f1ap_gnb_du_system_info_t *a, const f1ap_gnb_du_syst
   return true;
 }
 
+bool eq_f1ap_up_tnl(const f1ap_up_tnl_t *a, const f1ap_up_tnl_t *b)
+{
+  if (a == NULL && b == NULL)
+    return true;
+  if (a == NULL || b == NULL)
+    return false;
+    
+  _F1_EQ_CHECK_LONG(a->tl_address, b->tl_address);
+  _F1_EQ_CHECK_LONG(a->teid, b->teid);
+  _F1_EQ_CHECK_INT(a->port, b->port);
+  return true;
+}
+
+bool eq_f1ap_nssai(const nssai_t *a, const nssai_t *b)
+{
+  if (a == NULL && b == NULL)
+    return true;
+  if (a == NULL || b == NULL)
+    return false;
+    
+  _F1_EQ_CHECK_INT(a->sst, b->sst);
+  _F1_EQ_CHECK_LONG(a->sd, b->sd);
+  return true;
+}
+
+bool eq_f1ap_qos_flow_level_qos_parameters(const f1ap_qos_flow_level_qos_parameters_t *a, const f1ap_qos_flow_level_qos_parameters_t *b)
+{
+  if (a == NULL && b == NULL)
+    return true;
+  if (a == NULL || b == NULL)
+    return false;
+    
+  _F1_EQ_CHECK_INT(a->alloc_reten_priority.priority_level, b->alloc_reten_priority.priority_level);
+  _F1_EQ_CHECK_INT(a->alloc_reten_priority.preemption_capability, b->alloc_reten_priority.preemption_capability);
+  _F1_EQ_CHECK_INT(a->alloc_reten_priority.preemption_vulnerability, b->alloc_reten_priority.preemption_vulnerability);
+  
+  _F1_EQ_CHECK_INT(a->qos_characteristics.qos_type, b->qos_characteristics.qos_type);
+  
+  if (a->qos_characteristics.qos_type == NON_DYNAMIC) {
+    _F1_EQ_CHECK_LONG(a->qos_characteristics.non_dynamic.fiveqi, b->qos_characteristics.non_dynamic.fiveqi);
+    _F1_EQ_CHECK_LONG(a->qos_characteristics.non_dynamic.qos_priority_level, b->qos_characteristics.non_dynamic.qos_priority_level);
+  } else {
+    _F1_EQ_CHECK_LONG(a->qos_characteristics.dynamic.fiveqi, b->qos_characteristics.dynamic.fiveqi);
+    _F1_EQ_CHECK_LONG(a->qos_characteristics.dynamic.qos_priority_level, b->qos_characteristics.dynamic.qos_priority_level);
+    _F1_EQ_CHECK_LONG(a->qos_characteristics.dynamic.packet_delay_budget, b->qos_characteristics.dynamic.packet_delay_budget);
+    _F1_EQ_CHECK_LONG(a->qos_characteristics.dynamic.packet_error_rate.per_scalar, b->qos_characteristics.dynamic.packet_error_rate.per_scalar);
+    _F1_EQ_CHECK_LONG(a->qos_characteristics.dynamic.packet_error_rate.per_exponent, b->qos_characteristics.dynamic.packet_error_rate.per_exponent);
+  }
+  
+  return true;
+}
+
+bool eq_f1ap_flows_mapped_to_drb(const f1ap_flows_mapped_to_drb_t *a, const f1ap_flows_mapped_to_drb_t *b)
+{
+  if (a == NULL && b == NULL)
+    return true;
+  if (a == NULL || b == NULL)
+    return false;
+    
+  _F1_EQ_CHECK_LONG(a->qfi, b->qfi);
+  if (!eq_f1ap_qos_flow_level_qos_parameters(&a->qos_params, &b->qos_params))
+    return false;
+  return true;
+}
+
+bool eq_f1ap_drb_information(const f1ap_drb_information_t *a, const f1ap_drb_information_t *b)
+{
+  if (a == NULL && b == NULL)
+    return true;
+  if (a == NULL || b == NULL)
+    return false;
+    
+  if (!eq_f1ap_qos_flow_level_qos_parameters(&a->drb_qos, &b->drb_qos))
+    return false;
+  
+  _F1_EQ_CHECK_INT(a->flows_to_be_setup_length, b->flows_to_be_setup_length);
+  
+  // If both are NULL or both have zero length, they're equal
+  if ((a->flows_mapped_to_drb == NULL || a->flows_to_be_setup_length == 0) && 
+      (b->flows_mapped_to_drb == NULL || b->flows_to_be_setup_length == 0))
+    return true;
+    
+  // If only one is NULL or has zero length, they're not equal
+  if ((a->flows_mapped_to_drb == NULL || a->flows_to_be_setup_length == 0) || 
+      (b->flows_mapped_to_drb == NULL || b->flows_to_be_setup_length == 0))
+    return false;
+  
+  for (int i = 0; i < a->flows_to_be_setup_length; i++) {
+    if (!eq_f1ap_flows_mapped_to_drb(&a->flows_mapped_to_drb[i], &b->flows_mapped_to_drb[i]))
+      return false;
+  }
+  return true;
+}
+
+bool eq_f1ap_drb_to_be_setup(const f1ap_drb_to_be_setup_t *a, const f1ap_drb_to_be_setup_t *b)
+{
+  if (a == NULL && b == NULL)
+    return true;
+  if (a == NULL || b == NULL)
+    return false;
+    
+  _F1_EQ_CHECK_LONG(a->drb_id, b->drb_id);
+  _F1_EQ_CHECK_INT(a->up_ul_tnl_length, b->up_ul_tnl_length);
+  _F1_EQ_CHECK_INT(a->up_dl_tnl_length, b->up_dl_tnl_length);
+  
+  for (int i = 0; i < a->up_ul_tnl_length; i++) {
+    if (!eq_f1ap_up_tnl(&a->up_ul_tnl[i], &b->up_ul_tnl[i]))
+      return false;
+  }
+  
+  for (int i = 0; i < a->up_dl_tnl_length; i++) {
+    if (!eq_f1ap_up_tnl(&a->up_dl_tnl[i], &b->up_dl_tnl[i]))
+      return false;
+  }
+  
+  if (!eq_f1ap_drb_information(&a->drb_info, &b->drb_info))
+    return false;
+  
+  _F1_EQ_CHECK_INT(a->rlc_mode, b->rlc_mode);
+  
+  if (!eq_f1ap_nssai(&a->nssai, &b->nssai))
+    return false;
+    
+  return true;
+}
+
+bool eq_drb_to_setup(const f1ap_drb_to_be_setup_t *a, const f1ap_drb_to_be_setup_t *b)
+{
+  return eq_f1ap_drb_to_be_setup(a, b);
+}
