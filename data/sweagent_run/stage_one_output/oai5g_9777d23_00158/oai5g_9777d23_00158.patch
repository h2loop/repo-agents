+/* Compare two UE contexts for reset operations
+ * Returns 1 if the UEs are the same, 0 otherwise
+ */
+int eq_f1ap_ue_to_reset(const f1ap_ue_context_setup_t *ue1, const f1ap_ue_context_setup_t *ue2)
+{
+  if (ue1 == NULL || ue2 == NULL) {
+    return 0;
+  }
+  
+  /* Compare both CU and DU UE IDs to determine if UEs are the same */
+  return (ue1->gNB_CU_ue_id == ue2->gNB_CU_ue_id) && 
+         (ue1->gNB_DU_ue_id == ue2->gNB_DU_ue_id);
+}
