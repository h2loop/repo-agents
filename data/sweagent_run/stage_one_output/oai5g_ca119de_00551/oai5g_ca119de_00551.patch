+/*! \file f1ap_positioning.c
+ * \brief F1AP positioning procedures for both CU and DU
+ * \author OpenAirInterface Software Alliance
+ * \date 2022
+ * \version 0.1
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ */
+
+#include <pthread.h>
+#include "f1ap_positioning.h"
+#include "F1AP_TRPInformationTypeResponseItem.h"
+
+// Mutex for protecting shared TRP information data
+static pthread_mutex_t trp_info_mutex = PTHREAD_MUTEX_INITIALIZER;
+
+// Global shared data that needs protection
+static uint32_t trp_response_counter = 0;
+
+int eq_trp_info_type_response_item(F1AP_TRPInformationTypeResponseItem_t *item1,
+                                   F1AP_TRPInformationTypeResponseItem_t *item2)
+{
+  // Lock the mutex before accessing shared data
+  pthread_mutex_lock(&trp_info_mutex);
+  
+  // Increment counter to track function calls (shared data access)
+  trp_response_counter++;
+  
+  // Perform the actual comparison
+  int result = 0;
+  
+  // Check if both items are NULL
+  if (item1 == NULL && item2 == NULL) {
+    result = 1;  // Both NULL, considered equal
+  } else if (item1 == NULL || item2 == NULL) {
+    result = 0;  // One NULL, one not, not equal
+  } else {
+    // Both items are non-NULL, compare their content
+    // This is a simplified comparison - in reality, this would depend on the 
+    // specific structure of TRPInformationTypeResponseItem
+    result = (item1->present == item2->present);
+    
+    if (result && item1->present != F1AP_TRPInformationTypeResponseItem_PR_NOTHING) {
+      // Add more detailed comparison based on the present value
+      // This would be implementation-specific
+      switch (item1->present) {
+        case F1AP_TRPInformationTypeResponseItem_PR_pCI_NR:
+          result = (item1->choice.pCI_NR == item2->choice.pCI_NR);
+          break;
+        case F1AP_TRPInformationTypeResponseItem_PR_nG_RAN_CGI:
+          // For complex structures, we would need to compare each field
+          // This is a simplified check
+          result = 1;  // Placeholder
+          break;
+        case F1AP_TRPInformationTypeResponseItem_PR_nRARFCN:
+          result = (item1->choice.nRARFCN == item2->choice.nRARFCN);
+          break;
+        default:
+          result = 1;  // Default case
+          break;
+      }
+    }
+  }
+  
+  // Unlock the mutex after accessing shared data
+  pthread_mutex_unlock(&trp_info_mutex);
+  
+  return result;
+}
+
+// Additional functions that might be downstream of eq_trp_info_type_response_item
+// and could also have race conditions
+
+int process_trp_info_response_list(F1AP_TRPInformationTypeResponseList_t *list)
+{
+  pthread_mutex_lock(&trp_info_mutex);
+  
+  int result = 0;
+  trp_response_counter += list->list.count;
+  
+  // Process the list - this is where race conditions could occur
+  // if multiple threads access the same list simultaneously
+  for (int i = 0; i < list->list.count; i++) {
+    F1AP_TRPInformationTypeResponseItem_t *item = list->list.array[i];
+    if (item != NULL) {
+      // Process each item
+      result += 1;  // Simplified processing
+    }
+  }
+  
+  pthread_mutex_unlock(&trp_info_mutex);
+  return result;
+}
+
+uint32_t get_trp_response_count(void)
+{
+  pthread_mutex_lock(&trp_info_mutex);
+  uint32_t count = trp_response_counter;
+  pthread_mutex_unlock(&trp_info_mutex);
+  return count;
+}
+
+void reset_trp_response_count(void)
+{
+  pthread_mutex_lock(&trp_info_mutex);
+  trp_response_counter = 0;
+  pthread_mutex_unlock(&trp_info_mutex);
+}
