diff --git a/openair2/E1AP/lib/e1ap_bearer_context_management.c b/openair2/E1AP/lib/e1ap_bearer_context_management.c
index f2593f103c..75c201e910 100644
--- a/openair2/E1AP/lib/e1ap_bearer_context_management.c
+++ b/openair2/E1AP/lib/e1ap_bearer_context_management.c
@@ -1911,11 +1911,40 @@ bool decode_E1_bearer_context_mod_request(const E1AP_E1AP_PDU_t *pdu, e1ap_beare
 static DRB_nGRAN_to_mod_t cp_drb_to_mod_item(const DRB_nGRAN_to_mod_t *msg)
 {
   DRB_nGRAN_to_mod_t cp = {0};
+  
+  if (msg == NULL) {
+    PRINT_ERROR("NULL pointer passed to cp_drb_to_mod_item\n");
+    return cp;
+  }
+  
   // shallow copy
   cp = *msg;
   _E1_CP_OPTIONAL_IE(&cp, msg, sdap_config);
   _E1_CP_OPTIONAL_IE(&cp, msg, pdcp_config);
   _E1_CP_OPTIONAL_IE(&cp, msg, pdcp_status);
+  
+  // Copy DL UP Parameters List
+  cp.numDlUpParam = msg->numDlUpParam;
+  if (cp.numDlUpParam < 0 || cp.numDlUpParam > E1AP_MAX_NUM_UP_PARAM) {
+    PRINT_ERROR("Invalid numDlUpParam: %d (max: %d)\n", cp.numDlUpParam, E1AP_MAX_NUM_UP_PARAM);
+    cp.numDlUpParam = 0;
+  } else {
+    for (int k = 0; k < msg->numDlUpParam; k++) {
+      cp.DlUpParamList[k] = msg->DlUpParamList[k];
+    }
+  }
+  
+  // Copy QoS Flows Information To Modify
+  cp.numQosFlow2Setup = msg->numQosFlow2Setup;
+  if (cp.numQosFlow2Setup < 0 || cp.numQosFlow2Setup > E1AP_MAX_NUM_QOS_FLOWS) {
+    PRINT_ERROR("Invalid numQosFlow2Setup: %d (max: %d)\n", cp.numQosFlow2Setup, E1AP_MAX_NUM_QOS_FLOWS);
+    cp.numQosFlow2Setup = 0;
+  } else {
+    for (int k = 0; k < msg->numQosFlow2Setup; k++) {
+      cp.qosFlows[k] = msg->qosFlows[k];
+    }
+  }
+  
   return cp;
 }
 
