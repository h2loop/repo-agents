diff --git a/openair2/SDAP/nr_sdap/nr_sdap.c b/openair2/SDAP/nr_sdap/nr_sdap.c
index f6602c7597..8eb5184b7a 100644
--- a/openair2/SDAP/nr_sdap/nr_sdap.c
