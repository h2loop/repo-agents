+
+/**
+ * Cleanup function to close file descriptors associated with the thread pool
+ * This should be called when the thread pool is no longer needed
+ */
+static inline void cleanupTpool(tpool_t *t) {
+  /* Close file descriptors if they were opened */
+  if (t->traceFd > 0) {
+    close(t->traceFd);
+    t->traceFd = -1;
+  }
+  if (t->dummyKeepReadingTraceFd > 0) {
+    close(t->dummyKeepReadingTraceFd);
+    t->dummyKeepReadingTraceFd = -1;
+  }
+}
