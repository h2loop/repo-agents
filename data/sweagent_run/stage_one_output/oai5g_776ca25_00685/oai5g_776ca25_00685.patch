+void wls_mac_print_stats(void)
+{
+  PWLS_MAC_CTX pWls = wls_mac_get_ctx();
+
+  NFAPI_TRACE(NFAPI_TRACE_DEBUG, "wls_mac_free_list_all:\n");
+  NFAPI_TRACE(NFAPI_TRACE_DEBUG,
+              "        nTotalBlocks[%" PRIu32 "] nAllocBlocks[%" PRIu32 "] nFreeBlocks[%" PRIu32 "]\n",
+              pWls->nTotalBlocks,
+              pWls->nAllocBlocks,
+              (pWls->nTotalBlocks >= pWls->nAllocBlocks) ? 
+                (pWls->nTotalBlocks - pWls->nAllocBlocks) : 0);
+  NFAPI_TRACE(NFAPI_TRACE_DEBUG,
+              "        nTotalAllocCnt[%" PRIu32 "] nTotalFreeCnt[%" PRIu32 "] Diff[%" PRIu32 "]\n",
+              pWls->nTotalAllocCnt,
+              pWls->nTotalFreeCnt,
+              (pWls->nTotalAllocCnt >= pWls->nTotalFreeCnt) ? 
+                (pWls->nTotalAllocCnt - pWls->nTotalFreeCnt) : 0);
+  NFAPI_TRACE(NFAPI_TRACE_DEBUG,
+              "        nDlBufAllocCnt[%" PRIu32 "] nDlBufFreeCnt[%" PRIu32 "] Diff[%" PRIu32 "]\n",
+              pWls->nTotalDlBufAllocCnt,
+              pWls->nTotalDlBufFreeCnt,
+              (pWls->nTotalDlBufAllocCnt >= pWls->nTotalDlBufFreeCnt) ? 
+                (pWls->nTotalDlBufAllocCnt - pWls->nTotalDlBufFreeCnt) : 0);
+  NFAPI_TRACE(NFAPI_TRACE_DEBUG,
+              "        nUlBufAllocCnt[%" PRIu32 "] nUlBufFreeCnt[%" PRIu32 "] Diff[%" PRIu32 "]\n\n",
+              pWls->nTotalUlBufAllocCnt,
+              pWls->nTotalUlBufFreeCnt,
+              (pWls->nTotalUlBufAllocCnt >= pWls->nTotalUlBufFreeCnt) ? 
+                (pWls->nTotalUlBufAllocCnt - pWls->nTotalUlBufFreeCnt) : 0);
+}
