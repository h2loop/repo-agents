+/*! \file nfapi/open-nFAPI/fapi/src/nr_fapi_p7_utils.c
+ * \brief
+ * \author OpenAirInterface Software Alliance
+ * \date 2024
+ * \version 0.1
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ * \note
+ * \warning
+ */
+
+#include "nr_fapi_p7_utils.h"
+#include <stdlib.h>
+
+void free_uci_indication(nfapi_nr_uci_indication_t *msg)
+{
+  if (msg == NULL) {
+    return;
+  }
+
+  // Free the memory allocated for each UCI in the list
+  if (msg->uci_list != NULL) {
+    for (int i = 0; i < msg->num_ucis; i++) {
+      switch (msg->uci_list[i].pdu_type) {
+        case NFAPI_NR_UCI_PUSCH_PDU_TYPE:
+          // For PUSCH PDU, check and free any allocated payloads
+          // Based on the structure, there don't seem to be dynamically allocated fields
+          break;
+
+        case NFAPI_NR_UCI_FORMAT_0_1_PDU_TYPE: {
+          // For PUCCH Format 0/1 PDU, check and free any allocated payloads
+          // Based on the structure definition, these are direct structures, not pointers
+          // However, some implementations might allocate memory for these fields as pointers
+          nfapi_nr_uci_pucch_pdu_format_0_1_t *pucch_pdu_0_1 = &msg->uci_list[i].pucch_pdu_format_0_1;
+          
+          // Check if sr field is a pointer (some implementations might do this)
+          // This is defensive programming - in the standard structure it's not a pointer
+          // Uncomment the following lines if your implementation allocates sr as a pointer
+          /*
+          if (pucch_pdu_0_1->sr != NULL) {
+            free(pucch_pdu_0_1->sr);
+            pucch_pdu_0_1->sr = NULL;
+          }
+          */
+          
+          // Check if harq field is a pointer (some implementations might do this)
+          // This is defensive programming - in the standard structure it's not a pointer
+          // Uncomment the following lines if your implementation allocates harq as a pointer
+          /*
+          if (pucch_pdu_0_1->harq != NULL) {
+            // If harq->harq_list is also allocated dynamically
+            if (pucch_pdu_0_1->harq->harq_list != NULL) {
+              free(pucch_pdu_0_1->harq->harq_list);
+              pucch_pdu_0_1->harq->harq_list = NULL;
+            }
+            free(pucch_pdu_0_1->harq);
+            pucch_pdu_0_1->harq = NULL;
+          }
+          */
+          break;
+        }
+
+        case NFAPI_NR_UCI_FORMAT_2_3_4_PDU_TYPE: {
+          // For PUCCH Format 2/3/4 PDU, free the dynamically allocated payloads
+          nfapi_nr_uci_pucch_pdu_format_2_3_4_t *pucch_pdu = &msg->uci_list[i].pucch_pdu_format_2_3_4;
+          
+          // Free harq_payload if allocated
+          if (pucch_pdu->harq.harq_payload != NULL) {
+            free(pucch_pdu->harq.harq_payload);
+            pucch_pdu->harq.harq_payload = NULL;
+          }
+          
+          // Free sr_payload if allocated
+          if (pucch_pdu->sr.sr_payload != NULL) {
+            free(pucch_pdu->sr.sr_payload);
+            pucch_pdu->sr.sr_payload = NULL;
+          }
+          
+          // Free csi_part1_payload if allocated
+          if (pucch_pdu->csi_part1.csi_part1_payload != NULL) {
+            free(pucch_pdu->csi_part1.csi_part1_payload);
+            pucch_pdu->csi_part1.csi_part1_payload = NULL;
+          }
+          
+          // Free csi_part2_payload if allocated
+          if (pucch_pdu->csi_part2.csi_part2_payload != NULL) {
+            free(pucch_pdu->csi_part2.csi_part2_payload);
+            pucch_pdu->csi_part2.csi_part2_payload = NULL;
+          }
+          break;
+        }
+        
+        default:
+          // Unknown PDU type, do nothing
+          break;
+      }
+    }
+    
+    // Free the uci_list array itself
+    free(msg->uci_list);
+    msg->uci_list = NULL;
+  }
+}
