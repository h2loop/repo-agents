diff --git a/radio/vrtsim/vrtsim.c b/radio/vrtsim/vrtsim.c
index f2f9cfef1d..7d434aa7ba 100644
--- a/radio/vrtsim/vrtsim.c
+++ b/radio/vrtsim/vrtsim.c
@@ -556,6 +556,21 @@ static int vrtsim_write_beams(openair0_device_t *device,
                               int num_beams,
                               int flags)
 {
+  // Validate parameters
+  AssertFatal(nsamps > 0, "Number of samples must be greater than 0\n");
+  AssertFatal(nb_antennas_tx > 0 && nb_antennas_tx <= MAX_NUM_ANTENNAS_TX,
+              "Number of antennas %d must be between 1 and %d\n",
+              nb_antennas_tx,
+              MAX_NUM_ANTENNAS_TX);
+  AssertFatal(num_beams > 0 && num_beams <= 64,
+              "Number of beams %d must be between 1 and 64\n",
+              num_beams);
+  AssertFatal(timestamp >= 0, "Timestamp must be non-negative, got %ld\n", timestamp);
+  AssertFatal(buff != NULL, "Buffer pointer must not be NULL\n");
+  AssertFatal(buff[0] != NULL, "Buffer[0] pointer must not be NULL\n");
+  
+  // For now, we just process the first beam as in the original implementation
+  // In a full beamforming implementation, we would process all num_beams
   vrtsim_write(device, timestamp, (void **)buff[0], nsamps, nb_antennas_tx, flags);
   return nsamps;
 }
