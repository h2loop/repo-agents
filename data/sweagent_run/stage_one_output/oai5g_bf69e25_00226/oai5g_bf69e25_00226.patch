+/*
+ *-----------------------------------------------------------------------------
+ *                Helper function to decode APN format
+ *-----------------------------------------------------------------------------
+ */
+static int
+decode_apn_format(char* output, int output_len, const uint8_t* apn_encoded, int apn_len)
+{
+  int index = 0;
+  int out_index = 0;
+  
+  if (output == NULL || output_len <= 0 || apn_encoded == NULL || apn_len <= 0) {
+    return 0;
+  }
+  
+  while (index < apn_len && out_index < output_len - 1) {
+    // First octet is the length of the label
+    int label_len = apn_encoded[index++];
+    
+    // Check bounds
+    if (index + label_len > apn_len || out_index + label_len >= output_len - 1) {
+      break;
+    }
+    
+    // Add dot separator if not the first label
+    if (out_index > 0 && out_index < output_len - 1) {
+      output[out_index++] = '.';
+    }
+    
+    // Copy the label
+    for (int i = 0; i < label_len && out_index < output_len - 1; i++) {
+      output[out_index++] = apn_encoded[index++];
+    }
+  }
+  
+  output[out_index] = '\0';
+  return out_index;
+}
