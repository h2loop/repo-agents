+void rrc_ue_generate_measurementReport(NR_UE_RRC_INST_t *rrc, int gNB_index)
+{
+  LOG_D(NR_RRC, "Generating MeasurementReport for gNB index %d\n", gNB_index);
+
+  // Validate inputs
+  if (rrc == NULL || gNB_index < 0 || gNB_index >= NB_CNX_UE) {
+    LOG_E(NR_RRC, "Invalid parameters for MeasurementReport generation\n");
+    return;
+  }
+
+  rrcPerNB_t *rrcNB = &rrc->perNB[gNB_index];
+  
+  // For now, we'll create a simple measurement report with dummy values
+  // In a real implementation, these would come from actual measurements
+  
+  // Create the UL-DCCH message
+  NR_UL_DCCH_Message_t ul_dcch_msg = {0};
+  ul_dcch_msg.message.present = NR_UL_DCCH_MessageType_PR_c1;
+  NR_UL_DCCH_MessageType_t *ul_dcch_msg_type = &ul_dcch_msg.message.choice.c1;
+  
+  ul_dcch_msg_type->present = NR_UL_DCCH_MessageType__c1_PR_measurementReport;
+  NR_MeasurementReport_t *measurementReport = &ul_dcch_msg_type->choice.measurementReport;
+  
+  // Set up the MeasurementReport
+  measurementReport->criticalExtensions.present = NR_MeasurementReport__criticalExtensions_PR_measurementReport;
+  measurementReport->criticalExtensions.choice.measurementReport = calloc(1, sizeof(NR_MeasurementReport_IEs_t));
+  
+  if (measurementReport->criticalExtensions.choice.measurementReport == NULL) {
+    LOG_E(NR_RRC, "Failed to allocate memory for MeasurementReport_IEs\n");
+    return;
+  }
+  
+  NR_MeasurementReport_IEs_t *measReport_ies = measurementReport->criticalExtensions.choice.measurementReport;
+  
+  // Create a basic MeasResults structure
+  measReport_ies->measResults.measId = 1; // Default measurement ID
+  
+  // Add basic PCell measurement results
+  // In a real implementation, these values would come from actual measurements
+  measReport_ies->measResults.measResultPCell.rsrpResult = 60; // Example RSRP value (range 0-127)
+  measReport_ies->measResults.measResultPCell.rsrqResult = 20; // Example RSRQ value (range 0-127)
+  
+  // For now, we create a minimal MeasResults structure
+  // In a real implementation, this would be populated with actual measurement data
+  // For example, we would add:
+  // - measResultServingMOList with serving cell measurements
+  // - measResultNeighCells with neighbor cell measurements
+  // - measResultServFreqList with serving frequency measurements
+  
+  // Encode and send the message
+  uint8_t buffer[1024];
+  size_t buffer_size = sizeof(buffer);
+  
+  asn_enc_rval_t enc_rval = uper_encode_to_buffer(&asn_DEF_NR_UL_DCCH_Message,
+                                                  NULL,
+                                                  &ul_dcch_msg,
+                                                  buffer,
+                                                  buffer_size);
+  
+  if (enc_rval.encoded == -1) {
+    LOG_E(NR_RRC, "ASN.1 encoding of MeasurementReport failed\n");
+    // Free allocated memory before returning
+    if (measurementReport->criticalExtensions.choice.measurementReport) {
+      free(measurementReport->criticalExtensions.choice.measurementReport);
+    }
+    return;
+  }
+  
+  // Send the encoded message through RLC
+  int encoded_size = (enc_rval.encoded + 7) / 8;
+  LOG_D(NR_RRC, "Successfully encoded MeasurementReport: %d bytes\n", encoded_size);
+  
+  // Send the encoded message through RLC (SRB1 for MeasurementReport)
+  nr_rlc_srb_recv_sdu(rrc->ue_id, 1, buffer, encoded_size);
+  
+  // Free allocated memory manually
+  if (measurementReport->criticalExtensions.choice.measurementReport) {
+    free(measurementReport->criticalExtensions.choice.measurementReport);
+  }
+}
