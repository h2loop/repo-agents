diff --git a/common/utils/T/tracer/gui/init.c b/common/utils/T/tracer/gui/init.c
index c6d5e3e435..21f2db038e 100644
--- a/common/utils/T/tracer/gui/init.c
+++ b/common/utils/T/tracer/gui/init.c
@@ -32,3 +32,49 @@ gui *gui_init(void)
 
   return ret;
 }
+
+void gui_cleanup(gui *gui)
+{
+  struct gui *g = gui;
+  struct widget_list *cur, *next;
+  struct event_list *ecur, *enext;
+  
+  if (g == NULL) return;
+  
+  // Close the event pipe
+  close(g->event_pipe[0]);
+  close(g->event_pipe[1]);
+  
+  // Free queued events
+  ecur = g->queued_events;
+  while (ecur) {
+    enext = ecur->next;
+    if (ecur->item) {
+      free(ecur->item);
+    }
+    free(ecur);
+    ecur = enext;
+  }
+  
+  // Free toplevel widgets
+  cur = g->toplevel;
+  while (cur) {
+    next = cur->next;
+    free(cur);
+    cur = next;
+  }
+  
+  // Close X connection
+  if (g->x) {
+    x_close(g->x);
+  }
+  
+  // Destroy mutex
+  if (g->lock) {
+    pthread_mutex_destroy(g->lock);
+    free(g->lock);
+  }
+  
+  // Free the gui structure
+  free(g);
+}
diff --git a/common/utils/T/tracer/gui/x.c b/common/utils/T/tracer/gui/x.c
index 71bd805455..2771c35a54 100644
--- a/common/utils/T/tracer/gui/x.c
+++ b/common/utils/T/tracer/gui/x.c
@@ -334,6 +334,42 @@ void x_flush(x_connection *_x) {
   XFlush(x->d);
 }
 
+void x_close(x_connection *_x) {
+  struct x_connection *x = _x;
+  int i;
+  
+  if (x == NULL) return;
+  
+  // Free fonts
+  for (i = 0; i < x->nfonts; i++) {
+    if (x->fonts[i] != NULL) {
+      XftFontClose(x->d, x->fonts[i]);
+    }
+  }
+  free(x->fonts);
+  
+  // Free colors
+  for (i = 0; i < x->ncolors; i++) {
+    if (x->colors[i] != NULL) {
+      XFreeGC(x->d, x->colors[i]);
+    }
+    // Xft colors don't need to be freed according to Xft documentation
+  }
+  free(x->colors);
+  free(x->xft_colors);
+  
+  // Free points buffer
+  free(x->pts);
+  
+  // Close X display
+  if (x->d != NULL) {
+    XCloseDisplay(x->d);
+  }
+  
+  // Free the connection structure
+  free(x);
+}
