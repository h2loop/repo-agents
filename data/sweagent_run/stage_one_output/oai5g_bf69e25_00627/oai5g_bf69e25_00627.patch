+/* Extended structure to hold both the qmsg and the original function pointer */
+typedef struct {
+  telnetsrv_qmsg_t qmsg;
+  cmdfunc_t original_func;
+} telnetsrv_qmsg_ext_t;
+
+/* Wrapper function to adapt cmdfunc_t to qcmdfunc_t signature */
+static int cmdfunc_wrapper(char *cmdbuff, int debug, telnet_printfunc_t prnt, void *arg) {
+  /* The arg parameter points to the telnetsrv_qmsg_t structure */
+  telnetsrv_qmsg_t *qmsg = (telnetsrv_qmsg_t *)arg;
+  telnetsrv_qmsg_ext_t *ext = (telnetsrv_qmsg_ext_t *)((char *)qmsg - offsetof(telnetsrv_qmsg_ext_t, qmsg));
+  return ext->original_func(cmdbuff, debug, prnt);
+}
