+/**
+ * Create a 128-bit vector with 4 32-bit integers in reverse order.
+ * This is equivalent to _mm_setr_epi32(a, b, c, d) which creates a vector [a, b, c, d].
+ */
+__attribute__((always_inline)) static inline
+simde__m128i simde_mm_setr_epi32(int a, int b, int c, int d)
+{
+  return simde_mm_set_epi32(d, c, b, a);
+}
+
+/**
+ * Create a 128-bit vector with 4 32-bit integers.
+ * This is equivalent to _mm_set_epi32(a, b, c, d) which creates a vector [a, b, c, d].
+ */
+__attribute__((always_inline)) static inline
+simde__m128i simde_mm_set_epi32(int a, int b, int c, int d)
+{
+  simde__m128i result = simde_mm_setzero_si128();
+  result = simde_mm_insert_epi32(result, d, 0);
+  result = simde_mm_insert_epi32(result, c, 1);
+  result = simde_mm_insert_epi32(result, b, 2);
+  result = simde_mm_insert_epi32(result, a, 3);
+  return result;
+}
+
