+/* \brief Get SSB to RACH occasion preambles mapping for 2-step RA
+   This function maps the selected SSB to its corresponding preamble index for 2-step random access
+   @param mac pointer to MAC instance
+   @param rach_ConfigDedicated pointer to RACH configuration dedicated
+   @returns preamble index for the selected SSB, or -1 if not found */
+static int get_ssb_ro_preambles_2step(NR_UE_MAC_INST_t *mac, NR_RACH_ConfigDedicated_t *rach_ConfigDedicated)
+{
+  if (!rach_ConfigDedicated) {
+    LOG_E(MAC, "Invalid RACH configuration for 2-step RA\n");
+    return -1;
+  }
+
+  RA_config_t *ra = &mac->ra;
+  void **ssb_resource_list = NULL;
+  int num_ssb_resources = 0;
+  
+  // Check which CFRA configuration is used
+  if (rach_ConfigDedicated->cfra) {
+    // Standard CFRA configuration
+    NR_CFRA_t *cfra = rach_ConfigDedicated->cfra;
+    if (cfra->resources.present != NR_CFRA__resources_PR_ssb) {
+      LOG_E(MAC, "CFRA resources are not configured for SSB\n");
+      return -1;
+    }
+    ssb_resource_list = (void **)cfra->resources.choice.ssb->ssb_ResourceList.list.array;
+    num_ssb_resources = cfra->resources.choice.ssb->ssb_ResourceList.list.count;
+  } else if (rach_ConfigDedicated->ext1 && rach_ConfigDedicated->ext1->cfra_TwoStep_r16) {
+    // Rel-16 2-step CFRA configuration
+    NR_CFRA_TwoStep_r16_t *cfra_2step = rach_ConfigDedicated->ext1->cfra_TwoStep_r16;
+    ssb_resource_list = (void **)cfra_2step->ssb_ResourceList.list.array;
+    num_ssb_resources = cfra_2step->ssb_ResourceList.list.count;
+  } else {
+    LOG_E(MAC, "Invalid CFRA configuration for 2-step RA\n");
+    return -1;
+  }
+  
+  // For 2-step RA, we need to map the selected SSB to its preamble
+  // The ssb_nb_in_ro indicates which SSB was selected in this RACH occasion
+  uint8_t selected_ssb_index = ra->ssb_nb_in_ro;
+  
+  // Validate that the selected SSB index is within bounds
+  if (selected_ssb_index >= num_ssb_resources) {
+    LOG_W(MAC, "Selected SSB index %d is out of bounds (0-%d), using first SSB\n", 
+          selected_ssb_index, num_ssb_resources - 1);
+    selected_ssb_index = 0;
+  }
+  
+  // Get the preamble index for the selected SSB
+  // Access the field directly using offset - this is a workaround since we don't have the exact structure definition
+  long preamble_index = 0;
+  // The ra_PreambleIndex is the first field in the structure, so we can access it directly
+  preamble_index = *(long *)ssb_resource_list[selected_ssb_index];
+  
+  LOG_D(MAC, "Selected RA preamble index %ld for 2-step RA using SSB index %d\n", 
+        preamble_index, selected_ssb_index);
+  
+  return (int)preamble_index;
+}
