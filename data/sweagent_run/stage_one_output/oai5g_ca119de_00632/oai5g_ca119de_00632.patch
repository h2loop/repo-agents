+#ifndef TEST_UTIL_H
+#define TEST_UTIL_H
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <stdint.h>
+
+// Function to convert a hex character to its integer value
+static inline int hex_char_to_hex_value(char c)
+{
+  if (c >= '0' && c <= '9') return c - '0';
+  if (c >= 'A' && c <= 'F') return c - 'A' + 10;
+  if (c >= 'a' && c <= 'f') return c - 'a' + 10;
+  return 0;
+}
+
+// Function to convert a hex string to binary data
+static inline int hex_string_to_hex_value(uint8_t *hex_value, const char *hex_string, int size)
+{
+  if (strlen(hex_string) != size*2) {
+    fprintf(stderr, "the string '%s' should be of length %d\n", hex_string, size*2);
+    return -1;
+  }
+  
+  for (int i = 0; i < size; i++) {
+    int a = hex_char_to_hex_value(hex_string[2 * i]);
+    int b = hex_char_to_hex_value(hex_string[2 * i + 1]);
+    
+    if (a == -1 || b == -1) {
+      fprintf(stderr, "the string '%s' is not a valid hexadecimal string\n", hex_string);
+      return -1;
+    }
+    
+    hex_value[i] = (a << 4) | b;
+  }
+  
+  return 0;
+}
+
+// Function to decode hex string and return a duplicate buffer
+static inline uint8_t* decode_hex_dup(const char* hex_string)
+{
+  int len = strlen(hex_string);
+  if (len % 2 != 0) {
+    fprintf(stderr, "Hex string must have even length\n");
+    return NULL;
+  }
+  
+  int byte_len = len / 2;
+  uint8_t* buffer = (uint8_t*)malloc(byte_len);
+  if (buffer == NULL) {
+    return NULL;
+  }
+  
+  if (hex_string_to_hex_value(buffer, hex_string, byte_len) != 0) {
+    free(buffer);
+    return NULL;
+  }
+  
+  return buffer;
+}
+
+// Function to get the length of decoded hex string
+static inline unsigned decode_hex_length(const char* hex_string)
+{
+  return strlen(hex_string) / 2;
+}
+
+// HL macro that returns both the decoded data and its length
+#define HL(x) decode_hex_dup(x), decode_hex_length(x)
+
+// Function to compare buffers
+static inline int compare_buffer(uint8_t *buf1, unsigned len1, uint8_t *buf2, unsigned len2)
+{
+  if (len1 != len2) {
+    return -1;
+  }
+  
+  return memcmp(buf1, buf2, len1);
+}
+
+// Function to fail a test
+static inline void fail(const char* message)
+{
+  fprintf(stderr, "%s", message);
+  exit(1);
+}
+
+#endif // TEST_UTIL_H
