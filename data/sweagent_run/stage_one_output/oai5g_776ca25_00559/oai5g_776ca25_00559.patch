+  int32_t tx_power_times10 = (int32_t)ue->frame_parms.pdsch_config_common.referenceSignalPower * 10;
+  
+  int32_t path_loss_times10 = rx_gain_times10 + tx_power_times10 - rsrp_dB_times10;
+  
+  return (int16_t)(path_loss_times10 / 10);
 }
 
