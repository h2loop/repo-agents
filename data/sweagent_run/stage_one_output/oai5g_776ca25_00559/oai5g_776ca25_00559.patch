+  // Path Loss = Tx Power - Rx Power (per RE)
+  // Rx Power (per RE) = RSRP (in dBm per RE) = (dB_fixed_times10(rsrp) / 10) - rx_total_gain_dB
+  // Path Loss = referenceSignalPower - ((dB_fixed_times10(rsrp) / 10) - rx_total_gain_dB)
+  // Path Loss = referenceSignalPower - (dB_fixed_times10(rsrp) / 10) + rx_total_gain_dB
+  // Path Loss = rx_total_gain_dB + referenceSignalPower - (dB_fixed_times10(rsrp) / 10)
+  
+  int32_t rsrp_dB_times10 = (int32_t)dB_fixed_times10(ue->measurements.rsrp[eNB_index]);
