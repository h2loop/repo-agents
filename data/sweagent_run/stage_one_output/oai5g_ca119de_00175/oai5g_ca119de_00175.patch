+static int decode_imeisv_5gs_mobile_identity(Imeisv5GSMobileIdentity_t *imeisv, const uint8_t *buffer)
+{
+  int decoded = 0;
+  
+  imeisv->digittac01 = *(buffer + decoded) & 0xf;
+  imeisv->oddeven = (*(buffer + decoded) >> 4) & 0x1;
+  imeisv->typeofidentity = (*(buffer + decoded) >> 5) & 0x7;
+  
+  if (imeisv->typeofidentity != FGS_MOBILE_IDENTITY_IMEISV) {
+    return (TLV_DECODE_VALUE_DOESNT_MATCH);
+  }
+  
+  decoded++;
+  
+  imeisv->digittac02 = *(buffer + decoded) & 0xf;
+  imeisv->digittac03 = (*(buffer + decoded) >> 4) & 0xf;
+  decoded++;
+  
+  imeisv->digittac04 = *(buffer + decoded) & 0xf;
+  imeisv->digittac05 = (*(buffer + decoded) >> 4) & 0xf;
+  decoded++;
+  
+  imeisv->digittac06 = *(buffer + decoded) & 0xf;
+  imeisv->digittac07 = (*(buffer + decoded) >> 4) & 0xf;
+  decoded++;
+  
+  imeisv->digittac08 = *(buffer + decoded) & 0xf;
+  imeisv->digit09 = (*(buffer + decoded) >> 4) & 0xf;
+  decoded++;
+  
+  imeisv->digit10 = *(buffer + decoded) & 0xf;
+  imeisv->digit11 = (*(buffer + decoded) >> 4) & 0xf;
+  decoded++;
+  
+  imeisv->digit12 = *(buffer + decoded) & 0xf;
+  imeisv->digit13 = (*(buffer + decoded) >> 4) & 0xf;
+  decoded++;
+  
+  imeisv->digit14 = *(buffer + decoded) & 0xf;
+  imeisv->digitsv1 = (*(buffer + decoded) >> 4) & 0xf;
+  decoded++;
+  
+  imeisv->digitsv2 = *(buffer + decoded) & 0xf;
+  imeisv->spare = (*(buffer + decoded) >> 4) & 0xf;
+  decoded++;
+
+  return decoded;
+}
