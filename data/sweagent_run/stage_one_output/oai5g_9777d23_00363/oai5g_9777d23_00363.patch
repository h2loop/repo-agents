-  if (tmgi->spare != 0) {
+  if (tmgi->typeofidentity != MOBILE_IDENTITY_TMGI) {
     return (TLV_ENCODE_VALUE_DOESNT_MATCH);
   }
 
-  tmgi->mbmssessionidindication = (*(buffer + decoded) >> 5) & 0x1;
