 static int decode_tmgi_mobile_identity(TmgiMobileIdentity_t *tmgi, uint8_t *buffer)
 {
   int decoded = 0;
-  tmgi->spare = (*(buffer + decoded) >> 6) & 0x2;
+  tmgi->typeofidentity = *(buffer + decoded) & 0x7;
 
-  /*
-   * Spare bits are coded with 0s
