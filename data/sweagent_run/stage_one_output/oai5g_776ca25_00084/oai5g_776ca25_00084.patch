diff --git a/openair1/PHY/NR_TRANSPORT/nr_prach_common.c b/openair1/PHY/NR_TRANSPORT/nr_prach_common.c
index 5933e84cbb..993446f784 100644
--- a/openair1/PHY/NR_TRANSPORT/nr_prach_common.c
+++ b/openair1/PHY/NR_TRANSPORT/nr_prach_common.c
@@ -189,3 +189,29 @@ void init_nr_prach_tables(int N_ZC)
   }
 }
 
+uint16_t get_prach_K(uint8_t prach_sequence_length, uint8_t prach_fmt_id, uint8_t mu)
+{
+  // According to 3GPP TS 38.211, Section 6.3.3.2
+  // K is the frequency domain separation between PRACH resources
+  // mu parameter is included for future extensions but not currently used
+  
+  if (prach_sequence_length == 0) { // Long sequence (839)
+    switch (prach_fmt_id) {
+      case 0:  // format 0
+      case 1:  // format 1
+      case 2:  // format 2
+        return 24; // For formats 0,1,2 with long sequence
+      case 3:  // format 3
+        return 4;  // For format 3 with long sequence
+      default:
+        return 24; // Default for long sequences
+    }
+  } else { // Short sequence (139)
+    // For short sequences, K is typically 1 according to the specification
+    return 1;
+  }
+  
+  // Avoid unused parameter warning
+  (void)mu;
+}
+
