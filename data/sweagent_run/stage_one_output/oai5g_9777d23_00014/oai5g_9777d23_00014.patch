+static void select_ue(void *private, gui *g,
+    char *notification, widget *w, void *notification_data)
+{
+  ue_data *ed = (ue_data *)private;
+  int ue = ed->ue;
+  int do_reset = 0;
+
+  if (notification_data == NULL || *(int *)notification_data != 1) return;
+  if (w == ed->e->prev_ue_button) { ue--; if (ue < 0) ue = 0; }
+  if (w == ed->e->next_ue_button) ue++;
+  if (w == ed->e->current_ue_button) do_reset = 1;
+
+  if (pthread_mutex_lock(&ed->lock)) abort();
+  if (do_reset) reset_ue_ids();
+  if (ue != ed->ue) {
+    set_current_ue(g, ed, ue);
+  }
+  if (pthread_mutex_unlock(&ed->lock)) abort();
+}
