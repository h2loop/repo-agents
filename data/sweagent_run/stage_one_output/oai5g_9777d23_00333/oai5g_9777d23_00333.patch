-    AssertFatal ( sizeof(sem_counter) == write(t->sem_fd, &sem_counter, sizeof(sem_counter)), "");
+    ssize_t bytes_written = write(t->sem_fd, &sem_counter, sizeof(sem_counter));
+    if (sizeof(sem_counter) != bytes_written) {
+        LOG_E(ITTI, "Failed to write to eventfd for task %s: %s\n", 
+              itti_get_task_name(destination_task_id), strerror(errno));
+        return -1;
+    }
     LOG_D(ITTI, "sent messages id=%s messages_info to %s\n", messages_info[message_id].name, t->admin.name);
     return 0;
   }
