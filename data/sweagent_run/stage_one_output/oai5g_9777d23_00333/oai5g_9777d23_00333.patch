+  int itti_send_msg_to_task_locked(task_id_t destination_task_id, instance_t destinationInstance, MessageDef *message) {
+    // Check for null pointers
+    if (message == NULL) {
+        LOG_E(ITTI, "Message is NULL\n");
+        return -1;
+    }
+    
+    if (destination_task_id >= nb_queues || tasks[destination_task_id] == NULL) {
+        LOG_E(ITTI, "Invalid destination task ID: %d\n", destination_task_id);
+        return -1;
+    }
