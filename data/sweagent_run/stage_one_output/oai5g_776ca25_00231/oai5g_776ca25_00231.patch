+++ b/openair1/PHY/NR_UE_TRANSPORT/sss_nr.c
@@ -93,7 +93,7 @@ void init_context_sss_nr(int amp)
       /* Modulation of SSS is a BPSK TS 36.211 chapter 5.1.2 BPSK */
 #if 1
         d_sss[N_ID_2][N_ID_1][n]   = dss_current;// * amp;
