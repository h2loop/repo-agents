+        (void) amp;
 #else
         (void) amp;
         d_sss[N_ID_2][N_ID_1][n]   = (dss_current * SHRT_MAX)>>SCALING_PSS_NR;
@@ -192,6 +192,14 @@ static int pss_ch_est_nr(const NR_DL_FRAME_PARMS *frame_parms,
                          c16_t pss_ext[NB_ANTENNAS_RX][LENGTH_PSS_NR],
