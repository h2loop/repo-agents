+ *      contact@openairinterface.org
+ */
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <math.h>
+#include "time_source.h"
+
+// Structure to hold time source information with IQ data
+typedef struct {
+    uint64_t timestamp;
+    c16_t* iq_data;
+    int length;
+} time_source_iq_t;
+
+// Global time source IQ buffer
+static time_source_iq_t time_source_buffer = {0, NULL, 0};
+
+int time_source_iq_add(c16_t* iq_samples, int length, uint64_t timestamp)
+{
+    if (iq_samples == NULL || length <= 0) {
+        return -1; // Invalid input parameters
+    }
+
+    // If buffer is not allocated or size mismatch, reallocate
+    if (time_source_buffer.iq_data == NULL || time_source_buffer.length < length) {
+        if (time_source_buffer.iq_data != NULL) {
+            free(time_source_buffer.iq_data);
+        }
+        time_source_buffer.iq_data = (c16_t*)malloc(length * sizeof(c16_t));
+        if (time_source_buffer.iq_data == NULL) {
+            time_source_buffer.length = 0;
+            return -2; // Memory allocation failed
+        }
+        time_source_buffer.length = length;
+        memset(time_source_buffer.iq_data, 0, length * sizeof(c16_t));
+    }
+
+    // Add IQ samples (complex addition)
+    for (int i = 0; i < length; i++) {
+        time_source_buffer.iq_data[i] = c16add(time_source_buffer.iq_data[i], iq_samples[i]);
+    }
+
+    // Update timestamp
+    time_source_buffer.timestamp = timestamp;
+
+    return 0; // Success
+}
+
+int time_source_iq_get(c16_t* iq_samples, int length, uint64_t* timestamp)
+{
+    if (iq_samples == NULL || length <= 0 || timestamp == NULL) {
+        return -1; // Invalid input parameters
+    }
+
+    if (time_source_buffer.iq_data == NULL || time_source_buffer.length == 0) {
+        return -3; // No data available
+    }
+
+    // Copy data up to the minimum of requested length and available length
+    int copy_length = (length < time_source_buffer.length) ? length : time_source_buffer.length;
+    
+    for (int i = 0; i < copy_length; i++) {
+        iq_samples[i] = time_source_buffer.iq_data[i];
+    }
+
+    *timestamp = time_source_buffer.timestamp;
+
+    return copy_length; // Return number of samples copied
+}
+
+void time_source_iq_reset(void)
+{
+    if (time_source_buffer.iq_data != NULL) {
+        free(time_source_buffer.iq_data);
+        time_source_buffer.iq_data = NULL;
+    }
+    time_source_buffer.length = 0;
+    time_source_buffer.timestamp = 0;
+}
+
+int time_source_iq_init(int max_length)
+{
+    if (max_length <= 0) {
+        return -1; // Invalid parameter
+    }
+
+    // Reset any existing buffer
+    time_source_iq_reset();
+
+    // Allocate buffer
+    time_source_buffer.iq_data = (c16_t*)calloc(max_length, sizeof(c16_t));
+    if (time_source_buffer.iq_data == NULL) {
+        return -2; // Memory allocation failed
+    }
+
+    time_source_buffer.length = max_length;
+    time_source_buffer.timestamp = 0;
+
+    return 0; // Success
+}
