+#ifndef __TIME_SOURCE_H__
+#define __TIME_SOURCE_H__
+
+#include <stdint.h>
+#include "PHY/TOOLS/tools_defs.h"
+
+/**
+ * @brief Add IQ samples to the time source buffer
+ * 
+ * This function adds IQ samples to an internal buffer, maintaining timing information.
+ * The addition is performed as complex addition (real and imaginary parts separately).
+ * 
+ * @param iq_samples Pointer to the IQ samples to add
+ * @param length Number of IQ samples
+ * @param timestamp Timestamp associated with these samples
+ * @return 0 on success, negative value on error
+ *         -1: Invalid parameters
+ *         -2: Memory allocation failed
+ */
+int time_source_iq_add(c16_t* iq_samples, int length, uint64_t timestamp);
+
+/**
+ * @brief Get the current accumulated IQ samples from the time source
+ * 
+ * @param iq_samples Pointer to buffer where IQ samples will be copied
+ * @param length Maximum number of samples to copy
+ * @param timestamp Pointer to store the timestamp of the data
+ * @return Number of samples copied on success, negative value on error
+ *         -1: Invalid parameters
+ *         -3: No data available
+ */
+int time_source_iq_get(c16_t* iq_samples, int length, uint64_t* timestamp);
+
+/**
+ * @brief Initialize the time source IQ buffer
+ * 
+ * @param max_length Maximum number of IQ samples the buffer can hold
+ * @return 0 on success, negative value on error
+ *         -1: Invalid parameter
+ *         -2: Memory allocation failed
+ */
+int time_source_iq_init(int max_length);
+
+/**
+ * @brief Reset and free the time source IQ buffer
+ */
+void time_source_iq_reset(void);
+
+#endif /* __TIME_SOURCE_H__ */
