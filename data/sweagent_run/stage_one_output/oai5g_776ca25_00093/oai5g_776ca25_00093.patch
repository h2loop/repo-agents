+/*
+ * Test file for time_source_iq_add function
+ */
+
+#include <stdio.h>
+#include <stdlib.h>
+#include "time_source.h"
+
+int main() {
+    // Initialize the time source with capacity for 100 samples
+    int ret = time_source_iq_init(100);
+    if (ret != 0) {
+        printf("Failed to initialize time source: %d\n", ret);
+        return -1;
+    }
+
+    // Create some test IQ data
+    c16_t test_data1[10] = {
+        {100, 200}, {300, 400}, {500, 600}, {700, 800}, {900, 1000},
+        {1100, 1200}, {1300, 1400}, {1500, 1600}, {1700, 1800}, {1900, 2000}
+    };
+
+    c16_t test_data2[10] = {
+        {50, 100}, {150, 200}, {250, 300}, {350, 400}, {450, 500},
+        {550, 600}, {650, 700}, {750, 800}, {850, 900}, {950, 1000}
+    };
+
+    // Add first set of data
+    ret = time_source_iq_add(test_data1, 10, 1000);
+    if (ret != 0) {
+        printf("Failed to add first set of IQ data: %d\n", ret);
+        return -1;
+    }
+
+    // Add second set of data (should accumulate)
+    ret = time_source_iq_add(test_data2, 10, 2000);
+    if (ret != 0) {
+        printf("Failed to add second set of IQ data: %d\n", ret);
+        return -1;
+    }
+
+    // Retrieve the accumulated data
+    c16_t result_data[10];
+    uint64_t timestamp;
+    int samples_copied = time_source_iq_get(result_data, 10, ×tamp);
+    if (samples_copied < 0) {
+        printf("Failed to get IQ data: %d\n", samples_copied);
+        return -1;
+    }
+
+    printf("Retrieved %d samples with timestamp %lu\n", samples_copied, timestamp);
+    printf("First few results:\n");
+    for (int i = 0; i < 3 && i < samples_copied; i++) {
+        printf("  [%d] r=%d, i=%d\n", i, result_data[i].r, result_data[i].i);
+    }
+
+    // Expected results: sum of test_data1 and test_data2
+    printf("Expected results:\n");
+    for (int i = 0; i < 3; i++) {
+        int expected_r = test_data1[i].r + test_data2[i].r;
+        int expected_i = test_data1[i].i + test_data2[i].i;
+        printf("  [%d] r=%d, i=%d\n", i, expected_r, expected_i);
+    }
+
+    // Reset and clean up
+    time_source_iq_reset();
+
+    printf("Test completed successfully!\n");
+    return 0;
+}
