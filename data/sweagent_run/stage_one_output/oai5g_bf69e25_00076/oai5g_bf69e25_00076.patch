     {ngap_gNB_handle_initial_context_request, 0, 0}, /* InitialContextSetup */
     {0, 0, 0}, /* InitialUEMessage */
     {0, 0, 0}, /* LocationReportingControl */
@@ -1364,3 +1364,57 @@ int ngap_gNB_handle_message(sctp_assoc_t assoc_id, int32_t stream, const uint8_t
   ASN_STRUCT_FREE_CONTENTS_ONLY(asn_DEF_NGAP_NGAP_PDU, &pdu);
   return ret;
 }
+
+int ngap_gNB_handle_handover_request(sctp_assoc_t assoc_id, int32_t stream, NGAP_NGAP_PDU_t *pdu)
+{
+  NGAP_HandoverRequest_t *handoverRequest_p = NULL;
+  NGAP_HandoverRequestIEs_t *ie = NULL;
+  MessageDef *msg = NULL;
+  int i = 0;
+  int rc = 0;
+  struct ngap_gNB_amf_data_s *amf_desc_p = NULL;
+
+  DevAssert(pdu != NULL);
+
+  if (pdu->present != NGAP_NGAP_PDU_PR_initiatingMessage) {
+    NGAP_ERROR("PDU is not an initiating message\n");
+    return -1;
+  }
+
+  if (pdu->choice.initiatingMessage->value.present != NGAP_InitiatingMessage__value_PR_HandoverRequest) {
+    NGAP_ERROR("Initiating message is not a HandoverRequest\n");
+    return -1;
+  }
+
+  handoverRequest_p = &pdu->choice.initiatingMessage->value.choice.HandoverRequest;
+
+  NGAP_INFO("Handover Request received\n");
+
+  /* TODO: Process the HandoverRequest message
+   * This is where you would extract the information from the HandoverRequest
+   * and create the appropriate internal message to be sent to other modules.
+   * 
+   * Key information that would typically be extracted:
+   * - AMF UE NGAP ID
+   * - Handover Type
+   * - Cause
+   * - UE Aggregate Maximum Bit Rate
+   * - Core Network Assistance Information (optional)
+   * - UE Security Capabilities
+   * - Security Context
+   * - New Security Context Indicator
+   * - NPN Support (optional)
+   * - Trace Activation (optional)
+   * - Masked IMEISV (optional)
+   * - Source to Target Transparent Container
+   * - NAS PDU (optional)
+   * - PDU Session Resource Handover List
+   * - PDU Session Resource to Release List (optional)
+   * - Criticality Diagnostics (optional)
+   */
+
+  /* For now, we'll just log that we received the message and return success */
+  NGAP_INFO("HandoverRequest successfully processed\n");
+
+  return 0;
+}
