 int m2ap_id_get_id_source(m2ap_id_manager *m, int ue_id)
 {
+  if (ue_id < 0 || ue_id >= M2AP_MAX_IDS) {
+    return -1; // Invalid UE ID
+  }
   return m->ids[ue_id].id_source;
