 void m2ap_set_reloc_overall_timer(m2ap_id_manager *m, int ue_id, uint64_t time)
 {
+  if (ue_id < 0 || ue_id >= M2AP_MAX_IDS) {
+    return; // Invalid UE ID
+  }
