diff --git a/openair1/PHY/INIT/nr_init_ue.c b/openair1/PHY/INIT/nr_init_ue.c
index e5c8e975c9..de55bfeb50 100644
--- a/openair1/PHY/INIT/nr_init_ue.c
+++ b/openair1/PHY/INIT/nr_init_ue.c
@@ -515,7 +515,10 @@ static void sl_generate_psbch_dmrs_qpsk_sequences(PHY_VARS_NR_UE *UE, struct com
 
   /// QPSK modulation
   for (int m = 0; m < SL_NR_NUM_PSBCH_DMRS_RE; m++) {
-    idx = (((sl_dmrs_sequence[(m << 1) >> 5]) >> ((m << 1) & 0x1f)) & 3);
+    // Extract 2 bits for QPSK modulation
+    uint32_t word_index = (m << 1) >> 5;  // Equivalent to (2*m) / 32
+    uint32_t bit_offset = (m << 1) & 0x1f;  // Equivalent to (2*m) % 32
+    idx = ((sl_dmrs_sequence[word_index] >> bit_offset) & 3);
     modulated_dmrs_sym[m].r = mod_table[idx].r;
     modulated_dmrs_sym[m].i = mod_table[idx].i;
   }
