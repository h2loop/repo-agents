--- a/common/utils/T/tracer/utils.c
+++ b/common/utils/T/tracer/utils.c
@@ -15,27 +15,32 @@ void new_thread(void *(*f)(void *), void *data) {
 
   if (pthread_attr_init(&att)) {
     fprintf(stderr, "pthread_attr_init err\n");
