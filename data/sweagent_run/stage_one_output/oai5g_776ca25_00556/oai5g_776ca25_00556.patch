+/*! \file test_time_manager.c
+ * \brief Test program for time manager functions
+ * \author OpenAirInterface Software Alliance
+ * \date 2023
+ * \version 0.1
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ */
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <unistd.h>
+#include "common/utils/time_manager/time_manager.h"
+#include "common/utils/time_meas.h"
+
+int main() {
+    printf("Testing time_manager_iq_samples function\n");
+    
+    // Initialize time manager
+    double sample_rate = 30.72e6; // 30.72 MHz
+    if (time_manager_init(sample_rate) != 0) {
+        printf("Failed to initialize time manager\n");
+        return -1;
+    }
+    
+    // Test time_manager_iq_samples function
+    openair0_timestamp timestamp;
+    int num_samples = 1024;
+    
+    printf("Processing %d IQ samples\n", num_samples);
+    
+    int result = time_manager_iq_samples(×tamp, num_samples);
+    if (result != 0) {
+        printf("Error in time_manager_iq_samples: %d\n", result);
+        time_manager_cleanup();
+        return -1;
+    }
+    
+    printf("Successfully processed IQ samples. Timestamp: %lu\n", (unsigned long)timestamp);
+    
+    // Test with different number of samples
+    num_samples = 2048;
+    printf("Processing %d IQ samples\n", num_samples);
+    
+    result = time_manager_iq_samples(×tamp, num_samples);
+    if (result != 0) {
+        printf("Error in time_manager_iq_samples: %d\n", result);
+        time_manager_cleanup();
+        return -1;
+    }
+    
+    printf("Successfully processed IQ samples. Timestamp: %lu\n", (unsigned long)timestamp);
+    
+    // Get statistics
+    time_stats_t stats;
+    time_manager_get_stats(&stats);
+    printf("Time manager statistics - Trials: %d, Total time: %lu\n", 
+           stats.trials, (unsigned long)stats.diff);
+    
+    // Cleanup
+    time_manager_cleanup();
+    
+    printf("Time manager test completed successfully\n");
+    return 0;
+}
