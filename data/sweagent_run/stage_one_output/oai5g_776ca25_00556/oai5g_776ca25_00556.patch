+/*! \file time_manager.c
+ * \brief Time management functions for IQ samples
+ * \author OpenAirInterface Software Alliance
+ * \date 2023
+ * \version 0.1
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ */
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <time.h>
+#include <sys/time.h>
+#include "time_manager.h"
+#include "common/utils/time_meas.h"
+#include "common/utils/LOG/log.h"
+
+// Time management statistics
+static time_stats_t time_manager_iq_stats;
+
+// Global timestamp for IQ samples
+static openair0_timestamp current_iq_timestamp = 0;
+
+// Sample rate for IQ processing
+static double iq_sample_rate = 30.72e6; // Default to 30.72 MHz
+
+// Initialize time manager for IQ samples
+int time_manager_init(double sample_rate) {
+    reset_meas(&time_manager_iq_stats);
+    iq_sample_rate = sample_rate;
+    current_iq_timestamp = 0;
+    
+    LOG_I(PHY, "Time manager initialized with sample rate %f Hz\n", sample_rate);
+    return 0;
+}
+
+// Update timestamp for IQ samples
+void time_manager_update_timestamp(openair0_timestamp timestamp) {
+    current_iq_timestamp = timestamp;
+}
+
+// Get current IQ timestamp
+openair0_timestamp time_manager_get_timestamp(void) {
+    return current_iq_timestamp;
+}
+
+// Calculate time difference between two timestamps
+double time_manager_time_diff(openair0_timestamp ts1, openair0_timestamp ts2) {
+    return ((double)(ts2 - ts1)) / iq_sample_rate;
+}
+
+// Main function to manage time for IQ samples
+int time_manager_iq_samples(openair0_timestamp *timestamp, int num_samples) {
+    start_meas(&time_manager_iq_stats);
+    
+    // Validate input parameters
+    if (timestamp == NULL) {
+        LOG_E(PHY, "Invalid timestamp pointer\n");
+        stop_meas(&time_manager_iq_stats);
+        return -1;
+    }
+    
+    if (num_samples <= 0) {
+        LOG_E(PHY, "Invalid number of samples: %d\n", num_samples);
+        stop_meas(&time_manager_iq_stats);
+        return -1;
+    }
+    
+    // Update timestamp based on number of samples
+    // Each sample takes 1/sample_rate seconds
+    openair0_timestamp sample_time = (openair0_timestamp)(((double)num_samples / iq_sample_rate) * iq_sample_rate);
+    *timestamp = current_iq_timestamp;
+    current_iq_timestamp += sample_time;
+    
+    // Add some delay to simulate processing time if needed
+    // This is important for real-time IQ sample processing
+    struct timespec req;
+    req.tv_sec = 0;
+    req.tv_nsec = (long)((sample_time / iq_sample_rate) * 1e9);
+    
+    // Limit the delay to avoid excessive sleeping
+    if (req.tv_nsec > 1000000) { // 1ms
+        req.tv_nsec = 1000000;
+    }
+    
+    // Only sleep for small delays to maintain real-time performance
+    if (req.tv_nsec > 1000) { // 1us
+        nanosleep(&req, NULL);
+    }
+    
+    stop_meas(&time_manager_iq_stats);
+    
+    LOG_D(PHY, "Time manager processed %d IQ samples, timestamp: %lu\n", 
+          num_samples, (unsigned long)*timestamp);
+    
+    return 0; // Success
+}
+
+// Get time manager statistics
+void time_manager_get_stats(time_stats_t *stats) {
+    if (stats != NULL) {
+        copy_meas(stats, &time_manager_iq_stats);
+    }
+}
+
+// Reset time manager statistics
+void time_manager_reset_stats(void) {
+    reset_meas(&time_manager_iq_stats);
+}
+
+// Cleanup time manager
+void time_manager_cleanup(void) {
+    LOG_I(PHY, "Time manager cleanup\n");
+    reset_meas(&time_manager_iq_stats);
+    current_iq_timestamp = 0;
+}
