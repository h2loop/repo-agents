       Offset = 0;
     }
   }
+  // Get data in chronological order for plotting
+  void GetPlotData(const float*& xs, const float*& ys, int& count) const
+  {
+    if (Data.empty()) {
+      xs = nullptr;
+      ys = nullptr;
+      count = 0;
+      return;
+    }
+    
+    if (Data.size() < MaxSize) {
+      // Buffer not full, data is already in chronological order
+      xs = &Data[0].x;
+      ys = &Data[0].y;
+      count = Data.size();
+    } else {
+      // Buffer is full, data is circular
+      // We need to provide data in chronological order starting from Offset
+      static thread_local std::vector<ImVec2> plot_data;
+      plot_data.resize(MaxSize);
+      
+      // Copy data in chronological order
+      for (int i = 0; i < MaxSize; i++) {
+        int src_index = (Offset + i) % MaxSize;
+        plot_data[i] = Data[src_index];
+      }
+      
+      xs = &plot_data[0].x;
+      ys = &plot_data[0].y;
+      count = MaxSize;
+    }
+  }
 };
 
