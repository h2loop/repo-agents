+/* Find the opening parenthesis */
+char *name_start = strchr(pid_end, '(');
+if (name_start == NULL) {
+    prnt("Error: Invalid stat format, missing process name\n");
+    return;
+}
+
+/* Find the closing parenthesis */
+char *name_end = strrchr(name_start, ')');
+if (name_end == NULL) {
+    prnt("Error: Invalid stat format, missing closing parenthesis\n");
+    return;
+}
+
+/* Extract process name */
