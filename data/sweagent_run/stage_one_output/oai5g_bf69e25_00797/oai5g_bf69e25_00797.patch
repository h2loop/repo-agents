+    }
+    lptr += sprintf(lptr, "%20.20s ", "");
+}
+
+/* Continue parsing from after the closing parenthesis */
+char *remaining = name_end + 1;
+if (*remaining == ' ') remaining++; // Skip space after ')'
+
+/* Tokenize the rest of the fields */
+char *strtokptr;
+char *procfile_fields = strtok_r(remaining, " ", &strtokptr);
+fieldcnt = 2; // We've already handled PID and process name
