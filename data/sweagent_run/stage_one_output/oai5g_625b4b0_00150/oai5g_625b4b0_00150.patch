diff --git a/openair1/SIMULATION/LTE_PHY/signalanalyzer.c b/openair1/SIMULATION/LTE_PHY/signalanalyzer.c
index 62b0f93624..72992778b5 100644
--- a/openair1/SIMULATION/LTE_PHY/signalanalyzer.c
+++ b/openair1/SIMULATION/LTE_PHY/signalanalyzer.c
@@ -55,6 +55,12 @@ void analyzer(unsigned int gpib_card,unsigned int gpib_device,unsigned int freqb
 {
   char string[256];
 
+  // Check for valid parameters
+  if (frame_parms == NULL) {
+    printf("Error: frame_parms is NULL\n");
+    return;
+  }
+
   //Start the remote control
   gpib_send(gpib_card,gpib_device,"*RST;*CLS");   //reset and configure the signal analyzer
   gpib_send(gpib_card,gpib_device,"CONF:PRES");
@@ -74,7 +80,8 @@ void analyzer(unsigned int gpib_card,unsigned int gpib_device,unsigned int freqb
   gpib_send(gpib_card,gpib_device,"CONF:LDIR DL");
 
   //carrier frequency
-  gpib_send(gpib_card,gpib_device,"FREQ:CENT 1.2GHZ");
+  sprintf(string,"FREQ:CENT %u", frame_parms->dl_CarrierFreq);
+  gpib_send(gpib_card,gpib_device,string);
 
   //input source
   gpib_send(gpib_card,gpib_device,"INP RF");
@@ -95,6 +102,12 @@ void analyzer(unsigned int gpib_card,unsigned int gpib_device,unsigned int freqb
   //Identifies the configuration according to the data in the PDCCH DCIs
   gpib_send(gpib_card,gpib_device,"DL:FORM:PSCD PDCCH");
 
+  //Configure based on DCI allocation if provided
+  if (dci_alloc != NULL) {
+    sprintf(string,"DL:FORM:PSCD:RNTI %u", dci_alloc->rnti);
+    gpib_send(gpib_card,gpib_device,string);
+  }
+
   //sets the number of resource blocks to 25
   sprintf(string,"CONF:DL:NORB %d",frame_parms->N_RB_DL);
   gpib_send(gpib_card,gpib_device,string);
@@ -111,7 +124,7 @@ void analyzer(unsigned int gpib_card,unsigned int gpib_device,unsigned int freqb
   gpib_send(gpib_card,gpib_device,string);  //sets the UL/DL configuration into 3
 
   //Selects the configuration of a TDD special subframe
-  sprintf(string,"CONF:DL:TDD:UDC %d",frame_parms->tdd_config_S);
+  sprintf(string,"CONF:DL:TDD:SSC %d",frame_parms->tdd_config_S);
   gpib_send(gpib_card,gpib_device,string); //sets the special subframe configuration into 0
 
 
