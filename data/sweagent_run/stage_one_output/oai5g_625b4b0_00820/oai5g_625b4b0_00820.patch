+
+/* Positioning Measurement Failure Indication equality function */
+bool eq_f1ap_positioning_measurement_failure_indication(const f1ap_positioning_measurement_failure_indication_t *a,
+                                                        const f1ap_positioning_measurement_failure_indication_t *b)
+{
+  if (a == NULL || b == NULL)
+    return a == b;
+
+  _F1_EQ_CHECK_INT(a->transaction_id, b->transaction_id);
+  _F1_EQ_CHECK_INT(a->lmf_measurement_id, b->lmf_measurement_id);
+  _F1_EQ_CHECK_INT(a->ran_measurement_id, b->ran_measurement_id);
+  _F1_EQ_CHECK_INT(a->cause, b->cause);
+  _F1_EQ_CHECK_INT(a->cause_value, b->cause_value);
+
+  return true;
+}
+
+/* Positioning Measurement Failure Indication copy function */
+f1ap_positioning_measurement_failure_indication_t cp_f1ap_positioning_measurement_failure_indication(
+    const f1ap_positioning_measurement_failure_indication_t *msg)
+{
+  f1ap_positioning_measurement_failure_indication_t cp = {0};
+
+  if (msg == NULL)
+    return cp;
+
+  cp.transaction_id = msg->transaction_id;
+  cp.lmf_measurement_id = msg->lmf_measurement_id;
+  cp.ran_measurement_id = msg->ran_measurement_id;
+  cp.cause = msg->cause;
+  cp.cause_value = msg->cause_value;
+
+  return cp;
+}
+
+/* Positioning Measurement Failure Indication free function */
+void free_f1ap_positioning_measurement_failure_indication(const f1ap_positioning_measurement_failure_indication_t *msg)
+{
+  if (msg == NULL)
+    return;
+    
+  /* No dynamic memory to free in this structure */
+  (void)msg;
+}
