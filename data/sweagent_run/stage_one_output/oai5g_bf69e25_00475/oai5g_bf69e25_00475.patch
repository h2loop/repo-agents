+
+      if (result != EXIT_SUCCESS) {
+          LOG_I(RRC, "Failed to free memory (%d)!\n", result);
+        break;
+      }
+
+      break;
+
+    /* Messages from S1AP */
+    case S1AP_DOWNLINK_NAS:
+      rrc_eNB_process_S1AP_DOWNLINK_NAS(msg_p, msg_name_p, instance, &rrc_eNB_mui);
+      break;
+
+    case S1AP_INITIAL_CONTEXT_SETUP_REQ:
