+//-----------------------------------------------------------------------------
+void rrc_enb_process_itti_msg_one_shot(void) {
+  MessageDef                         *msg_p;
+  // Process all available messages without blocking
+  do {
+    itti_poll_msg(TASK_RRC_ENB, &msg_p);
+    if (msg_p) {
+      rrc_enb_process_one_itti_msg(msg_p);
+    }
+  } while(msg_p != NULL);
+}
