+/* Function to map RSRP/RSRQ to CQI value */
+static int _map_channel_quality_to_cqi(int rsrp, int rsrq)
+{
+  /* 
+   * Simple mapping based on typical LTE values:
+   * RSRP: 27 maps to medium quality (~-100 dBm)
+   * RSRQ: 55 maps to medium quality (~-10 dB)
+   * CQI range: 0-15 (0 worst, 15 best)
+   */
+  
+  /* Base CQI from RSRP (scale 0-15) */
+  int cqi_rsrp = 0;
+  if (rsrp <= 10) {
+    cqi_rsrp = 2;  /* Poor RSRP */
+  } else if (rsrp <= 20) {
+    cqi_rsrp = 6;  /* Fair RSRP */
+  } else if (rsrp <= 30) {
+    cqi_rsrp = 10; /* Good RSRP */
+  } else {
+    cqi_rsrp = 14; /* Excellent RSRP */
+  }
+  
+  /* Base CQI from RSRQ (scale 0-15) */
+  int cqi_rsrq = 0;
+  if (rsrq <= 30) {
+    cqi_rsrq = 2;  /* Poor RSRQ */
+  } else if (rsrq <= 45) {
+    cqi_rsrq = 6;  /* Fair RSRQ */
+  } else if (rsrq <= 60) {
+    cqi_rsrq = 10; /* Good RSRQ */
+  } else {
+    cqi_rsrq = 14; /* Excellent RSRQ */
+  }
+  
+  /* Combine both metrics (take the minimum as the limiting factor) */
+  int cqi = (cqi_rsrp < cqi_rsrq) ? cqi_rsrp : cqi_rsrq;
+  
+  /* Ensure CQI is within valid range */
+  if (cqi < 0) cqi = 0;
+  if (cqi > 15) cqi = 15;
+  
+  return cqi;
+}
+
+/* Function to map CQI to appropriate QCI based on channel quality */
+static int _map_cqi_to_qci(int cqi)
+{
+  /*
+   * Map CQI to QCI based on channel quality:
+   * - Higher CQI (better channel) -> Lower latency/better QoS requirements
+   * - Lower CQI (poorer channel) -> More tolerant QoS requirements
+   */
+   
+  if (cqi >= 12) {
+    /* Excellent channel quality - use QCI 1 (conversational voice) */
+    return 1;
+  } else if (cqi >= 8) {
+    /* Good channel quality - use QCI 2 (conversational video) */
+    return 2;
+  } else if (cqi >= 5) {
+    /* Medium channel quality - use QCI 3 (real-time gaming) */
+    return 3;
+  } else if (cqi >= 2) {
+    /* Fair channel quality - use QCI 4 (buffered streaming) */
+    return 4;
+  } else {
+    /* Poor channel quality - use QCI 5 (IMS signaling) or adaptive */
+    return 5;
+  }
+}
