+/****************************************************************************
+ **                                                                        **
+ ** Name:        _usim_api_ensure_directory()                              **
+ **                                                                        **
+ ** Description: Ensures that the directory for a given file path exists   **
+ **                                                                        **
+ ** Inputs:      filepath:      Full path to the file                      **
+ **              Others:        None                                       **
+ **                                                                        **
+ ** Outputs:     None                                                      **
+ **              Return:        RETURNerror, RETURNok                      **
+ **              Others:        None                                       **
+ **                                                                        **
+ ***************************************************************************/
+static int _usim_api_ensure_directory(const char *filepath)
+{
+  char *dirpath = NULL;
+  char *tmp = NULL;
+  struct stat st = {0};
+  int rc = RETURNok;
+
+  /* Make a copy of the filepath since dirname() may modify its argument */
+  tmp = strdup(filepath);
+  if (tmp == NULL) {
+    LOG_TRACE(ERROR, "USIM-API  - Failed to allocate memory for directory path");
+    return RETURNerror;
+  }
+
+  dirpath = dirname(tmp);
+
+  /* Check if directory exists */
+  if (stat(dirpath, &st) == -1) {
+    if (errno == ENOENT) {
+      /* Directory does not exist, try to create it */
+      if (mkdir(dirpath, 0755) == -1 && errno != EEXIST) {
+        LOG_TRACE(ERROR, "USIM-API  - Failed to create directory %s: %s", 
+                  dirpath, strerror(errno));
+        rc = RETURNerror;
+      }
+    } else {
+      LOG_TRACE(ERROR, "USIM-API  - Failed to stat directory %s: %s", 
+                dirpath, strerror(errno));
+      rc = RETURNerror;
+    }
+  } else if (!S_ISDIR(st.st_mode)) {
+    LOG_TRACE(ERROR, "USIM-API  - %s exists but is not a directory", dirpath);
+    rc = RETURNerror;
+  }
+
+  free(tmp);
+  return rc;
+}
+
