diff --git a/openair3/NAS/NR_UE/nr_nas_msg.c b/openair3/NAS/NR_UE/nr_nas_msg.c
index 615cc5a4f1..c023cbf432 100644
--- a/openair3/NAS/NR_UE/nr_nas_msg.c
+++ b/openair3/NAS/NR_UE/nr_nas_msg.c
@@ -1749,8 +1749,47 @@ static void generatePduSessionEstablishRequest(nr_ue_nas_t *nas, as_nas_info_t *
 
 static void send_nas_uplink_data_req(nr_ue_nas_t *nas, const as_nas_info_t *initial_nas_msg)
 {
-  MessageDef *msg = itti_alloc_new_message(TASK_NAS_NRUE, nas->UE_id, NAS_UPLINK_DATA_REQ);
-  ul_info_transfer_req_t *req = &NAS_UPLINK_DATA_REQ(msg);
+  // Check if this is a security-related message that should be sent with high priority
+  bool is_high_priority = false;
+  
+  if (initial_nas_msg->nas_data != NULL && initial_nas_msg->length > 0) {
+    uint8_t *data = initial_nas_msg->nas_data;
+    int length = initial_nas_msg->length;
+    
+    // Check if we have enough bytes to determine the message type
+    if (length >= 3) {
+      // Check security header type (byte 1)
+      uint8_t security_header_type = data[1] & 0x0f;
+      
+      if (security_header_type == 0) {
+        // Plain message - message type is in byte 2
+        uint8_t message_type = data[2];
+        if (message_type == FGS_SECURITY_MODE_COMPLETE || message_type == FGS_SECURITY_MODE_REJECT) {
+          is_high_priority = true;
+        }
+      } else {
+        // Security protected message - message type is in byte 9
+        if (length >= 10) {
+          uint8_t message_type = data[9];
+          if (message_type == FGS_SECURITY_MODE_COMPLETE || message_type == FGS_SECURITY_MODE_REJECT) {
+            is_high_priority = true;
+          }
+        }
+      }
+    }
+  }
+  
+  MessageDef *msg;
+  ul_info_transfer_req_t *req;
+  
+  if (is_high_priority) {
+    msg = itti_alloc_new_message(TASK_NAS_NRUE, nas->UE_id, NAS_UPLINK_DATA_REQ_HIGH_PRIORITY);
+    req = &NAS_UPLINK_DATA_REQ_HIGH_PRIORITY(msg);
+  } else {
+    msg = itti_alloc_new_message(TASK_NAS_NRUE, nas->UE_id, NAS_UPLINK_DATA_REQ);
+    req = &NAS_UPLINK_DATA_REQ(msg);
+  }
+  
   req->UEid = nas->UE_id;
   req->nasMsg.nas_data = (uint8_t *)initial_nas_msg->nas_data;
   req->nasMsg.length = initial_nas_msg->length;
