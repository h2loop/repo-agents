+/*! \file nfapi/open-nFAPI/fapi/src/nr_fapi_p7_utils.c
+ * \brief
+ * \author OpenAirInterface Software Alliance
+ * \date 2024
+ * \version 0.1
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ * \note
+ * \warning
+ */
+
+#include "nr_fapi_p7_utils.h"
+#include "nr_fapi.h"
+#include <stdlib.h>
+#include <string.h>
+
+void copy_uci_indication_PUSCH(const nfapi_nr_uci_pusch_pdu_t *src, nfapi_nr_uci_pusch_pdu_t *dst)
+{
+  if (!src || !dst) {
+    return;
+  }
+
+  // Copy basic fields
+  dst->pduBitmap = src->pduBitmap;
+  dst->handle = src->handle;
+  dst->rnti = src->rnti;
+  dst->ul_cqi = src->ul_cqi;
+  dst->timing_advance = src->timing_advance;
+  dst->rssi = src->rssi;
+
+  // Copy HARQ information
+  dst->harq.harq_crc = src->harq.harq_crc;
+  dst->harq.harq_bit_len = src->harq.harq_bit_len;
+  // For harq_payload, we need to allocate memory and copy the data
+  if (src->harq.harq_payload && src->harq.harq_bit_len > 0) {
+    int payload_size = (src->harq.harq_bit_len + 7) / 8; // Convert bits to bytes
+    dst->harq.harq_payload = (uint8_t*)malloc(payload_size);
+    if (dst->harq.harq_payload) {
+      memcpy(dst->harq.harq_payload, src->harq.harq_payload, payload_size);
+    }
+  } else {
+    dst->harq.harq_payload = NULL;
+  }
+
+  // Copy CSI Part 1 information
+  dst->csi_part1.csi_part1_crc = src->csi_part1.csi_part1_crc;
+  dst->csi_part1.csi_part1_bit_len = src->csi_part1.csi_part1_bit_len;
+  // For csi_part1_payload, we need to allocate memory and copy the data
+  if (src->csi_part1.csi_part1_payload && src->csi_part1.csi_part1_bit_len > 0) {
+    int payload_size = (src->csi_part1.csi_part1_bit_len + 7) / 8; // Convert bits to bytes
+    dst->csi_part1.csi_part1_payload = (uint8_t*)malloc(payload_size);
+    if (dst->csi_part1.csi_part1_payload) {
+      memcpy(dst->csi_part1.csi_part1_payload, src->csi_part1.csi_part1_payload, payload_size);
+    }
+  } else {
+    dst->csi_part1.csi_part1_payload = NULL;
+  }
+
+  // Copy CSI Part 2 information
+  dst->csi_part2.csi_part2_crc = src->csi_part2.csi_part2_crc;
+  dst->csi_part2.csi_part2_bit_len = src->csi_part2.csi_part2_bit_len;
+  // For csi_part2_payload, we need to allocate memory and copy the data
+  if (src->csi_part2.csi_part2_payload && src->csi_part2.csi_part2_bit_len > 0) {
+    int payload_size = (src->csi_part2.csi_part2_bit_len + 7) / 8; // Convert bits to bytes
+    dst->csi_part2.csi_part2_payload = (uint8_t*)malloc(payload_size);
+    if (dst->csi_part2.csi_part2_payload) {
+      memcpy(dst->csi_part2.csi_part2_payload, src->csi_part2.csi_part2_payload, payload_size);
+    }
+  } else {
+    dst->csi_part2.csi_part2_payload = NULL;
+  }
+}
+
+void free_uci_indication_PUSCH(nfapi_nr_uci_pusch_pdu_t *uci_pusch_pdu)
+{
+  if (!uci_pusch_pdu) {
+    return;
+  }
+
+  // Free HARQ payload if allocated
+  if (uci_pusch_pdu->harq.harq_payload) {
+    free(uci_pusch_pdu->harq.harq_payload);
+    uci_pusch_pdu->harq.harq_payload = NULL;
+  }
+
+  // Free CSI Part 1 payload if allocated
+  if (uci_pusch_pdu->csi_part1.csi_part1_payload) {
+    free(uci_pusch_pdu->csi_part1.csi_part1_payload);
+    uci_pusch_pdu->csi_part1.csi_part1_payload = NULL;
+  }
+
+  // Free CSI Part 2 payload if allocated
+  if (uci_pusch_pdu->csi_part2.csi_part2_payload) {
+    free(uci_pusch_pdu->csi_part2.csi_part2_payload);
+    uci_pusch_pdu->csi_part2.csi_part2_payload = NULL;
+  }
+}
+
+void copy_uci_indication_entry(const nfapi_nr_uci_t *src, nfapi_nr_uci_t *dst)
+{
+  if (!src || !dst) {
+    return;
+  }
+
+  // Copy basic fields
+  dst->pdu_type = src->pdu_type;
+  dst->pdu_size = src->pdu_size;
+
+  // Handle different PDU types
+  switch (src->pdu_type) {
+    case NFAPI_NR_UCI_PUSCH_PDU_TYPE: {
+      copy_uci_indication_PUSCH(&src->pusch_pdu, &dst->pusch_pdu);
+      break;
+    }
+    case NFAPI_NR_UCI_FORMAT_0_1_PDU_TYPE: {
+      // For PUCCH Format 0/1, copy the structure directly since it doesn't seem to have dynamic payloads
+      dst->pucch_pdu_format_0_1 = src->pucch_pdu_format_0_1;
+      break;
+    }
+    case NFAPI_NR_UCI_FORMAT_2_3_4_PDU_TYPE: {
+      // For PUCCH Format 2/3/4, copy basic fields
+      dst->pucch_pdu_format_2_3_4.pduBitmap = src->pucch_pdu_format_2_3_4.pduBitmap;
+      dst->pucch_pdu_format_2_3_4.handle = src->pucch_pdu_format_2_3_4.handle;
+      dst->pucch_pdu_format_2_3_4.rnti = src->pucch_pdu_format_2_3_4.rnti;
+      dst->pucch_pdu_format_2_3_4.pucch_format = src->pucch_pdu_format_2_3_4.pucch_format;
+      dst->pucch_pdu_format_2_3_4.ul_cqi = src->pucch_pdu_format_2_3_4.ul_cqi;
+      dst->pucch_pdu_format_2_3_4.timing_advance = src->pucch_pdu_format_2_3_4.timing_advance;
+      dst->pucch_pdu_format_2_3_4.rssi = src->pucch_pdu_format_2_3_4.rssi;
+
+      // Copy SR information
+      dst->pucch_pdu_format_2_3_4.sr.sr_crc = src->pucch_pdu_format_2_3_4.sr.sr_crc;
+      dst->pucch_pdu_format_2_3_4.sr.sr_bit_len = src->pucch_pdu_format_2_3_4.sr.sr_bit_len;
+      if (src->pucch_pdu_format_2_3_4.sr.sr_payload && src->pucch_pdu_format_2_3_4.sr.sr_bit_len > 0) {
+        int payload_size = (src->pucch_pdu_format_2_3_4.sr.sr_bit_len + 7) / 8;
+        dst->pucch_pdu_format_2_3_4.sr.sr_payload = (uint8_t*)malloc(payload_size);
+        if (dst->pucch_pdu_format_2_3_4.sr.sr_payload) {
+          memcpy(dst->pucch_pdu_format_2_3_4.sr.sr_payload, src->pucch_pdu_format_2_3_4.sr.sr_payload, payload_size);
+        }
+      } else {
+        dst->pucch_pdu_format_2_3_4.sr.sr_payload = NULL;
+      }
+
+      // Copy HARQ information
+      dst->pucch_pdu_format_2_3_4.harq.harq_crc = src->pucch_pdu_format_2_3_4.harq.harq_crc;
+      dst->pucch_pdu_format_2_3_4.harq.harq_bit_len = src->pucch_pdu_format_2_3_4.harq.harq_bit_len;
+      if (src->pucch_pdu_format_2_3_4.harq.harq_payload && src->pucch_pdu_format_2_3_4.harq.harq_bit_len > 0) {
+        int payload_size = (src->pucch_pdu_format_2_3_4.harq.harq_bit_len + 7) / 8;
+        dst->pucch_pdu_format_2_3_4.harq.harq_payload = (uint8_t*)malloc(payload_size);
+        if (dst->pucch_pdu_format_2_3_4.harq.harq_payload) {
+          memcpy(dst->pucch_pdu_format_2_3_4.harq.harq_payload, src->pucch_pdu_format_2_3_4.harq.harq_payload, payload_size);
+        }
+      } else {
+        dst->pucch_pdu_format_2_3_4.harq.harq_payload = NULL;
+      }
+
+      // Copy CSI Part 1 information
+      dst->pucch_pdu_format_2_3_4.csi_part1.csi_part1_crc = src->pucch_pdu_format_2_3_4.csi_part1.csi_part1_crc;
+      dst->pucch_pdu_format_2_3_4.csi_part1.csi_part1_bit_len = src->pucch_pdu_format_2_3_4.csi_part1.csi_part1_bit_len;
+      if (src->pucch_pdu_format_2_3_4.csi_part1.csi_part1_payload && src->pucch_pdu_format_2_3_4.csi_part1.csi_part1_bit_len > 0) {
+        int payload_size = (src->pucch_pdu_format_2_3_4.csi_part1.csi_part1_bit_len + 7) / 8;
+        dst->pucch_pdu_format_2_3_4.csi_part1.csi_part1_payload = (uint8_t*)malloc(payload_size);
+        if (dst->pucch_pdu_format_2_3_4.csi_part1.csi_part1_payload) {
+          memcpy(dst->pucch_pdu_format_2_3_4.csi_part1.csi_part1_payload, src->pucch_pdu_format_2_3_4.csi_part1.csi_part1_payload, payload_size);
+        }
+      } else {
+        dst->pucch_pdu_format_2_3_4.csi_part1.csi_part1_payload = NULL;
+      }
+
+      // Copy CSI Part 2 information
+      dst->pucch_pdu_format_2_3_4.csi_part2.csi_part2_crc = src->pucch_pdu_format_2_3_4.csi_part2.csi_part2_crc;
+      dst->pucch_pdu_format_2_3_4.csi_part2.csi_part2_bit_len = src->pucch_pdu_format_2_3_4.csi_part2.csi_part2_bit_len;
+      if (src->pucch_pdu_format_2_3_4.csi_part2.csi_part2_payload && src->pucch_pdu_format_2_3_4.csi_part2.csi_part2_bit_len > 0) {
+        int payload_size = (src->pucch_pdu_format_2_3_4.csi_part2.csi_part2_bit_len + 7) / 8;
+        dst->pucch_pdu_format_2_3_4.csi_part2.csi_part2_payload = (uint8_t*)malloc(payload_size);
+        if (dst->pucch_pdu_format_2_3_4.csi_part2.csi_part2_payload) {
+          memcpy(dst->pucch_pdu_format_2_3_4.csi_part2.csi_part2_payload, src->pucch_pdu_format_2_3_4.csi_part2.csi_part2_payload, payload_size);
+        }
+      } else {
+        dst->pucch_pdu_format_2_3_4.csi_part2.csi_part2_payload = NULL;
+      }
+      break;
+    }
+    default:
+      // Unknown PDU type, just copy the union as-is
+      dst->pusch_pdu = src->pusch_pdu; // This will copy whatever is in the union
+      break;
+  }
+}
+
+void free_uci_indication_entry(nfapi_nr_uci_t *uci_entry)
+{
+  if (!uci_entry) {
+    return;
+  }
+
+  // Handle different PDU types
+  switch (uci_entry->pdu_type) {
+    case NFAPI_NR_UCI_PUSCH_PDU_TYPE: {
+      free_uci_indication_PUSCH(&uci_entry->pusch_pdu);
+      break;
+    }
+    case NFAPI_NR_UCI_FORMAT_0_1_PDU_TYPE: {
+      // For PUCCH Format 0/1, no dynamic memory to free
+      break;
+    }
+    case NFAPI_NR_UCI_FORMAT_2_3_4_PDU_TYPE: {
+      // Free SR payload if allocated
+      if (uci_entry->pucch_pdu_format_2_3_4.sr.sr_payload) {
+        free(uci_entry->pucch_pdu_format_2_3_4.sr.sr_payload);
+        uci_entry->pucch_pdu_format_2_3_4.sr.sr_payload = NULL;
+      }
+
+      // Free HARQ payload if allocated
+      if (uci_entry->pucch_pdu_format_2_3_4.harq.harq_payload) {
+        free(uci_entry->pucch_pdu_format_2_3_4.harq.harq_payload);
+        uci_entry->pucch_pdu_format_2_3_4.harq.harq_payload = NULL;
+      }
+
+      // Free CSI Part 1 payload if allocated
+      if (uci_entry->pucch_pdu_format_2_3_4.csi_part1.csi_part1_payload) {
+        free(uci_entry->pucch_pdu_format_2_3_4.csi_part1.csi_part1_payload);
+        uci_entry->pucch_pdu_format_2_3_4.csi_part1.csi_part1_payload = NULL;
+      }
+
+      // Free CSI Part 2 payload if allocated
+      if (uci_entry->pucch_pdu_format_2_3_4.csi_part2.csi_part2_payload) {
+        free(uci_entry->pucch_pdu_format_2_3_4.csi_part2.csi_part2_payload);
+        uci_entry->pucch_pdu_format_2_3_4.csi_part2.csi_part2_payload = NULL;
+      }
+      break;
+    }
+    default:
+      // Unknown PDU type, nothing to free
+      break;
+  }
+}
+
+void copy_uci_indication(const nfapi_nr_uci_indication_t *src, nfapi_nr_uci_indication_t *dst)
+{
+  if (!src || !dst) {
+    return;
+  }
+
+  // Copy header
+  dst->header = src->header;
+  
+  // Copy basic fields
+  dst->sfn = src->sfn;
+  dst->slot = src->slot;
+  dst->num_ucis = src->num_ucis;
+
+  // Allocate memory for UCI list
+  if (src->num_ucis > 0 && src->uci_list) {
+    dst->uci_list = (nfapi_nr_uci_t*)calloc(src->num_ucis, sizeof(nfapi_nr_uci_t));
+    if (dst->uci_list) {
+      // Copy each UCI entry
+      for (int i = 0; i < src->num_ucis; i++) {
+        copy_uci_indication_entry(&src->uci_list[i], &dst->uci_list[i]);
+      }
+    }
+  } else {
+    dst->uci_list = NULL;
+  }
+}
+
+void free_uci_indication(nfapi_nr_uci_indication_t *uci_ind)
+{
+  if (!uci_ind) {
+    return;
+  }
+
+  // Free each UCI entry
+  if (uci_ind->uci_list && uci_ind->num_ucis > 0) {
+    for (int i = 0; i < uci_ind->num_ucis; i++) {
+      free_uci_indication_entry(&uci_ind->uci_list[i]);
+    }
+    free(uci_ind->uci_list);
+    uci_ind->uci_list = NULL;
+  }
+  
+  uci_ind->num_ucis = 0;
+}
