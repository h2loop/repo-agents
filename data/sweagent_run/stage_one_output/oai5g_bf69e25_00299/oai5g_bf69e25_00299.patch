+/*! \file nfapi/open-nFAPI/fapi/inc/nr_fapi_p7_utils.h
+ * \brief
+ * \author OpenAirInterface Software Alliance
+ * \date 2024
+ * \version 0.1
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ * \note
+ * \warning
+ */
+
+#ifndef OPENAIRINTERFACE_NR_FAPI_P7_UTILS_H
+#define OPENAIRINTERFACE_NR_FAPI_P7_UTILS_H
+
+#include "stdio.h"
+#include "stdint.h"
+#include "nr_fapi.h"
+#include "nfapi/oai_integration/vendor_ext.h"
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/**
+ * @brief Copy UCI indication for PUSCH PDU
+ * This function copies the UCI indication data specifically for PUSCH from source to destination
+ * 
+ * @param src Source UCI PUSCH PDU structure
+ * @param dst Destination UCI PUSCH PDU structure
+ * @return void
+ */
+void copy_uci_indication_PUSCH(const nfapi_nr_uci_pusch_pdu_t *src, nfapi_nr_uci_pusch_pdu_t *dst);
+
+/**
+ * @brief Free allocated memory in UCI indication for PUSCH PDU
+ * This function frees the dynamically allocated memory in the UCI PUSCH PDU structure
+ * 
+ * @param uci_pusch_pdu UCI PUSCH PDU structure to free
+ * @return void
+ */
+void free_uci_indication_PUSCH(nfapi_nr_uci_pusch_pdu_t *uci_pusch_pdu);
+
+/**
+ * @brief Copy a single UCI indication entry
+ * This function copies a single UCI indication entry, handling the different PDU types properly
+ * 
+ * @param src Source UCI indication entry
+ * @param dst Destination UCI indication entry
+ * @return void
+ */
+void copy_uci_indication_entry(const nfapi_nr_uci_t *src, nfapi_nr_uci_t *dst);
+
+/**
+ * @brief Free allocated memory in a single UCI indication entry
+ * This function frees the dynamically allocated memory in a UCI indication entry
+ * 
+ * @param uci_entry UCI indication entry to free
+ * @return void
+ */
+void free_uci_indication_entry(nfapi_nr_uci_t *uci_entry);
+
+/**
+ * @brief Copy entire UCI indication message
+ * This function copies the entire UCI indication message, including all entries
+ * 
+ * @param src Source UCI indication message
+ * @param dst Destination UCI indication message
+ * @return void
+ */
+void copy_uci_indication(const nfapi_nr_uci_indication_t *src, nfapi_nr_uci_indication_t *dst);
+
+/**
+ * @brief Free allocated memory in UCI indication message
+ * This function frees the dynamically allocated memory in the UCI indication message
+ * 
+ * @param uci_ind UCI indication message to free
+ * @return void
+ */
+void free_uci_indication(nfapi_nr_uci_indication_t *uci_ind);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif // OPENAIRINTERFACE_NR_FAPI_P7_UTILS_H
