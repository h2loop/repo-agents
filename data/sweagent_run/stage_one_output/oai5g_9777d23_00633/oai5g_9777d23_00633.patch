diff --git a/openair3/NAS/NR_UE/5GS/5GMM/MSG/fgs_service_request.c b/openair3/NAS/NR_UE/5GS/5GMM/MSG/fgs_service_request.c
index 4603db55c5..95b14d5074 100644
--- a/openair3/NAS/NR_UE/5GS/5GMM/MSG/fgs_service_request.c
+++ b/openair3/NAS/NR_UE/5GS/5GMM/MSG/fgs_service_request.c
@@ -70,6 +70,11 @@ int decode_fgs_service_request(fgs_service_request_msg_t *sr, const uint8_t *buf
 {
   uint32_t decoded = 0;
   int decoded_rc = 0;
+  uint16_t mobile_id_len = 0;
+
+  // Check minimum length
+  if (len < MIN_LEN_FGS_SERVICE_REQUEST)
+    return -1;
 
   // Service type (1/2 octet) (M)
   sr->serviceType = *buffer & 0x0f;
@@ -78,10 +83,24 @@ int decode_fgs_service_request(fgs_service_request_msg_t *sr, const uint8_t *buf
     return decoded_rc;
   }
   decoded++;
+  len -= decoded;
 
   // 5GS Mobile Identity (M) type 5G-S-TMSI (9 octets) (M)
-  decoded += LEN_FGS_MOBILE_ID_CONTENTS_SIZE; // skip "Length of 5GS mobile identity contents" IE
-  if ((decoded_rc = decode_stmsi_5gs_mobile_identity(&sr->fiveg_s_tmsi, buffer + decoded, len - decoded)) < 0) {
+  // Read "Length of 5GS mobile identity contents" IE (2 octets)
+  if (len < LEN_FGS_MOBILE_ID_CONTENTS_SIZE) {
+    return -1;
+  }
+  memcpy(&mobile_id_len, buffer + decoded, sizeof(mobile_id_len));
+  mobile_id_len = ntohs(mobile_id_len);
+  decoded += LEN_FGS_MOBILE_ID_CONTENTS_SIZE;
+  len -= LEN_FGS_MOBILE_ID_CONTENTS_SIZE;
+  
+  // Validate that we have enough data for the mobile identity
+  if (len < mobile_id_len) {
+    return -1;
+  }
+  
+  if ((decoded_rc = decode_stmsi_5gs_mobile_identity(&sr->fiveg_s_tmsi, buffer + decoded, len)) < 0) {
     return decoded_rc;
   }
   decoded += decoded_rc;
