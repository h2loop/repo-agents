+#ifndef F1AP_POSITIONING_H_
+#define F1AP_POSITIONING_H_
+
+#include <stdint.h>
+#include <stdbool.h>
+
+// Forward declarations for ASN.1 types
+typedef struct F1AP_TRPInformationTypeResponseItem F1AP_TRPInformationTypeResponseItem_t;
+typedef long F1AP_NRPCI_t;
+typedef struct F1AP_NRCGI F1AP_NRCGI_t;
+typedef struct F1AP_PRSConfiguration F1AP_PRSConfiguration_t;
+typedef struct F1AP_SSBInformation F1AP_SSBInformation_t;
+typedef long F1AP_SFNInitialisationTime_t;
+typedef struct F1AP_SpatialDirectionInformation F1AP_SpatialDirectionInformation_t;
+typedef struct F1AP_GeographicalCoordinates F1AP_GeographicalCoordinates_t;
+typedef struct F1AP_ProtocolIE_SingleContainer F1AP_ProtocolIE_SingleContainer_t;
+
+// Enum to represent the present field in the choice based on ASN.1 definition
+typedef enum {
+  F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_NOTHING,
+  F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_pCI_NR,
+  F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_nG_RAN_CGI,
+  F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_nRARFCN,
+  F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_pRSConfiguration,
+  F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_sSBinformation,
+  F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_sFNInitialisationTime,
+  F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_spatialDirectionInformation,
+  F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_geographicalCoordinates,
+  F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_choice_extension
+} f1ap_trp_info_type_response_item_present_t;
+
+// Structure to represent TRP information type response item
+// Based on ASN.1 definition:
+// TRPInformationTypeResponseItem ::= CHOICE {
+//   pCI-NR                              NRPCI,
+//   nG-RAN-CGI                          NRCGI,
+//   nRARFCN                             INTEGER (0..maxNRARFCN),
+//   pRSConfiguration                    PRSConfiguration,
+//   sSBinformation                      SSBInformation,
+//   sFNInitialisationTime               SFNInitialisationTime,
+//   spatialDirectionInformation         SpatialDirectionInformation,
+//   geographicalCoordinates             GeographicalCoordinates,
+//   choice-extension                    ProtocolIE-SingleContainer { { TRPInformationTypeResponseItem-ExtIEs} }
+// }
+typedef struct {
+  f1ap_trp_info_type_response_item_present_t present;
+  union {
+    F1AP_NRPCI_t pCI_NR;  // NRPCI type
+    F1AP_NRCGI_t nG_RAN_CGI;
+    long nRARFCN;
+    F1AP_PRSConfiguration_t pRSConfiguration;
+    F1AP_SSBInformation_t sSBinformation;
+    F1AP_SFNInitialisationTime_t sFNInitialisationTime;
+    F1AP_SpatialDirectionInformation_t spatialDirectionInformation;
+    F1AP_GeographicalCoordinates_t geographicalCoordinates;
+    F1AP_ProtocolIE_SingleContainer_t choice_extension;
+  } choice;
+} f1ap_trp_info_type_response_item_t;
+
+// Function declarations
+F1AP_TRPInformationTypeResponseItem_t encode_trp_info_type_response_item(
+    const f1ap_trp_info_type_response_item_t *trp_info_item);
+
+#endif /* F1AP_POSITIONING_H_ */
