+/*! \file f1ap_positioning.c
+ * \brief F1AP positioning procedures for TRP information
+ * \author Javier Morgade
+ * \date 2024
+ * \version 1.0
+ * \company CTT Group
+ * \email: javier.morgade@ieee.org
+ */
+
+#include "f1ap_positioning.h"
+#include "f1ap_lib_common.h"
+#include "f1ap_messages_types.h"
+#include "common/utils/LOG/log.h"
+#include <string.h>
+
+// Include ASN.1 generated TRP-related headers
+#include "F1AP_TRPInformationTypeResponseItem.h"
+#include "F1AP_NRPCI.h"
+#include "F1AP_NRCGI.h"
+#include "F1AP_PRSConfiguration.h"
+#include "F1AP_SSBInformation.h"
+#include "F1AP_SFNInitialisationTime.h"
+#include "F1AP_SpatialDirectionInformation.h"
+#include "F1AP_GeographicalCoordinates.h"
+#include "F1AP_ProtocolIE-SingleContainer.h"
+
+// Helper function to copy ASN.1 structures (following the pattern from existing code)
+static void copy_nrcgi(F1AP_NRCGI_t *dest, const F1AP_NRCGI_t *src)
+{
+  if (dest && src) {
+    // Copy PLMN Identity
+    memcpy(&dest->pLMN_Identity, &src->pLMN_Identity, sizeof(dest->pLMN_Identity));
+    // Copy NR Cell Identity
+    memcpy(&dest->nRCellIdentity, &src->nRCellIdentity, sizeof(dest->nRCellIdentity));
+    // Copy extensions if present
+    if (src->iE_Extensions) {
+      dest->iE_Extensions = src->iE_Extensions; // Shallow copy for now
+    }
+  }
+}
+
+F1AP_TRPInformationTypeResponseItem_t encode_trp_info_type_response_item(
+    const f1ap_trp_info_type_response_item_t *trp_info_item)
+{
+  F1AP_TRPInformationTypeResponseItem_t enc = {0};
+
+  if (!trp_info_item) {
+    LOG_E(F1AP, "NULL TRP information type response item provided\n");
+    return enc;
+  }
+
+  switch (trp_info_item->present) {
+    case F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_pCI_NR:
+      enc.present = F1AP_TRPInformationTypeResponseItem_PR_pCI_NR;
+      enc.choice.pCI_NR = trp_info_item->choice.pCI_NR;
+      break;
+
+    case F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_nG_RAN_CGI:
+      enc.present = F1AP_TRPInformationTypeResponseItem_PR_nG_RAN_CGI;
+      // For now, do a shallow copy - in a real implementation this would need proper ASN.1 structure handling
+      enc.choice.nG_RAN_CGI = trp_info_item->choice.nG_RAN_CGI;
+      break;
+
+    case F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_nRARFCN:
+      enc.present = F1AP_TRPInformationTypeResponseItem_PR_nRARFCN;
+      enc.choice.nRARFCN = trp_info_item->choice.nRARFCN;
+      break;
+
+    case F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_pRSConfiguration:
+      enc.present = F1AP_TRPInformationTypeResponseItem_PR_pRSConfiguration;
+      // Shallow copy for now - would need proper ASN.1 structure handling in real implementation
+      enc.choice.pRSConfiguration = trp_info_item->choice.pRSConfiguration;
+      break;
+
+    case F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_sSBinformation:
+      enc.present = F1AP_TRPInformationTypeResponseItem_PR_sSBinformation;
+      // Shallow copy for now - would need proper ASN.1 structure handling in real implementation
+      enc.choice.sSBinformation = trp_info_item->choice.sSBinformation;
+      break;
+
+    case F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_sFNInitialisationTime:
+      enc.present = F1AP_TRPInformationTypeResponseItem_PR_sFNInitialisationTime;
+      enc.choice.sFNInitialisationTime = trp_info_item->choice.sFNInitialisationTime;
+      break;
+
+    case F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_spatialDirectionInformation:
+      enc.present = F1AP_TRPInformationTypeResponseItem_PR_spatialDirectionInformation;
+      // Shallow copy for now - would need proper ASN.1 structure handling in real implementation
+      enc.choice.spatialDirectionInformation = trp_info_item->choice.spatialDirectionInformation;
+      break;
+
+    case F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_geographicalCoordinates:
+      enc.present = F1AP_TRPInformationTypeResponseItem_PR_geographicalCoordinates;
+      // Shallow copy for now - would need proper ASN.1 structure handling in real implementation
+      enc.choice.geographicalCoordinates = trp_info_item->choice.geographicalCoordinates;
+      break;
+
+    case F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_choice_extension:
+      enc.present = F1AP_TRPInformationTypeResponseItem_PR_choice_extension;
+      // Shallow copy for now - would need proper ASN.1 structure handling in real implementation
+      enc.choice.choice_extension = trp_info_item->choice.choice_extension;
+      break;
+
+    case F1AP_TRP_INFO_TYPE_RESPONSE_ITEM_PR_NOTHING:
+    default:
+      LOG_W(F1AP, "Unknown or unspecified TRP information type response item %d\n", trp_info_item->present);
+      enc.present = F1AP_TRPInformationTypeResponseItem_PR_NOTHING;
+      break;
+  }
+
+  return enc;
+}
