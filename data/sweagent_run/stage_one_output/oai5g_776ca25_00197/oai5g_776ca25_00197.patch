+/*! \file f1ap_lib_common.c
+ * \brief F1AP library common functions
+ * \author OpenAirInterface Software Alliance
+ * \date 2024
+ * \version 0.1
+ * \company OpenAirInterface Software Alliance
+ * \email: contact@openairinterface.org
+ * \note
+ * \warning
+ */
+
+#include "f1ap_messages_types.h"
+#include "f1ap_common.h"
+#include <pthread.h>
+#include <string.h>
+
+extern f1ap_cudu_inst_t *getCxt(instance_t instanceP);
+
+bool eq_f1ap_cell_info(const f1ap_served_cell_info_t *cell1, const f1ap_served_cell_info_t *cell2)
+{
+  if (cell1 == NULL || cell2 == NULL) {
+    return cell1 == cell2;
+  }
+
+  // Compare basic fields
+  if (cell1->plmn.mcc != cell2->plmn.mcc ||
+      cell1->plmn.mnc != cell2->plmn.mnc ||
+      cell1->plmn.mnc_digit_length != cell2->plmn.mnc_digit_length ||
+      cell1->nr_cellid != cell2->nr_cellid ||
+      cell1->nr_pci != cell2->nr_pci ||
+      cell1->num_ssi != cell2->num_ssi ||
+      cell1->mode != cell2->mode) {
+    return false;
+  }
+
+  // Compare TAC if both are present
+  if (cell1->tac != NULL && cell2->tac != NULL) {
+    if (*cell1->tac != *cell2->tac) {
+      return false;
+    }
+  } else if (cell1->tac != cell2->tac) {
+    // One is NULL and the other is not
+    return false;
+  }
+
+  // Compare NSSAI
+  for (int i = 0; i < cell1->num_ssi && i < 16; i++) {
+    if (cell1->nssai[i].sst != cell2->nssai[i].sst) {
+      return false;
+    }
+    // Compare SD if both are present
+    if (cell1->nssai[i].sd != NULL && cell2->nssai[i].sd != NULL) {
+      if (memcmp(cell1->nssai[i].sd, cell2->nssai[i].sd, 3) != 0) {
+        return false;
+      }
+    } else if (cell1->nssai[i].sd != cell2->nssai[i].sd) {
+      // One is NULL and the other is not
+      return false;
+    }
+  }
+
+  // Compare mode-specific information
+  if (cell1->mode == F1AP_MODE_FDD) {
+    if (cell1->fdd.ul_freqinfo.arfcn != cell2->fdd.ul_freqinfo.arfcn ||
+        cell1->fdd.ul_freqinfo.band != cell2->fdd.ul_freqinfo.band ||
+        cell1->fdd.dl_freqinfo.arfcn != cell2->fdd.dl_freqinfo.arfcn ||
+        cell1->fdd.dl_freqinfo.band != cell2->fdd.dl_freqinfo.band ||
+        cell1->fdd.ul_tbw.scs != cell2->fdd.ul_tbw.scs ||
+        cell1->fdd.ul_tbw.nrb != cell2->fdd.ul_tbw.nrb ||
+        cell1->fdd.dl_tbw.scs != cell2->fdd.dl_tbw.scs ||
+        cell1->fdd.dl_tbw.nrb != cell2->fdd.dl_tbw.nrb) {
+      return false;
+    }
+  } else if (cell1->mode == F1AP_MODE_TDD) {
+    if (cell1->tdd.freqinfo.arfcn != cell2->tdd.freqinfo.arfcn ||
+        cell1->tdd.freqinfo.band != cell2->tdd.freqinfo.band ||
+        cell1->tdd.tbw.scs != cell2->tdd.tbw.scs ||
+        cell1->tdd.tbw.nrb != cell2->tdd.tbw.nrb) {
+      return false;
+    }
+  }
+
+  // Compare measurement timing configuration
+  if (cell1->measurement_timing_config_len != cell2->measurement_timing_config_len) {
+    return false;
+  }
+  if (cell1->measurement_timing_config_len > 0 && cell1->measurement_timing_config != NULL && cell2->measurement_timing_config != NULL) {
+    if (memcmp(cell1->measurement_timing_config, cell2->measurement_timing_config, cell1->measurement_timing_config_len) != 0) {
+      return false;
+    }
+  } else if ((cell1->measurement_timing_config != NULL) != (cell2->measurement_timing_config != NULL)) {
+    // One is NULL and the other is not
+    return false;
+  }
+
+  return true;
+}
