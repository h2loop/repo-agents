+static inline int64_t time_now_us(void)
+{
+  struct timespec t;
+  if (clock_gettime(CLOCK_REALTIME, &t)) {
+    return -1; // Error case
+  }
+  return (int64_t)t.tv_sec * 1000000LL + t.tv_nsec / 1000LL;
