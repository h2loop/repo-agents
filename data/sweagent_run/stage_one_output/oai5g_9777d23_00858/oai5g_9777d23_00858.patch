+/* ====================================
+ *      Positioning Information Response
+ * ==================================== */
+
+/**
+ * @brief Positioning Information Response encoding
+ */
+F1AP_F1AP_PDU_t *encode_f1ap_positioning_information_response(const f1ap_positioning_information_response_t *msg)
+{
+  F1AP_F1AP_PDU_t *pdu = calloc_or_fail(1, sizeof(*pdu));
+  /* Create */
+  /* 0. Message Type */
+  asn1cCalloc(pdu->choice.successfulOutcome, SuccessfulOutcome);
+  pdu->present = F1AP_F1AP_PDU_PR_successfulOutcome;
+  SuccessfulOutcome->procedureCode = F1AP_ProcedureCode_id_PositioningInformationExchange;
+  SuccessfulOutcome->criticality = F1AP_Criticality_reject;
+  SuccessfulOutcome->value.present = F1AP_SuccessfulOutcome__value_PR_PositioningInformationResponse;
+  F1AP_PositioningInformationResponse_t *out = &pdu->choice.successfulOutcome->value.choice.PositioningInformationResponse;
+  
+  /* mandatory */
+  /* c1. GNB-CU-UE-F1AP-ID (integer value)*/
+  asn1cSequenceAdd(out->protocolIEs.list, F1AP_PositioningInformationResponseIEs_t, ie1);
+  ie1->id = F1AP_ProtocolIE_ID_id_gNB_CU_UE_F1AP_ID;
+  ie1->criticality = F1AP_Criticality_reject;
+  ie1->value.present = F1AP_PositioningInformationResponseIEs__value_PR_GNB_CU_UE_F1AP_ID;
+  ie1->value.choice.GNB_CU_UE_F1AP_ID = msg->gNB_CU_ue_id;
+  
+  /* mandatory */
+  /* c2. GNB-DU-UE-F1AP-ID (integer value)*/
+  asn1cSequenceAdd(out->protocolIEs.list, F1AP_PositioningInformationResponseIEs_t, ie2);
+  ie2->id = F1AP_ProtocolIE_ID_id_gNB_DU_UE_F1AP_ID;
+  ie2->criticality = F1AP_Criticality_reject;
+  ie2->value.present = F1AP_PositioningInformationResponseIEs__value_PR_GNB_DU_UE_F1AP_ID;
+  ie2->value.choice.GNB_DU_UE_F1AP_ID = msg->gNB_DU_ue_id;
+  
+  /* optional */
+  /* c3. SRS Configuration */
+  if (msg->srs_configuration_length > 0) {
+    asn1cSequenceAdd(out->protocolIEs.list, F1AP_PositioningInformationResponseIEs_t, ie3);
+    ie3->id = F1AP_ProtocolIE_ID_id_SRSConfiguration;
+    ie3->criticality = F1AP_Criticality_ignore;
+    ie3->value.present = F1AP_PositioningInformationResponseIEs__value_PR_SRSConfiguration;
+    OCTET_STRING_fromBuf(&ie3->value.choice.SRSConfiguration, (char *)msg->srs_configuration, msg->srs_configuration_length);
+  }
+  
+  /* optional */
+  /* c4. SFN Initialisation Time */
+  if (msg->sfn_initialisation_time_length > 0) {
+    asn1cSequenceAdd(out->protocolIEs.list, F1AP_PositioningInformationResponseIEs_t, ie4);
+    ie4->id = F1AP_ProtocolIE_ID_id_SFNInitialisationTime;
+    ie4->criticality = F1AP_Criticality_ignore;
+    ie4->value.present = F1AP_PositioningInformationResponseIEs__value_PR_SFNInitialisationTime;
+    OCTET_STRING_fromBuf(&ie4->value.choice.SFNInitialisationTime, (char *)msg->sfn_initialisation_time, msg->sfn_initialisation_time_length);
+  }
+  
+  /* optional */
+  /* c5. Criticality Diagnostics */
+  if (msg->criticality_diagnostics_length > 0) {
+    asn1cSequenceAdd(out->protocolIEs.list, F1AP_PositioningInformationResponseIEs_t, ie5);
+    ie5->id = F1AP_ProtocolIE_ID_id_CriticalityDiagnostics;
+    ie5->criticality = F1AP_Criticality_ignore;
+    ie5->value.present = F1AP_PositioningInformationResponseIEs__value_PR_CriticalityDiagnostics;
+    OCTET_STRING_fromBuf(&ie5->value.choice.CriticalityDiagnostics, (char *)msg->criticality_diagnostics, msg->criticality_diagnostics_length);
+  }
+  
+  return pdu;
+}
+
+bool decode_f1ap_positioning_information_response(const F1AP_F1AP_PDU_t *pdu, f1ap_positioning_information_response_t *out)
+{
+  DevAssert(pdu != NULL && out != NULL);
+  memset(out, 0, sizeof(*out));
+  
+  F1AP_PositioningInformationResponse_t *container = &pdu->choice.successfulOutcome->value.choice.PositioningInformationResponse;
+  
+  for (int i = 0; i < container->protocolIEs.list.count; i++) {
+    F1AP_PositioningInformationResponseIEs_t *ie = container->protocolIEs.list.array[i];
+    
+    switch (ie->id) {
+      case F1AP_ProtocolIE_ID_id_gNB_CU_UE_F1AP_ID:
+        DevAssert(ie->value.present == F1AP_PositioningInformationResponseIEs__value_PR_GNB_CU_UE_F1AP_ID);
+        out->gNB_CU_ue_id = ie->value.choice.GNB_CU_UE_F1AP_ID;
+        break;
+        
+      case F1AP_ProtocolIE_ID_id_gNB_DU_UE_F1AP_ID:
+        DevAssert(ie->value.present == F1AP_PositioningInformationResponseIEs__value_PR_GNB_DU_UE_F1AP_ID);
+        out->gNB_DU_ue_id = ie->value.choice.GNB_DU_UE_F1AP_ID;
+        break;
+        
+      case F1AP_ProtocolIE_ID_id_SRSConfiguration:
+        if (ie->value.present == F1AP_PositioningInformationResponseIEs__value_PR_SRSConfiguration) {
+          out->srs_configuration_length = ie->value.choice.SRSConfiguration.size;
+          out->srs_configuration = malloc(out->srs_configuration_length);
+          memcpy(out->srs_configuration, ie->value.choice.SRSConfiguration.buf, out->srs_configuration_length);
+        }
+        break;
+        
+      case F1AP_ProtocolIE_ID_id_SFNInitialisationTime:
+        if (ie->value.present == F1AP_PositioningInformationResponseIEs__value_PR_SFNInitialisationTime) {
+          out->sfn_initialisation_time_length = ie->value.choice.SFNInitialisationTime.size;
+          out->sfn_initialisation_time = malloc(out->sfn_initialisation_time_length);
+          memcpy(out->sfn_initialisation_time, ie->value.choice.SFNInitialisationTime.buf, out->sfn_initialisation_time_length);
+        }
+        break;
+        
+      case F1AP_ProtocolIE_ID_id_CriticalityDiagnostics:
+        if (ie->value.present == F1AP_PositioningInformationResponseIEs__value_PR_CriticalityDiagnostics) {
+          out->criticality_diagnostics_length = ie->value.choice.CriticalityDiagnostics.size;
+          out->criticality_diagnostics = malloc(out->criticality_diagnostics_length);
+          memcpy(out->criticality_diagnostics, ie->value.choice.CriticalityDiagnostics.buf, out->criticality_diagnostics_length);
+        }
+        break;
+        
+      default:
+        return false;
+    }
+  }
+  
+  return true;
+}
+
+void free_f1ap_positioning_information_response(const f1ap_positioning_information_response_t *msg)
+{
+  DevAssert(msg != NULL);
+  
+  if (msg->srs_configuration) {
+    free(msg->srs_configuration);
+  }
+  
+  if (msg->sfn_initialisation_time) {
+    free(msg->sfn_initialisation_time);
+  }
+  
+  if (msg->criticality_diagnostics) {
+    free(msg->criticality_diagnostics);
+  }
+}
+
+f1ap_positioning_information_response_t cp_f1ap_positioning_information_response(const f1ap_positioning_information_response_t *msg)
+{
+  DevAssert(msg != NULL);
+  f1ap_positioning_information_response_t out;
+  memset(&out, 0, sizeof(out));
+  
+  out.gNB_CU_ue_id = msg->gNB_CU_ue_id;
+  out.gNB_DU_ue_id = msg->gNB_DU_ue_id;
+  
+  if (msg->srs_configuration_length > 0) {
+    out.srs_configuration_length = msg->srs_configuration_length;
+    out.srs_configuration = malloc(out.srs_configuration_length);
+    memcpy(out.srs_configuration, msg->srs_configuration, out.srs_configuration_length);
+  }
+  
+  if (msg->sfn_initialisation_time_length > 0) {
+    out.sfn_initialisation_time_length = msg->sfn_initialisation_time_length;
+    out.sfn_initialisation_time = malloc(out.sfn_initialisation_time_length);
+    memcpy(out.sfn_initialisation_time, msg->sfn_initialisation_time, out.sfn_initialisation_time_length);
+  }
+  
+  if (msg->criticality_diagnostics_length > 0) {
+    out.criticality_diagnostics_length = msg->criticality_diagnostics_length;
+    out.criticality_diagnostics = malloc(out.criticality_diagnostics_length);
+    memcpy(out.criticality_diagnostics, msg->criticality_diagnostics, out.criticality_diagnostics_length);
+  }
+  
+  return out;
+}
+
+bool eq_f1ap_positioning_information_response(const f1ap_positioning_information_response_t *a, const f1ap_positioning_information_response_t *b)
+{
+  DevAssert(a != NULL && b != NULL);
+  
+  if (a->gNB_CU_ue_id != b->gNB_CU_ue_id) return false;
+  if (a->gNB_DU_ue_id != b->gNB_DU_ue_id) return false;
+  
+  if (a->srs_configuration_length != b->srs_configuration_length) return false;
+  if (a->srs_configuration_length > 0 && memcmp(a->srs_configuration, b->srs_configuration, a->srs_configuration_length) != 0) return false;
+  
+  if (a->sfn_initialisation_time_length != b->sfn_initialisation_time_length) return false;
+  if (a->sfn_initialisation_time_length > 0 && memcmp(a->sfn_initialisation_time, b->sfn_initialisation_time, a->sfn_initialisation_time_length) != 0) return false;
+  
+  if (a->criticality_diagnostics_length != b->criticality_diagnostics_length) return false;
+  if (a->criticality_diagnostics_length > 0 && memcmp(a->criticality_diagnostics, b->criticality_diagnostics, a->criticality_diagnostics_length) != 0) return false;
+  
+  return true;
+}
