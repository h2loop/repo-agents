diff --git a/arch/renesas/src/rx65n/rx65n_usbhost.c b/arch/renesas/src/rx65n/rx65n_usbhost.c
index 040821bb..cd336b51 100644
--- a/arch/renesas/src/rx65n/rx65n_usbhost.c
+++ b/arch/renesas/src/rx65n/rx65n_usbhost.c
@@ -60,6 +60,25 @@
 #include "arch/rx65n/iodefine.h"
 #include "rx65n_cmtw.h"
 
+/****************************************************************************
+ * Private Functions
+ ****************************************************************************/
+
+/****************************************************************************
+ * Name: rx65n_wdt_service
+ *
+ * Description:
+ *   Service the watchdog timer to prevent reset during long-running operations
+ *
+ ****************************************************************************/
+
+static void rx65n_wdt_service(void)
+{
+  /* Service the watchdog timer by writing the refresh sequence */
+  WDT.WDTRR = 0x00;
+  WDT.WDTRR = 0xFF;
+}
+
 #define INTSTS0_BIT_VALUES_TO_ACK       (0xd870u)
 #define INTSTS1_BIT_VALUES_TO_ACK       (0xd870u)
 
@@ -3885,6 +3904,12 @@ static void usb_cstd_set_nak(uint16_t pipe)
         {
           n = 0xfffeu;
         }
+      
+      /* Service watchdog periodically to prevent reset */
+      if ((n & 0xFF) == 0)  /* Service every 256 iterations */
+        {
+          rx65n_wdt_service();
+        }
     }
 }
 
@@ -3959,6 +3984,7 @@ void usb_cstd_chg_curpipe(uint16_t pipe, uint16_t fifosel, uint16_t isel)
       do
         {
           buffer = hw_usb_read_fifosel(USB_CUSE);
+          rx65n_wdt_service();  /* Service watchdog to prevent reset */
         }
 
       while ((buffer & (USB_ISEL | USB_CURPIPE)) != (isel | pipe));
@@ -3984,6 +4010,7 @@ void usb_cstd_chg_curpipe(uint16_t pipe, uint16_t fifosel, uint16_t isel)
       do
         {
           buffer = hw_usb_read_fifosel(fifosel);
+          rx65n_wdt_service();  /* Service watchdog to prevent reset */
         }
       while ((buffer & USB_CURPIPE) != pipe);
       break;
