+/****************************************************************************
+ * Name: xmc4_bringdown
+ *
+ * Description:
+ *   Bring down board features
+ *
+ ****************************************************************************/
+
+int xmc4_bringdown(void)
+{
+  int ret = OK;
+
+#ifdef CONFIG_USERLED
+  /* Unregister the LED driver */
+
+  ret = userled_lower_uninitialize("/dev/userleds");
+  if (ret < 0)
+    {
+      syslog(LOG_ERR, "ERROR: userled_lower_uninitialize() failed: %d\n", ret);
+    }
+#endif
+
+  return ret;
+}
