--- a/drivers/leds/userled_upper.c
+++ b/drivers/leds/userled_upper.c
@@ -493,6 +493,46 @@ static int userled_ioctl(FAR struct file *filep, int cmd, unsigned long arg)
   return ret;
 }
 
+/****************************************************************************
+ * Private Functions
+ ****************************************************************************/
+
+/****************************************************************************
+ * Name: userled_unbind
+ *
+ * Description:
+ *   Unbind the user LED driver and free resources.
+ *
+ * Input Parameters:
+ *   priv - Pointer to the upper half driver structure
+ *
+ * Returned Value:
+ *   None
+ *
+ ****************************************************************************/
+
+static void userled_unbind(FAR struct userled_upperhalf_s *priv)
+{
+  FAR struct userled_open_s *opriv;
+  FAR struct userled_open_s *next;
+
+  /* Close all open instances */
+
+  for (opriv = priv->lu_open; opriv; opriv = next)
+    {
+      next = opriv->bo_flink;
+      kmm_free(opriv);
+    }
+
+  /* Destroy the mutex */
+
+  nxmutex_destroy(&priv->lu_lock);
+
+  /* Free the driver structure */
+
+  kmm_free(priv);
+}
+
 /****************************************************************************
  * Public Functions
  ****************************************************************************/
@@ -564,3 +604,48 @@ errout_with_priv:
   kmm_free(priv);
   return ret;
 }
+
+/****************************************************************************
+ * Name: userled_unregister
+ *
+ * Description:
+ *   Unregister the user LED driver and free all allocated resources.
+ *
+ * Input Parameters:
+ *   devname - The name of the LED device to be unregistered.
+ *
+ * Returned Value:
+ *   Zero (OK) is returned on success.  Otherwise a negated errno value is
+ *   returned to indicate the nature of the failure.
+ *
+ ****************************************************************************/
+
+int userled_unregister(FAR const char *devname)
+{
+  FAR struct inode *node;
+  FAR struct userled_upperhalf_s *priv;
+  int ret;
+
+  /* Find the inode for the driver */
+
+  node = find_inode(devname);
+  if (!node || !node->i_private)
+    {
+      return -ENODEV;
+    }
+
+  priv = (FAR struct userled_upperhalf_s *)node->i_private;
+
+  /* Unregister the driver */
+
+  ret = unregister_driver(devname);
+  if (ret < 0)
+    {
+      return ret;
+    }
+
+  /* Free the allocated resources */
+
+  userled_unbind(priv);
+  return OK;
+}
