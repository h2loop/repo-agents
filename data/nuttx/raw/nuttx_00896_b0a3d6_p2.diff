diff --git a/drivers/sensors/veml6070.c b/drivers/sensors/veml6070.c
index fad1aab0..293bab97 100644
--- a/drivers/sensors/veml6070.c
+++ b/drivers/sensors/veml6070.c
@@ -40,6 +40,8 @@
 #include <nuttx/i2c/i2c_master.h>
 #include <nuttx/sensors/veml6070.h>
 
+#include "inode/inode.h"
+
 #if defined(CONFIG_I2C) && defined(CONFIG_SENSORS_VEML6070)
 
 /****************************************************************************
@@ -284,6 +286,7 @@ int veml6070_register(FAR const char *devpath, FAR struct i2c_master_s *i2c,
   if (ret < 0)
     {
       snerr("ERROR: Failed to initialize the VEML6070!\n");
+      kmm_free(priv);
       return ret;
     }
 
@@ -299,4 +302,59 @@ int veml6070_register(FAR const char *devpath, FAR struct i2c_master_s *i2c,
   return ret;
 }
 
+/****************************************************************************
+ * Name: veml6070_unregister
+ *
+ * Description:
+ *   Unregister the VEML6070 character device
+ *
+ * Input Parameters:
+ *   devpath - The full path to the driver to unregister. E.g., "/dev/uvlight0"
+ *
+ * Returned Value:
+ *   Zero (OK) on success; a negated errno value on failure.
+ *
+ ****************************************************************************/
+
+int veml6070_unregister(FAR const char *devpath)
+{
+  FAR struct inode *inode;
+  FAR struct veml6070_dev_s *priv;
+  int ret;
+
+  /* Find the inode for the device */
+
+  ret = inode_find(devpath, &inode);
+  if (ret < 0)
+    {
+      snerr("ERROR: Failed to find inode for %s: %d\n", devpath, ret);
+      return ret;
+    }
+
+  /* Get the private data structure */
+
+  DEBUGASSERT(inode->i_private);
+  priv = inode->i_private;
+
+  /* Unregister the character driver */
+
+  ret = unregister_driver(devpath);
+  if (ret < 0)
+    {
+      snerr("ERROR: Failed to unregister driver: %d\n", ret);
+      inode_release(inode);
+      return ret;
+    }
+
+  /* Free the private data structure */
+
+  kmm_free(priv);
+
+  /* Release the inode reference */
+
+  inode_release(inode);
+
+  return OK;
+}
+
 #endif /* CONFIG_I2C && CONFIG_SENSORS_VEML6070 */
