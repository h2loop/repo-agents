diff --git a/fs/inode/fs_inode.c b/fs/inode/fs_inode.c
index b957a8cc..e369c2c3 100644
--- a/fs/inode/fs_inode.c
+++ b/fs/inode/fs_inode.c
@@ -76,6 +76,22 @@ void inode_lock(void)
   down_write(&g_inode_lock);
 }
 
+/****************************************************************************
+ * Name: inode_trylock
+ *
+ * Description:
+ *   Try to get writeable exclusive access to the in-memory inode tree.
+ *
+ * Returned Value:
+ *   True if the lock was acquired, false if it would block.
+ *
+ ****************************************************************************/
+
+bool inode_trylock(void)
+{
+  return down_write_trylock(&g_inode_lock) != 0;
+}
+
 /****************************************************************************
  * Name: inode_rlock
  *
@@ -89,6 +105,22 @@ void inode_rlock(void)
   down_read(&g_inode_lock);
 }
 
+/****************************************************************************
+ * Name: inode_tryrlock
+ *
+ * Description:
+ *   Try to get readable exclusive access to the in-memory inode tree.
+ *
+ * Returned Value:
+ *   True if the lock was acquired, false if it would block.
+ *
+ ****************************************************************************/
+
+bool inode_tryrlock(void)
+{
+  return down_read_trylock(&g_inode_lock) != 0;
+}
+
 /****************************************************************************
  * Name: inode_unlock
  *
diff --git a/fs/inode/fs_inodefind.c b/fs/inode/fs_inodefind.c
index f53b502b..aa73d019 100644
--- a/fs/inode/fs_inodefind.c
+++ b/fs/inode/fs_inodefind.c
@@ -28,8 +28,10 @@
 
 #include <assert.h>
 #include <errno.h>
+#include <stdbool.h>
 
 #include <nuttx/fs/fs.h>
+#include <nuttx/sched.h>
 
 #include "inode/inode.h"
 
@@ -47,6 +49,9 @@
  *   difference between inode_find() and inode_search is that inode_find()
  *   will lock the inode tree and increment the reference count on the inode.
  *
+ *   This function detects when it's called from interrupt context and uses
+ *   non-blocking operations to avoid undefined behavior.
+ *
  ****************************************************************************/
 
 int inode_find(FAR struct inode_search_s *desc)
@@ -57,7 +62,24 @@ int inode_find(FAR struct inode_search_s *desc)
    * references on the node.
    */
 
-  inode_rlock();
+  if (up_interrupt_context())
+    {
+      /* In interrupt context, use non-blocking operations */
+
+      if (!inode_tryrlock())
+        {
+          /* Would block, return EWOULDBLOCK */
+
+          return -EWOULDBLOCK;
+        }
+    }
+  else
+    {
+      /* In normal context, use blocking operations */
+
+      inode_rlock();
+    }
+
   ret = inode_search(desc);
   if (ret >= 0)
     {
@@ -71,6 +93,14 @@ int inode_find(FAR struct inode_search_s *desc)
       atomic_fetch_add(&inode->i_crefs, 1);
     }
 
-  inode_runlock();
+  if (up_interrupt_context())
+    {
+      inode_runlock();
+    }
+  else
+    {
+      inode_runlock();
+    }
+
   return ret;
 }
