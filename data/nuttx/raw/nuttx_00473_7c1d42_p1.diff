diff --git a/arch/xtensa/src/common/espressif/esp_dedic_gpio.c b/arch/xtensa/src/common/espressif/esp_dedic_gpio.c
index a1780a54..7f073437 100644
--- a/arch/xtensa/src/common/espressif/esp_dedic_gpio.c
+++ b/arch/xtensa/src/common/espressif/esp_dedic_gpio.c
@@ -698,8 +698,38 @@ struct file *esp_dedic_gpio_new_bundle(
 
   dedic_gpio_common[cpu].refs++;
 
-  register_driver(config->path, &dedic_gpio_ops,
-                  0666, priv);
+  if (register_driver(config->path, &dedic_gpio_ops,
+                      0666, priv) < 0)
+    {
+      gpioerr("ERROR: Failed to register driver %s\n", config->path);
+      
+      /* Clean up allocated resources */
+      flags = spin_lock_irqsave(&dedic_gpio_common[cpu].spinlock);
+      dedic_gpio_common[cpu].refs--;
+      
+      if (out_mask)
+        {
+          dedic_gpio_common[cpu].out_occupied_mask &= ~out_mask;
+        }
+        
+      if (in_mask)
+        {
+          dedic_gpio_common[cpu].in_occupied_mask &= ~in_mask;
+        }
+        
+      if (dedic_gpio_common[cpu].refs == 0)
+        {
+          PERIPH_RCC_ATOMIC()
+            {
+              dedic_gpio_ll_enable_bus_clock(false);
+            }
+        }
+        
+      spin_unlock_irqrestore(&dedic_gpio_common[cpu].spinlock, flags);
+      free(priv);
+      return NULL;
+    }
+    
   return (struct file *)priv;
 }
 
diff --git a/boards/xtensa/esp32s3/esp32s3-devkit/src/esp32s3_gpio.c b/boards/xtensa/esp32s3/esp32s3-devkit/src/esp32s3_gpio.c
index df719860..d1bc7d8d 100644
--- a/boards/xtensa/esp32s3/esp32s3-devkit/src/esp32s3_gpio.c
+++ b/boards/xtensa/esp32s3/esp32s3-devkit/src/esp32s3_gpio.c
@@ -451,6 +451,10 @@ int esp32s3_gpio_init(void)
 {
   int pincount = 0;
   int i;
+  int ret;
+#ifdef CONFIG_ESPRESSIF_DEDICATED_GPIO
+  FAR struct file *temp_dedicated_gpio = NULL;
+#endif
 
 #if BOARD_NGPIOOUT > 0
   for (i = 0; i < BOARD_NGPIOOUT; i++)
@@ -510,8 +514,14 @@ int esp32s3_gpio_init(void)
 #endif
 
 #ifdef CONFIG_ESPRESSIF_DEDICATED_GPIO
-  dedicated_gpio = esp_dedic_gpio_new_bundle(&dedic_gpio_conf);
+  temp_dedicated_gpio = esp_dedic_gpio_new_bundle(&dedic_gpio_conf);
+  if (temp_dedicated_gpio == NULL)
+    {
+      syslog(LOG_ERR, "ERROR: Failed to initialize dedicated GPIO\n");
+      return -ENOMEM;
+    }
 
+  dedicated_gpio = temp_dedicated_gpio;
   pincount++;
 #endif
 
