FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# System deps for code navigation and basic C/C++ tooling
# NOT a full OAI5G build — just enough for SWE-agent to navigate and make lightweight checks
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ cmake make \
    clang-format cscope universal-ctags \
    git python3 python3-pip \
    grep findutils coreutils diffutils patch \
    less file tree \
    && rm -rf /var/lib/apt/lists/*

# Argument for which commit to check out
ARG REPO_COMMIT=HEAD

# Argument for which repo directory to copy (set via --build-arg or defaults to openairinterface5g)
ARG REPO_DIR=openairinterface5g

# Argument for container-internal repo path
ARG CONTAINER_REPO_PATH=/repo

# Copy repo source into container
COPY ${REPO_DIR}/ ${CONTAINER_REPO_PATH}/

# If a specific commit is requested, check it out
RUN cd ${CONTAINER_REPO_PATH} && if [ "$REPO_COMMIT" != "HEAD" ]; then git checkout "$REPO_COMMIT"; fi

# Initialize git for tracking agent changes
RUN cd ${CONTAINER_REPO_PATH} && git config user.email "sera-agent@local" && git config user.name "SERA Agent"

WORKDIR ${CONTAINER_REPO_PATH}
